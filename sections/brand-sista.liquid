{% comment %}
  Brand Page: SISTA — Peace · Love · Unity
  Soulful womenswear brand. Birmingham 1983.
  Spiritual, inclusive, feminine — not novelty or retro merch.
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}
{%- if sista_col == blank or sista_col.products_count == 0 -%}
  {%- assign sista_col = collections['sista-1'] -%}
{%- endif -%}

<!-- ============================================================
     HERO — Ethereal flowing gradient with logo reveal
     ============================================================ -->
<section class="si-hero" id="si-top">
  <!-- Flowing aurora gradient -->
  <div class="si-aurora" aria-hidden="true">
    <div class="si-aurora-1"></div>
    <div class="si-aurora-2"></div>
    <div class="si-aurora-3"></div>
  </div>

  <!-- Soft floating petals -->
  <div class="si-petals" aria-hidden="true">
    <div class="si-petal" style="--p:0"></div>
    <div class="si-petal" style="--p:1"></div>
    <div class="si-petal" style="--p:2"></div>
    <div class="si-petal" style="--p:3"></div>
    <div class="si-petal" style="--p:4"></div>
    <div class="si-petal" style="--p:5"></div>
    <div class="si-petal" style="--p:6"></div>
    <div class="si-petal" style="--p:7"></div>
  </div>

  <div class="si-hero-content">
    <div class="si-hero-tag">
      <span class="si-tag-line"></span>
      <span>Peace · Love · Unity</span>
    </div>

    <!-- Main Logo -->
    <div class="si-hero-logo">
      <img src="{{ 'logo-sista-main.jpeg' | asset_url }}" alt="SISTA" class="si-logo-img" />
    </div>

    <h1 class="si-hero-h1">
      <span class="si-h1-word">S</span><span class="si-h1-word si-h1-accent">I</span><span class="si-h1-word">S</span><span class="si-h1-word si-h1-accent">T</span><span class="si-h1-word">A</span>
    </h1>

    <p class="si-hero-sub">{{ section.settings.tagline | default: 'A universal womenswear brand built on sisterhood, connection and self-expression. Created for women of every colour, every shape and every walk of life.' }}</p>

    <div class="si-hero-actions">
      <a class="si-btn" href="#si-shop">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Shop The Collection
      </a>
      <div class="si-stats">
        <div class="si-stat"><span class="si-stat-val">1983</span><span class="si-stat-lbl">Birmingham</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-val">Unity</span><span class="si-stat-lbl">Sisterhood</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-val">Soul</span><span class="si-stat-lbl">Spirit</span></div>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="si-scroll" aria-hidden="true">
    <div class="si-scroll-bar"><div class="si-scroll-fill"></div></div>
    <span>Explore</span>
  </div>
</section>

<!-- ============================================================
     TICKER — Gentle flowing mantra
     ============================================================ -->
<div class="si-ticker">
  <div class="si-ticker-track">
    {%- for i in (1..2) -%}
    <div class="si-ticker-set">
      <span>PEACE</span><span class="si-tdot">♡</span>
      <span>LOVE</span><span class="si-tdot">♡</span>
      <span>UNITY</span><span class="si-tdot">♡</span>
      <span>SISTA</span><span class="si-tdot">♡</span>
      <span>SISTERHOOD</span><span class="si-tdot">♡</span>
      <span>CONNECTION</span><span class="si-tdot">♡</span>
      <span>SPIRIT</span><span class="si-tdot">♡</span>
      <span>SELF-EXPRESSION</span><span class="si-tdot">♡</span>
    </div>
    {%- endfor -%}
  </div>
</div>

<!-- ============================================================
     STORY — Sisterhood split with second logo
     ============================================================ -->
<section class="si-story">
  <div class="si-story-visual">
    <div class="si-story-glow" aria-hidden="true"></div>
    <div class="si-story-logo-wrap">
      <img src="{{ 'logo-sista-text.jpeg' | asset_url }}" alt="SISTA" class="si-story-logo" />
    </div>
    <div class="si-story-badge">
      <span>Est.</span>
      <strong>1983</strong>
    </div>
  </div>
  <div class="si-story-text">
    <div class="si-eyebrow">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      The Story
    </div>
    <h2 class="si-story-h2">Built on<br><em>sisterhood.</em></h2>
    <p class="si-story-p">{{ section.settings.story_text | default: "Born in Birmingham in 1983, SISTA is a universal womenswear brand built on peace, love and unity. Created for women of every colour, every shape and every walk of life — SISTA represents sisterhood. A shared energy that brings women together across cultures, generations and communities." }}</p>
    <div class="si-values">
      <span class="si-value">Peace</span>
      <span class="si-value">Love</span>
      <span class="si-value">Unity</span>
      <span class="si-value">Spirit</span>
      <span class="si-value">Connection</span>
    </div>
  </div>
</section>

<!-- ============================================================
     MANIFESTO — Full-width emotional statement
     ============================================================ -->
<section class="si-manifesto">
  <div class="si-manifesto-inner">
    <blockquote class="si-quote">
      "More than clothing — SISTA represents <em>sisterhood.</em> A shared energy that brings women together across cultures, generations and communities."
    </blockquote>
    <div class="si-manifesto-line"></div>
    <p class="si-manifesto-attr">Peace · Love · Unity — Since 1983</p>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Elegant grid
     ============================================================ -->
<section class="si-shop" id="si-shop">
  <div class="si-shop-inner">
    <div class="si-shop-head">
      <div>
        <div class="si-eyebrow-sm">The Collection</div>
        <h2 class="si-shop-h2">For Every Woman.</h2>
      </div>
      <div>
        <p class="si-shop-desc">Soulful womenswear rooted in connection, spirit and self-expression. Every colour, every shape, every walk of life.</p>
        <div class="si-filters">
          <button class="si-filter active" data-filter="all">All</button>
          <button class="si-filter" data-filter="tee">T-Shirts</button>
          <button class="si-filter" data-filter="hood">Hoodies</button>
          <button class="si-filter" data-filter="acc">Accessories</button>
        </div>
      </div>
    </div>

    <div class="si-grid" id="si-product-grid">
      {%- assign si_count = 0 -%}
      {%- for product in sista_col.products limit: 500 -%}
        {%- assign vd = product.vendor | downcase -%}
        {%- unless vd contains 'sista' -%}{%- continue -%}{%- endunless -%}
        {%- assign si_count = si_count | plus: 1 -%}
        {%- assign filter_tag = 'acc' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}
          {%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' or tl contains 'longsleeve' -%}
          {%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="si-prod" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="si-prod-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="si-badge">SALE</span>
            {%- endif -%}
            <div class="si-prod-hover">
              <span>View</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
          </div>
          <div class="si-prod-info">
            <span class="si-prod-type">{{ product.type | default: 'SISTA' }}</span>
            <div class="si-prod-name">{{ product.title }}</div>
            <div class="si-prod-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
      {%- if si_count == 0 -%}
        <div class="si-empty">No SISTA products found. Check back soon.</div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING — Emotional CTA
     ============================================================ -->
<section class="si-closing">
  <div class="si-closing-aurora" aria-hidden="true">
    <div class="si-ca-1"></div>
    <div class="si-ca-2"></div>
  </div>
  <div class="si-closing-inner">
    <div class="si-closing-logo">
      <img src="{{ 'logo-sista-main.jpeg' | asset_url }}" alt="SISTA" />
    </div>
    <h2 class="si-closing-h2">Peace. Love.<br><em>Unity.</em></h2>
    <p>For women of every colour, every shape and every walk of life. Sisterhood — always.</p>
    <a class="si-btn" href="#si-shop">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Shop SISTA
    </a>
  </div>
</section>

<!-- ============================================================
     STYLES — Soulful, feminine, flowing
     ============================================================ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Great+Vibes&display=swap');

:root {
  --si-rose: #DB2777;
  --si-pink: #F472B6;
  --si-blush: #FDF2F8;
  --si-gold: #CA8A04;
  --si-gold-dim: rgba(202,138,4,.12);
  --si-plum: #831843;
  --si-deep: #1a0812;
  --si-warm: #fef7f0;
  --si-white: #fefcfb;
  --si-grey: rgba(131,24,67,.5);
  --si-serif: 'Cormorant Infant', Georgia, serif;
  --si-script: 'Great Vibes', cursive;
  --si-body: 'Poppins', var(--body), sans-serif;
  --si-mono: var(--mono), monospace;
}

/* ---- HERO ---- */
.si-hero {
  position: relative;
  min-height: 100vh;
  min-height: 100dvh;
  background: linear-gradient(160deg, #1a0812 0%, #2d0a1e 30%, #1a0812 60%, #0f0a18 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 120px 40px 80px;
  text-align: center;
}
@media(max-width:768px){.si-hero{padding:100px 20px 60px;}}

/* Aurora gradients */
.si-aurora { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.si-aurora-1 {
  position: absolute; width: 120%; height: 120%; top: -30%; left: -10%;
  background: radial-gradient(ellipse at 30% 50%, rgba(219,39,119,.15) 0%, transparent 60%);
  animation: si-aurora-drift 12s ease-in-out infinite alternate;
}
.si-aurora-2 {
  position: absolute; width: 100%; height: 100%; top: 10%; right: -20%;
  background: radial-gradient(ellipse at 70% 40%, rgba(244,114,182,.1) 0%, transparent 55%);
  animation: si-aurora-drift 15s ease-in-out infinite alternate-reverse;
}
.si-aurora-3 {
  position: absolute; width: 80%; height: 80%; bottom: -10%; left: 20%;
  background: radial-gradient(ellipse at 50% 80%, rgba(202,138,4,.06) 0%, transparent 50%);
  animation: si-aurora-drift 18s ease-in-out infinite alternate;
}
@keyframes si-aurora-drift {
  0% { transform: translate(0,0) scale(1); }
  100% { transform: translate(30px,-20px) scale(1.1); }
}

/* Floating petals */
.si-petals { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.si-petal {
  position: absolute;
  width: 6px; height: 6px;
  border-radius: 50% 0 50% 0;
  background: rgba(244,114,182,.15);
  animation: si-float 14s ease-in-out infinite;
  animation-delay: calc(var(--p) * -1.8s);
  left: calc(var(--p) * 12%);
  top: calc(var(--p) * 8% + 10%);
}
.si-petal:nth-child(odd) { background: rgba(219,39,119,.12); width: 8px; height: 8px; }
.si-petal:nth-child(3n) { background: rgba(202,138,4,.1); border-radius: 50%; }
@keyframes si-float {
  0%,100% { transform: translateY(0) rotate(0deg); opacity: .3; }
  25% { transform: translateY(-60px) rotate(45deg); opacity: .6; }
  50% { transform: translateY(-120px) rotate(90deg); opacity: .3; }
  75% { transform: translateY(-60px) rotate(135deg); opacity: .5; }
}

/* Hero content */
.si-hero-content { position: relative; z-index: 2; max-width: 720px; }
.si-hero-tag {
  display: inline-flex; align-items: center; gap: 14px;
  font-family: var(--si-mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--si-pink); margin-bottom: 32px;
}
.si-tag-line { display: block; width: 32px; height: 1px; background: var(--si-pink); }

.si-hero-logo { margin-bottom: 24px; }
.si-hero-logo .si-logo-img {
  width: clamp(120px, 22vw, 200px); height: auto;
  border-radius: 50%; object-fit: cover;
  box-shadow: 0 0 60px rgba(219,39,119,.25), 0 0 120px rgba(219,39,119,.1);
  animation: si-logo-glow 4s ease-in-out infinite alternate;
}
@keyframes si-logo-glow {
  0% { box-shadow: 0 0 40px rgba(219,39,119,.2), 0 0 80px rgba(219,39,119,.05); }
  100% { box-shadow: 0 0 60px rgba(219,39,119,.35), 0 0 120px rgba(219,39,119,.12); }
}

.si-hero-h1 {
  font-family: var(--si-serif); font-size: clamp(48px, 8vw, 96px); font-weight: 300;
  letter-spacing: .15em; text-transform: uppercase; color: var(--si-white);
  margin: 0 0 24px; line-height: 1;
}
.si-h1-accent { color: var(--si-pink); text-shadow: 0 0 40px rgba(219,39,119,.3); }

.si-hero-sub {
  font-family: var(--si-serif); font-size: 17px; font-weight: 300; font-style: italic;
  line-height: 1.8; color: rgba(254,252,251,.55); margin: 0 0 40px; max-width: 520px;
  margin-left: auto; margin-right: auto;
}

.si-hero-actions { display: flex; align-items: center; justify-content: center; gap: 36px; flex-wrap: wrap; }

.si-btn {
  display: inline-flex; align-items: center; gap: 10px;
  background: linear-gradient(135deg, var(--si-rose) 0%, var(--si-pink) 100%);
  color: #fff; font-family: var(--si-mono); font-size: 11px; letter-spacing: .14em;
  text-transform: uppercase; text-decoration: none; padding: 16px 30px; font-weight: 600;
  cursor: pointer; transition: all .3s; border-radius: 2px;
}
.si-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(219,39,119,.35); }

.si-stats { display: flex; align-items: center; gap: 20px; }
.si-stat { display: flex; flex-direction: column; gap: 2px; }
.si-stat-val { font-family: var(--si-serif); font-size: 22px; font-weight: 600; color: var(--si-white); line-height: 1; }
.si-stat-lbl { font-family: var(--si-mono); font-size: 9px; letter-spacing: .15em; text-transform: uppercase; color: rgba(254,252,251,.3); }
.si-stat-sep { width: 1px; height: 32px; background: rgba(254,252,251,.1); }

/* Scroll */
.si-scroll {
  position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
  display: flex; align-items: center; gap: 12px;
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .15em; text-transform: uppercase;
  color: rgba(254,252,251,.2);
}
.si-scroll-bar { width: 40px; height: 1px; background: rgba(254,252,251,.1); position: relative; overflow: hidden; }
.si-scroll-fill { position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--si-pink); animation: si-scr 2s ease infinite; }
@keyframes si-scr { to { left: 100%; } }

/* ---- TICKER ---- */
.si-ticker {
  background: linear-gradient(135deg, var(--si-rose) 0%, var(--si-pink) 100%);
  padding: 14px 0; overflow: hidden; white-space: nowrap;
}
.si-ticker-track { display: flex; width: max-content; animation: si-tick 28s linear infinite; }
.si-ticker-set {
  display: flex; align-items: center; gap: 24px; padding-right: 24px; flex-shrink: 0;
  font-family: var(--si-serif); font-size: 14px; font-weight: 600; letter-spacing: .15em;
  text-transform: uppercase; color: #fff;
}
.si-tdot { opacity: .5; font-size: 12px; }
@keyframes si-tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ---- STORY ---- */
.si-story {
  display: grid; grid-template-columns: 1fr 1.4fr; min-height: 560px;
  background: var(--si-blush);
}
@media(max-width:900px){.si-story{grid-template-columns:1fr;}}

.si-story-visual {
  background: linear-gradient(160deg, #fce7f3 0%, #fdf2f8 100%);
  display: flex; align-items: center; justify-content: center; padding: 60px 40px;
  position: relative; border-right: 1px solid rgba(219,39,119,.08);
}
@media(max-width:900px){.si-story-visual{min-height:340px;border-right:none;border-bottom:1px solid rgba(219,39,119,.08);}}

.si-story-glow {
  position: absolute; width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle, rgba(219,39,119,.08) 0%, transparent 70%);
  pointer-events: none;
}
.si-story-logo-wrap { position: relative; z-index: 2; }
.si-story-logo {
  width: clamp(180px, 30vw, 280px); height: auto; object-fit: contain;
  filter: drop-shadow(0 8px 24px rgba(131,24,67,.15));
}
.si-story-badge {
  position: absolute; bottom: 20px; right: 20px;
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .15em; text-transform: uppercase;
  color: var(--si-rose); display: flex; flex-direction: column; align-items: center; gap: 2px;
}
.si-story-badge strong { font-family: var(--si-serif); font-size: 22px; font-weight: 600; }

.si-story-text { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; gap: 24px; }
@media(max-width:768px){.si-story-text{padding:48px 24px;}}

.si-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--si-rose);
}
.si-story-h2 {
  font-family: var(--si-serif); font-size: clamp(32px, 4.5vw, 52px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .05em; line-height: 1.1; color: var(--si-plum); margin: 0;
}
.si-story-h2 em { font-style: italic; color: var(--si-rose); }
.si-story-p {
  font-family: var(--si-serif); font-size: 15px; font-weight: 400; line-height: 1.85;
  color: rgba(131,24,67,.6); max-width: 480px; margin: 0;
}
.si-values { display: flex; gap: 8px; flex-wrap: wrap; }
.si-value {
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase;
  padding: 6px 14px; border: 1px solid rgba(219,39,119,.15); color: var(--si-rose);
  transition: all .25s; cursor: default; border-radius: 2px;
}
.si-value:hover { background: var(--si-rose); color: #fff; border-color: var(--si-rose); }

/* ---- MANIFESTO ---- */
.si-manifesto {
  background: var(--si-deep); padding: 100px 40px; text-align: center; position: relative; overflow: hidden;
}
@media(max-width:768px){.si-manifesto{padding:60px 20px;}}
.si-manifesto-inner { max-width: 800px; margin: 0 auto; position: relative; z-index: 2; }
.si-quote {
  font-family: var(--si-serif); font-size: clamp(22px, 3.5vw, 36px); font-weight: 300;
  font-style: italic; line-height: 1.6; color: rgba(254,252,251,.85); margin: 0;
}
.si-quote em { font-style: normal; color: var(--si-pink); }
.si-manifesto-line { width: 60px; height: 1px; background: var(--si-rose); margin: 32px auto; opacity: .5; }
.si-manifesto-attr {
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: rgba(244,114,182,.4);
}

/* ---- SHOP ---- */
.si-shop { background: var(--si-blush); padding: 80px 60px; }
@media(max-width:768px){.si-shop{padding:48px 20px;}}
.si-shop-inner { max-width: 1200px; margin: 0 auto; }
.si-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px){.si-shop-head{grid-template-columns:1fr;}}
.si-eyebrow-sm { font-family: var(--si-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--si-rose); }
.si-shop-h2 {
  font-family: var(--si-serif); font-size: clamp(36px, 5vw, 56px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .05em; line-height: 1; margin: 8px 0 0; color: var(--si-plum);
}
.si-shop-desc { font-family: var(--si-serif); font-size: 14px; font-weight: 400; line-height: 1.75; color: rgba(131,24,67,.45); font-style: italic; }
.si-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
.si-filter {
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
  padding: 9px 18px; border: 1px solid rgba(219,39,119,.2); background: transparent;
  color: var(--si-plum); cursor: pointer; transition: all .25s; border-radius: 2px;
}
.si-filter:hover, .si-filter.active { background: var(--si-rose); color: #fff; border-color: var(--si-rose); }

.si-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; }
.si-prod { text-decoration: none; color: inherit; cursor: pointer; transition: transform .3s; }
.si-prod:hover { transform: translateY(-6px); }
.si-prod-img { position: relative; overflow: hidden; background: #fce7f3; aspect-ratio: 1; border-radius: 4px; }
.si-prod-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.si-prod:hover .si-prod-img img { transform: scale(1.06); }
.si-prod-hover {
  position: absolute; inset: 0; background: rgba(26,8,18,.65);
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase;
  color: var(--si-pink); opacity: 0; transition: opacity .3s; border-radius: 4px;
}
.si-prod:hover .si-prod-hover { opacity: 1; }
.si-no-img {
  width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
  font-family: var(--si-script); font-size: 28px; color: rgba(219,39,119,.2);
}
.si-badge {
  position: absolute; top: 12px; right: 12px;
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .1em;
  background: var(--si-rose); color: #fff; padding: 4px 10px; font-weight: 700; border-radius: 2px;
}
.si-prod-info { padding: 16px 0; }
.si-prod-type { font-family: var(--si-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--si-rose); }
.si-prod-name { font-family: var(--si-serif); font-size: 15px; font-weight: 500; color: var(--si-plum); margin: 6px 0 4px; }
.si-prod-price { font-family: var(--si-mono); font-size: 13px; color: var(--si-grey); }
.si-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--si-mono); font-size: 11px; letter-spacing: .12em; color: rgba(219,39,119,.3); text-transform: uppercase; }

/* ---- CLOSING ---- */
.si-closing {
  background: var(--si-deep); padding: 100px 40px; text-align: center; position: relative; overflow: hidden;
}
@media(max-width:768px){.si-closing{padding:60px 20px;}}
.si-closing-aurora { position: absolute; inset: 0; pointer-events: none; }
.si-ca-1 {
  position: absolute; width: 100%; height: 100%;
  background: radial-gradient(ellipse at 30% 60%, rgba(219,39,119,.1) 0%, transparent 50%);
  animation: si-aurora-drift 14s ease-in-out infinite alternate;
}
.si-ca-2 {
  position: absolute; width: 100%; height: 100%;
  background: radial-gradient(ellipse at 70% 30%, rgba(244,114,182,.06) 0%, transparent 50%);
  animation: si-aurora-drift 18s ease-in-out infinite alternate-reverse;
}
.si-closing-inner { max-width: 600px; margin: 0 auto; position: relative; z-index: 2; }
.si-closing-logo img {
  width: 100px; height: 100px; border-radius: 50%; object-fit: cover; margin-bottom: 32px;
  box-shadow: 0 0 40px rgba(219,39,119,.2);
}
.si-closing-h2 {
  font-family: var(--si-serif); font-size: clamp(32px, 5vw, 56px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .05em; line-height: 1.1; color: var(--si-white); margin: 0 0 20px;
}
.si-closing-h2 em { font-style: italic; color: var(--si-pink); }
.si-closing-inner p {
  font-family: var(--si-serif); font-size: 15px; font-weight: 300; font-style: italic;
  line-height: 1.75; color: rgba(254,252,251,.5); margin: 0 0 32px;
}

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce){
  .si-aurora-1,.si-aurora-2,.si-aurora-3,.si-petal,.si-scroll-fill,.si-ticker-track,.si-ca-1,.si-ca-2,.si-logo-img{animation:none!important;}
  .si-prod:hover{transform:none;}
}
</style>

<!-- ============================================================
     SCRIPTS — Motion.dev animations
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  /* Filters */
  var fBtns = document.querySelectorAll('.si-filter');
  var cards = document.querySelectorAll('.si-prod');
  fBtns.forEach(function(b) {
    b.addEventListener('click', function() {
      var f = this.dataset.filter;
      fBtns.forEach(function(x) { x.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });

  /* Motion.dev */
  if (window.Motion) {
    var M = window.Motion;
    M.animate('.si-hero-tag', { opacity: [0,1], y: [-10,0] }, { duration: .6, delay: .3 });
    M.animate('.si-hero-logo', { opacity: [0,1], scale: [.8,1] }, { duration: 1, delay: .5, easing: [.22,1,.36,1] });
    M.animate('.si-hero-h1', { opacity: [0,1], y: [30,0] }, { duration: .8, delay: .8, easing: [.22,1,.36,1] });
    M.animate('.si-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: 1.1 });
    M.animate('.si-hero-actions', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: 1.3 });

    M.inView('.si-story-visual', function() {
      M.animate('.si-story-logo-wrap', { opacity: [0,1], scale: [.85,1] }, { duration: .8, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    M.inView('.si-story-text', function() {
      M.animate('.si-story-text > *', { opacity: [0,1], x: [30,0] }, { delay: M.stagger(.1), duration: .6, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    M.inView('.si-manifesto-inner', function() {
      M.animate('.si-quote', { opacity: [0,1], y: [30,0] }, { duration: .8, easing: [.22,1,.36,1] });
      M.animate('.si-manifesto-line', { scaleX: [0,1] }, { duration: .6, delay: .3 });
      M.animate('.si-manifesto-attr', { opacity: [0,1] }, { duration: .5, delay: .5 });
    }, { margin: '-10% 0px' });

    document.querySelectorAll('.si-prod').forEach(function(c) {
      M.inView(c, function() {
        M.animate(c, { opacity: [0,1], y: [25,0] }, { duration: .5, easing: [.22,1,.36,1] });
      }, { margin: '-5% 0px' });
    });

    M.inView('.si-closing-inner', function() {
      M.animate('.si-closing-logo', { opacity: [0,1], scale: [.7,1] }, { duration: .8, easing: [.22,1,.36,1] });
      M.animate('.si-closing-h2', { opacity: [0,1], y: [30,0] }, { duration: .7, delay: .2, easing: [.22,1,.36,1] });
      M.animate('.si-closing-inner p', { opacity: [0,1], y: [15,0] }, { duration: .6, delay: .4 });
      M.animate('.si-closing-inner .si-btn', { opacity: [0,1], y: [15,0] }, { duration: .6, delay: .5 });
    }, { margin: '-10% 0px' });
  }
});
</script>

