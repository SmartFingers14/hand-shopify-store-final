{% comment %}
  Brand Page: SISTA — Peace · Love · Unity
  Soulful womenswear. Birmingham 1983.
  ✦ BLINGY · SHIMMER · WOW ✦
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}
{%- if sista_col == blank or sista_col.products_count == 0 -%}
  {%- assign sista_col = collections['sista-1'] -%}
{%- endif -%}

<!-- ============================================================
     HERO — Cinematic shimmer with sparkle particles
     ============================================================ -->
<section class="si-hero" id="si-top">
  <!-- Shimmer overlay -->
  <div class="si-shimmer" aria-hidden="true"></div>

  <!-- Sparkle particles -->
  <div class="si-sparkles" aria-hidden="true">
    <div class="si-spark" style="--sx:15%;--sy:20%;--sd:0s"></div>
    <div class="si-spark" style="--sx:85%;--sy:30%;--sd:.4s"></div>
    <div class="si-spark" style="--sx:25%;--sy:70%;--sd:.8s"></div>
    <div class="si-spark" style="--sx:70%;--sy:15%;--sd:1.2s"></div>
    <div class="si-spark" style="--sx:50%;--sy:80%;--sd:1.6s"></div>
    <div class="si-spark" style="--sx:90%;--sy:65%;--sd:2s"></div>
    <div class="si-spark" style="--sx:10%;--sy:50%;--sd:2.4s"></div>
    <div class="si-spark" style="--sx:60%;--sy:45%;--sd:2.8s"></div>
    <div class="si-spark" style="--sx:35%;--sy:90%;--sd:3.2s"></div>
    <div class="si-spark" style="--sx:78%;--sy:85%;--sd:3.6s"></div>
    <div class="si-spark" style="--sx:42%;--sy:12%;--sd:4s"></div>
    <div class="si-spark" style="--sx:5%;--sy:88%;--sd:4.4s"></div>
  </div>

  <!-- Radial glows -->
  <div class="si-glow si-glow-1" aria-hidden="true"></div>
  <div class="si-glow si-glow-2" aria-hidden="true"></div>
  <div class="si-glow si-glow-3" aria-hidden="true"></div>

  <div class="si-hero-content">
    <div class="si-hero-tag">
      <span class="si-diamond">✦</span>
      <span>Peace · Love · Unity</span>
      <span class="si-diamond">✦</span>
    </div>

    <!-- Main Logo — centered, bg removed -->
    <div class="si-hero-logo">
      <div class="si-logo-ring"></div>
      <img src="{{ 'logo-sista-main.jpeg' | asset_url }}" alt="SISTA" class="si-logo-img" />
    </div>

    <h1 class="si-hero-h1">
      <span class="si-letter">S</span><span class="si-letter si-gold">I</span><span class="si-letter">S</span><span class="si-letter si-gold">T</span><span class="si-letter">A</span>
    </h1>

    <p class="si-hero-sub">{{ section.settings.tagline | default: 'A universal womenswear brand built on sisterhood, connection and self-expression. Created for women of every colour, every shape and every walk of life.' }}</p>

    <div class="si-hero-actions">
      <a class="si-btn-gold" href="#si-shop">
        <span class="si-btn-shine"></span>
        ✦ Shop The Collection
      </a>
      <div class="si-stats">
        <div class="si-stat"><span class="si-stat-val">1983</span><span class="si-stat-lbl">Est.</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-val">B'ham</span><span class="si-stat-lbl">Born</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-val">Unity</span><span class="si-stat-lbl">Spirit</span></div>
      </div>
    </div>
  </div>

  <div class="si-scroll" aria-hidden="true">
    <div class="si-scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     TICKER — Gold shimmer
     ============================================================ -->
<div class="si-ticker">
  <div class="si-ticker-track">
    {%- for i in (1..2) -%}
    <div class="si-ticker-set">
      <span>PEACE</span><span class="si-tdot">✦</span>
      <span>LOVE</span><span class="si-tdot">✦</span>
      <span>UNITY</span><span class="si-tdot">✦</span>
      <span>SISTA</span><span class="si-tdot">✦</span>
      <span>SISTERHOOD</span><span class="si-tdot">✦</span>
      <span>SPIRIT</span><span class="si-tdot">✦</span>
      <span>CONNECTION</span><span class="si-tdot">✦</span>
      <span>SELF-EXPRESSION</span><span class="si-tdot">✦</span>
    </div>
    {%- endfor -%}
  </div>
</div>

<!-- ============================================================
     STORY — Luxe split with second logo
     ============================================================ -->
<section class="si-story">
  <div class="si-story-visual">
    <div class="si-story-shimmer" aria-hidden="true"></div>
    <div class="si-story-logo-wrap">
      <img src="{{ 'logo-sista-text.jpeg' | asset_url }}" alt="SISTA" class="si-story-logo" />
    </div>
  </div>
  <div class="si-story-text">
    <div class="si-eyebrow">✦ The Story</div>
    <h2 class="si-story-h2">Built on<br><em>sisterhood.</em></h2>
    <p class="si-story-p">{{ section.settings.story_text | default: "Born in Birmingham in 1983, SISTA is a universal womenswear brand built on peace, love and unity. Created for women of every colour, every shape and every walk of life — SISTA represents sisterhood. A shared energy that brings women together across cultures, generations and communities." }}</p>
    <div class="si-values">
      <span class="si-value">✦ Peace</span>
      <span class="si-value">✦ Love</span>
      <span class="si-value">✦ Unity</span>
      <span class="si-value">✦ Spirit</span>
    </div>
  </div>
</section>

<!-- ============================================================
     MANIFESTO — Cinematic quote
     ============================================================ -->
<section class="si-manifesto">
  <div class="si-mani-sparkles" aria-hidden="true">
    <div class="si-spark" style="--sx:20%;--sy:30%;--sd:0s"></div>
    <div class="si-spark" style="--sx:80%;--sy:50%;--sd:1s"></div>
    <div class="si-spark" style="--sx:50%;--sy:20%;--sd:2s"></div>
    <div class="si-spark" style="--sx:30%;--sy:70%;--sd:3s"></div>
    <div class="si-spark" style="--sx:70%;--sy:80%;--sd:4s"></div>
  </div>
  <div class="si-manifesto-inner">
    <div class="si-mani-diamond">✦</div>
    <blockquote class="si-quote">
      More than clothing — SISTA represents <em>sisterhood.</em> A shared energy that brings women together across cultures, generations and communities.
    </blockquote>
    <div class="si-mani-line"></div>
    <p class="si-mani-attr">Peace · Love · Unity — Birmingham, 1983</p>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Blingy grid
     ============================================================ -->
<section class="si-shop" id="si-shop">
  <div class="si-shop-inner">
    <div class="si-shop-head">
      <div>
        <div class="si-eyebrow-sm">✦ The Collection</div>
        <h2 class="si-shop-h2">For Every Woman.</h2>
      </div>
      <div>
        <p class="si-shop-desc">Soulful womenswear rooted in connection, spirit and self-expression.</p>
        <div class="si-filters">
          <button class="si-filter active" data-filter="all">All</button>
          <button class="si-filter" data-filter="tee">T-Shirts</button>
          <button class="si-filter" data-filter="hood">Hoodies</button>
          <button class="si-filter" data-filter="acc">Accessories</button>
        </div>
      </div>
    </div>

    <div class="si-grid" id="si-product-grid">
      {%- assign si_count = 0 -%}
      {%- for product in sista_col.products limit: 500 -%}
        {%- assign vd = product.vendor | downcase -%}
        {%- unless vd contains 'sista' -%}{%- continue -%}{%- endunless -%}
        {%- assign si_count = si_count | plus: 1 -%}
        {%- assign filter_tag = 'acc' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}
          {%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' or tl contains 'longsleeve' -%}
          {%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="si-prod" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="si-prod-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="si-sale-badge">SALE</span>
            {%- endif -%}
            <div class="si-prod-overlay">
              <span>View ✦</span>
            </div>
          </div>
          <div class="si-prod-info">
            <span class="si-prod-type">{{ product.type | default: 'SISTA' }}</span>
            <div class="si-prod-name">{{ product.title }}</div>
            <div class="si-prod-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
      {%- if si_count == 0 -%}
        <div class="si-empty">✦ No SISTA products found. Check back soon. ✦</div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING — Grand finale
     ============================================================ -->
<section class="si-closing">
  <div class="si-closing-sparkles" aria-hidden="true">
    <div class="si-spark" style="--sx:15%;--sy:25%;--sd:0s"></div>
    <div class="si-spark" style="--sx:85%;--sy:40%;--sd:1s"></div>
    <div class="si-spark" style="--sx:50%;--sy:75%;--sd:2s"></div>
    <div class="si-spark" style="--sx:25%;--sy:60%;--sd:3s"></div>
    <div class="si-spark" style="--sx:75%;--sy:20%;--sd:4s"></div>
  </div>
  <div class="si-closing-inner">
    <div class="si-closing-logo">
      <div class="si-cl-ring"></div>
      <img src="{{ 'logo-sista-main.jpeg' | asset_url }}" alt="SISTA" />
    </div>
    <h2 class="si-closing-h2">Peace. Love.<br><em>Unity.</em></h2>
    <p>For women of every colour, every shape and every walk of life.<br>Sisterhood — always.</p>
    <a class="si-btn-gold" href="#si-shop">
      <span class="si-btn-shine"></span>
      ✦ Shop SISTA
    </a>
  </div>
</section>

<!-- ============================================================
     STYLES — BLINGY · SHIMMER · WOW
     ============================================================ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Infant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap');

:root {
  --si-black: #0a0508;
  --si-deep: #140a10;
  --si-plum: #2a0f20;
  --si-rose: #e8357a;
  --si-pink: #f472b6;
  --si-hot: #ff2d78;
  --si-gold: #d4a853;
  --si-gold-bright: #f0c96e;
  --si-champagne: #f5e6c8;
  --si-white: #fff;
  --si-serif: 'Cormorant Infant', Georgia, serif;
  --si-mono: var(--mono, 'JetBrains Mono'), monospace;
}

/* ---- HERO ---- */
.si-hero {
  position: relative; min-height: 100vh; min-height: 100dvh;
  background: radial-gradient(ellipse at 50% 40%, var(--si-plum) 0%, var(--si-deep) 50%, var(--si-black) 100%);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 100px 24px 80px; text-align: center;
}

/* Shimmer sweep */
.si-shimmer {
  position: absolute; inset: 0; pointer-events: none;
  background: linear-gradient(105deg, transparent 40%, rgba(212,168,83,.04) 45%, rgba(212,168,83,.08) 50%, rgba(212,168,83,.04) 55%, transparent 60%);
  background-size: 300% 100%;
  animation: si-shimmer-sweep 6s ease-in-out infinite;
}
@keyframes si-shimmer-sweep { 0%{background-position:200% 0} 100%{background-position:-200% 0} }

/* Sparkle particles */
.si-sparkles, .si-mani-sparkles, .si-closing-sparkles { position: absolute; inset: 0; pointer-events: none; }
.si-spark {
  position: absolute; left: var(--sx); top: var(--sy);
  width: 3px; height: 3px; border-radius: 50%;
  background: var(--si-gold-bright);
  box-shadow: 0 0 6px var(--si-gold), 0 0 12px rgba(212,168,83,.3);
  animation: si-twinkle 3s ease-in-out infinite;
  animation-delay: var(--sd);
}
@keyframes si-twinkle {
  0%,100% { opacity: 0; transform: scale(0); }
  50% { opacity: 1; transform: scale(1); }
}

/* Glows */
.si-glow { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(80px); }
.si-glow-1 { width: 500px; height: 500px; top: 10%; left: 15%; background: rgba(232,53,122,.08); animation: si-glow-pulse 8s ease-in-out infinite alternate; }
.si-glow-2 { width: 400px; height: 400px; bottom: 15%; right: 10%; background: rgba(212,168,83,.06); animation: si-glow-pulse 10s ease-in-out infinite alternate-reverse; }
.si-glow-3 { width: 300px; height: 300px; top: 50%; left: 50%; transform: translate(-50%,-50%); background: rgba(244,114,182,.05); animation: si-glow-pulse 12s ease-in-out infinite alternate; }
@keyframes si-glow-pulse { 0%{opacity:.5;transform:scale(1)} 100%{opacity:1;transform:scale(1.2)} }

/* Hero content */
.si-hero-content { position: relative; z-index: 2; max-width: 700px; width: 100%; display: flex; flex-direction: column; align-items: center; }

.si-hero-tag {
  display: inline-flex; align-items: center; gap: 14px;
  font-family: var(--si-mono); font-size: 11px; letter-spacing: .25em; text-transform: uppercase;
  color: var(--si-gold); margin-bottom: 40px;
}
.si-diamond { color: var(--si-gold-bright); font-size: 8px; animation: si-twinkle 2s ease-in-out infinite; }

/* Logo — centered, bg removed */
.si-hero-logo {
  position: relative; width: clamp(140px, 24vw, 220px); height: clamp(140px, 24vw, 220px);
  margin: 0 auto 32px; display: flex; align-items: center; justify-content: center;
}
.si-logo-ring {
  position: absolute; inset: -8px; border-radius: 50%;
  border: 1px solid rgba(212,168,83,.3);
  animation: si-ring-rotate 20s linear infinite;
  background: conic-gradient(from 0deg, transparent 0%, rgba(212,168,83,.15) 25%, transparent 50%, rgba(232,53,122,.1) 75%, transparent 100%);
}
@keyframes si-ring-rotate { to { transform: rotate(360deg); } }

.si-logo-img {
  width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  mix-blend-mode: screen;
  box-shadow: 0 0 40px rgba(232,53,122,.3), 0 0 80px rgba(212,168,83,.15), inset 0 0 30px rgba(0,0,0,.3);
  animation: si-logo-breathe 4s ease-in-out infinite alternate;
}
@keyframes si-logo-breathe {
  0% { box-shadow: 0 0 30px rgba(232,53,122,.2), 0 0 60px rgba(212,168,83,.1); }
  100% { box-shadow: 0 0 50px rgba(232,53,122,.4), 0 0 100px rgba(212,168,83,.2); }
}

.si-hero-h1 {
  font-family: var(--si-serif); font-size: clamp(56px, 10vw, 120px); font-weight: 300;
  letter-spacing: .2em; text-transform: uppercase; margin: 0 0 20px; line-height: 1;
}
.si-letter {
  display: inline-block; color: var(--si-white);
  text-shadow: 0 0 20px rgba(255,255,255,.1);
}
.si-gold {
  background: linear-gradient(180deg, var(--si-gold-bright) 0%, var(--si-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  filter: drop-shadow(0 0 8px rgba(212,168,83,.4));
}

.si-hero-sub {
  font-family: var(--si-serif); font-size: 16px; font-weight: 300; font-style: italic;
  line-height: 1.85; color: rgba(255,255,255,.45); margin: 0 auto 44px; max-width: 500px;
}

.si-hero-actions { display: flex; align-items: center; justify-content: center; gap: 32px; flex-wrap: wrap; }

/* Gold shimmer button */
.si-btn-gold {
  position: relative; display: inline-flex; align-items: center; gap: 10px; overflow: hidden;
  background: linear-gradient(135deg, var(--si-gold) 0%, var(--si-gold-bright) 50%, var(--si-gold) 100%);
  color: var(--si-black); font-family: var(--si-mono); font-size: 11px; letter-spacing: .16em;
  text-transform: uppercase; text-decoration: none; padding: 16px 32px; font-weight: 700;
  cursor: pointer; transition: all .3s;
}
.si-btn-gold:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(212,168,83,.4); }
.si-btn-shine {
  position: absolute; top: 0; left: -100%; width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.35), transparent);
  animation: si-btn-flash 3s ease-in-out infinite;
}
@keyframes si-btn-flash { 0%{left:-100%} 50%{left:150%} 100%{left:150%} }

.si-stats { display: flex; align-items: center; gap: 18px; }
.si-stat { display: flex; flex-direction: column; gap: 2px; align-items: center; }
.si-stat-val { font-family: var(--si-serif); font-size: 20px; font-weight: 600; color: var(--si-champagne); }
.si-stat-lbl { font-family: var(--si-mono); font-size: 8px; letter-spacing: .18em; text-transform: uppercase; color: rgba(212,168,83,.4); }
.si-stat-sep { width: 1px; height: 28px; background: rgba(212,168,83,.15); }

.si-scroll {
  position: absolute; bottom: 28px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  font-family: var(--si-mono); font-size: 8px; letter-spacing: .2em; text-transform: uppercase; color: rgba(212,168,83,.3);
}
.si-scroll-line { width: 1px; height: 40px; background: linear-gradient(to bottom, rgba(212,168,83,.3), transparent); animation: si-scroll-pulse 2s ease infinite; }
@keyframes si-scroll-pulse { 0%,100%{opacity:.3} 50%{opacity:.8} }

/* ---- TICKER ---- */
.si-ticker {
  background: linear-gradient(90deg, var(--si-black), var(--si-deep), var(--si-black));
  border-top: 1px solid rgba(212,168,83,.15); border-bottom: 1px solid rgba(212,168,83,.15);
  padding: 16px 0; overflow: hidden; white-space: nowrap;
}
.si-ticker-track { display: flex; width: max-content; animation: si-tick 30s linear infinite; }
.si-ticker-set {
  display: flex; align-items: center; gap: 28px; padding-right: 28px; flex-shrink: 0;
  font-family: var(--si-serif); font-size: 15px; font-weight: 600; letter-spacing: .2em;
  text-transform: uppercase; color: var(--si-champagne);
}
.si-tdot { color: var(--si-gold); font-size: 9px; }
@keyframes si-tick { to { transform: translateX(-50%); } }

/* ---- STORY ---- */
.si-story { display: grid; grid-template-columns: 1fr 1.4fr; min-height: 540px; background: var(--si-black); }
@media(max-width:900px){.si-story{grid-template-columns:1fr;}}

.si-story-visual {
  background: var(--si-deep); display: flex; align-items: center; justify-content: center;
  padding: 60px 40px; position: relative; border-right: 1px solid rgba(212,168,83,.08);
  overflow: hidden;
}
@media(max-width:900px){.si-story-visual{min-height:320px;border-right:none;border-bottom:1px solid rgba(212,168,83,.08);}}

.si-story-shimmer {
  position: absolute; inset: 0;
  background: linear-gradient(105deg, transparent 40%, rgba(212,168,83,.03) 50%, transparent 60%);
  background-size: 300% 100%; animation: si-shimmer-sweep 8s ease-in-out infinite;
}
.si-story-logo-wrap { position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; }
.si-story-logo {
  width: clamp(160px, 28vw, 260px); height: auto; object-fit: contain;
  mix-blend-mode: screen;
  filter: drop-shadow(0 0 20px rgba(232,53,122,.2)) drop-shadow(0 0 40px rgba(212,168,83,.1));
}

.si-story-text { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; gap: 24px; }
@media(max-width:768px){.si-story-text{padding:48px 24px;}}

.si-eyebrow {
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: var(--si-gold);
}
.si-story-h2 {
  font-family: var(--si-serif); font-size: clamp(34px, 5vw, 56px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .06em; line-height: 1.1; color: var(--si-champagne); margin: 0;
}
.si-story-h2 em { font-style: italic; color: var(--si-rose); }
.si-story-p {
  font-family: var(--si-serif); font-size: 15px; font-weight: 300; line-height: 1.9; font-style: italic;
  color: rgba(245,230,200,.45); max-width: 480px; margin: 0;
}
.si-values { display: flex; gap: 8px; flex-wrap: wrap; }
.si-value {
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase;
  padding: 7px 16px; border: 1px solid rgba(212,168,83,.2); color: var(--si-gold);
  transition: all .25s; cursor: default;
}
.si-value:hover { background: var(--si-gold); color: var(--si-black); border-color: var(--si-gold); }

/* ---- MANIFESTO ---- */
.si-manifesto {
  background: linear-gradient(180deg, var(--si-deep) 0%, var(--si-plum) 50%, var(--si-deep) 100%);
  padding: 120px 40px; text-align: center; position: relative; overflow: hidden;
}
@media(max-width:768px){.si-manifesto{padding:80px 20px;}}
.si-manifesto-inner { max-width: 760px; margin: 0 auto; position: relative; z-index: 2; }
.si-mani-diamond { font-size: 18px; color: var(--si-gold); margin-bottom: 28px; animation: si-twinkle 3s ease-in-out infinite; }
.si-quote {
  font-family: var(--si-serif); font-size: clamp(24px, 3.8vw, 40px); font-weight: 300;
  font-style: italic; line-height: 1.65; color: rgba(255,255,255,.8); margin: 0;
}
.si-quote em { font-style: normal; color: var(--si-rose); text-shadow: 0 0 20px rgba(232,53,122,.3); }
.si-mani-line { width: 80px; height: 1px; background: linear-gradient(90deg, transparent, var(--si-gold), transparent); margin: 36px auto; }
.si-mani-attr { font-family: var(--si-mono); font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: rgba(212,168,83,.35); }

/* ---- SHOP ---- */
.si-shop { background: var(--si-black); padding: 80px 60px; }
@media(max-width:768px){.si-shop{padding:48px 20px;}}
.si-shop-inner { max-width: 1200px; margin: 0 auto; }
.si-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px){.si-shop-head{grid-template-columns:1fr;}}
.si-eyebrow-sm { font-family: var(--si-mono); font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: var(--si-gold); }
.si-shop-h2 {
  font-family: var(--si-serif); font-size: clamp(36px, 5vw, 56px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .06em; line-height: 1; margin: 8px 0 0; color: var(--si-champagne);
}
.si-shop-desc { font-family: var(--si-serif); font-size: 14px; font-weight: 300; line-height: 1.75; color: rgba(245,230,200,.35); font-style: italic; }
.si-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
.si-filter {
  font-family: var(--si-mono); font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
  padding: 9px 18px; border: 1px solid rgba(212,168,83,.2); background: transparent;
  color: var(--si-champagne); cursor: pointer; transition: all .25s;
}
.si-filter:hover, .si-filter.active { background: var(--si-gold); color: var(--si-black); border-color: var(--si-gold); }

.si-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
.si-prod { text-decoration: none; color: inherit; cursor: pointer; transition: transform .3s; }
.si-prod:hover { transform: translateY(-6px); }
.si-prod-img { position: relative; overflow: hidden; background: var(--si-deep); aspect-ratio: 1; }
.si-prod-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.si-prod:hover .si-prod-img img { transform: scale(1.08); }
.si-prod-overlay {
  position: absolute; inset: 0; background: rgba(10,5,8,.7);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--si-mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--si-gold); opacity: 0; transition: opacity .3s; backdrop-filter: blur(4px);
}
.si-prod:hover .si-prod-overlay { opacity: 1; }
.si-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--si-serif); font-size: 32px; color: rgba(212,168,83,.1); font-weight: 300; letter-spacing: .2em; }
.si-sale-badge {
  position: absolute; top: 12px; right: 12px;
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .12em;
  background: var(--si-gold); color: var(--si-black); padding: 4px 12px; font-weight: 700;
}
.si-prod-info { padding: 16px 4px; }
.si-prod-type { font-family: var(--si-mono); font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: var(--si-gold); }
.si-prod-name { font-family: var(--si-serif); font-size: 15px; font-weight: 500; color: var(--si-champagne); margin: 6px 0 4px; }
.si-prod-price { font-family: var(--si-mono); font-size: 13px; color: rgba(212,168,83,.5); }
.si-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--si-mono); font-size: 11px; letter-spacing: .14em; color: rgba(212,168,83,.25); text-transform: uppercase; }

/* ---- CLOSING ---- */
.si-closing {
  background: radial-gradient(ellipse at 50% 50%, var(--si-plum) 0%, var(--si-black) 70%);
  padding: 120px 40px; text-align: center; position: relative; overflow: hidden;
}
@media(max-width:768px){.si-closing{padding:80px 20px;}}
.si-closing-inner { max-width: 600px; margin: 0 auto; position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; }
.si-closing-logo {
  position: relative; width: 120px; height: 120px; margin-bottom: 36px;
  display: flex; align-items: center; justify-content: center;
}
.si-cl-ring {
  position: absolute; inset: -6px; border-radius: 50%;
  border: 1px solid rgba(212,168,83,.25);
  background: conic-gradient(from 0deg, transparent 0%, rgba(212,168,83,.1) 25%, transparent 50%);
  animation: si-ring-rotate 15s linear infinite;
}
.si-closing-logo img {
  width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  mix-blend-mode: screen;
  box-shadow: 0 0 40px rgba(232,53,122,.25), 0 0 80px rgba(212,168,83,.1);
}
.si-closing-h2 {
  font-family: var(--si-serif); font-size: clamp(36px, 6vw, 64px); font-weight: 300;
  text-transform: uppercase; letter-spacing: .06em; line-height: 1.1; color: var(--si-white); margin: 0 0 20px;
}
.si-closing-h2 em { font-style: italic; background: linear-gradient(180deg, var(--si-gold-bright), var(--si-gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.si-closing-inner p { font-family: var(--si-serif); font-size: 15px; font-weight: 300; font-style: italic; line-height: 1.8; color: rgba(255,255,255,.4); margin: 0 0 36px; }

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce){
  .si-shimmer,.si-spark,.si-glow,.si-logo-ring,.si-cl-ring,.si-scroll-line,.si-ticker-track,.si-btn-shine,.si-story-shimmer,.si-logo-img{animation:none!important;}
  .si-prod:hover{transform:none;}
}
</style>

<!-- SCRIPTS — Motion.dev -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  var fBtns = document.querySelectorAll('.si-filter');
  var cards = document.querySelectorAll('.si-prod');
  fBtns.forEach(function(b) {
    b.addEventListener('click', function() {
      var f = this.dataset.filter;
      fBtns.forEach(function(x) { x.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });
  if (window.Motion) {
    var M = window.Motion;
    M.animate('.si-hero-tag', { opacity: [0,1], y: [-15,0] }, { duration: .6, delay: .2 });
    M.animate('.si-hero-logo', { opacity: [0,1], scale: [.6,1] }, { duration: 1.2, delay: .4, easing: [.22,1,.36,1] });
    M.animate('.si-hero-h1 .si-letter', { opacity: [0,1], y: [40,0] }, { delay: M.stagger(.08, {start:.8}), duration: .6, easing: [.22,1,.36,1] });
    M.animate('.si-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: 1.4 });
    M.animate('.si-hero-actions', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: 1.6 });
    M.inView('.si-story-visual', function() {
      M.animate('.si-story-logo-wrap', { opacity: [0,1], scale: [.8,1] }, { duration: .9, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.si-story-text', function() {
      M.animate('.si-story-text > *', { opacity: [0,1], x: [30,0] }, { delay: M.stagger(.12), duration: .6, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.si-manifesto-inner', function() {
      M.animate('.si-mani-diamond', { opacity: [0,1], scale: [0,1] }, { duration: .5 });
      M.animate('.si-quote', { opacity: [0,1], y: [30,0] }, { duration: .9, delay: .2, easing: [.22,1,.36,1] });
      M.animate('.si-mani-line', { scaleX: [0,1] }, { duration: .6, delay: .5 });
      M.animate('.si-mani-attr', { opacity: [0,1] }, { duration: .5, delay: .7 });
    }, { margin: '-10% 0px' });
    document.querySelectorAll('.si-prod').forEach(function(c) {
      M.inView(c, function() { M.animate(c, { opacity: [0,1], y: [25,0] }, { duration: .5, easing: [.22,1,.36,1] }); }, { margin: '-5% 0px' });
    });
    M.inView('.si-closing-inner', function() {
      M.animate('.si-closing-logo', { opacity: [0,1], scale: [.5,1] }, { duration: 1, easing: [.22,1,.36,1] });
      M.animate('.si-closing-h2', { opacity: [0,1], y: [30,0] }, { duration: .8, delay: .3, easing: [.22,1,.36,1] });
      M.animate('.si-closing-inner p', { opacity: [0,1] }, { duration: .6, delay: .5 });
      M.animate('.si-closing-inner .si-btn-gold', { opacity: [0,1], y: [15,0] }, { duration: .6, delay: .7 });
    }, { margin: '-10% 0px' });
  }
});
</script>

{% schema %}
{
  "name": "Brand: SISTA",
  "settings": [
    { "type": "collection", "id": "brand_collection", "label": "SISTA Collection" },
    { "type": "textarea", "id": "tagline", "label": "Hero tagline", "default": "A universal womenswear brand built on sisterhood, connection and self-expression. Created for women of every colour, every shape and every walk of life." },
    { "type": "textarea", "id": "story_text", "label": "Brand story", "default": "Born in Birmingham in 1983, SISTA is a universal womenswear brand built on peace, love and unity. Created for women of every colour, every shape and every walk of life — SISTA represents sisterhood. A shared energy that brings women together across cultures, generations and communities." }
  ],
  "presets": [{ "name": "Brand: SISTA" }]
}
{% endschema %}
