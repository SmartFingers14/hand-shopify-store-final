{% comment %}
  Brand Page: SISTA — Peace · Love · Unity
  Memphis Pink Pop — Bold · Geometric · Flashy · Chatak Matak
  UI/UX Pro Max: Memphis Design + Syne/Manrope + #FF71CE/#FFCE5C/#86CCCA
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}
{%- if sista_col == blank or sista_col.products_count == 0 -%}
  {%- assign sista_col = collections['sista-1'] -%}
{%- endif -%}

<div class="si-page">

<!-- ============================================================
     HERO — Memphis Pink Pop with geometric shapes
     ============================================================ -->
<section class="si-hero" id="si-top">
  <!-- Memphis decorations -->
  <div class="si-deco" aria-hidden="true">
    <div class="si-dots"></div>
    <div class="si-shape si-tri1"></div>
    <div class="si-shape si-tri2"></div>
    <div class="si-shape si-circ1"></div>
    <div class="si-shape si-circ2"></div>
    <div class="si-shape si-sq1"></div>
    <div class="si-shape si-sq2"></div>
    <div class="si-zig"></div>
    <div class="si-zig2"></div>
    <div class="si-shape si-circ3"></div>
    <div class="si-squig"></div>
  </div>

  <div class="si-hero-content">
    <div class="si-hero-badge">Peace · Love · Unity</div>

    <!-- Logo with dashed spinning ring -->
    <div class="si-hero-logo">
      <div class="si-logo-ring"></div>
      <div class="si-logo-ring2"></div>
      <img src="{{ 'logo-sista.jpeg' | asset_url }}" alt="SISTA" class="si-logo-img" />
    </div>

    <h1 class="si-hero-h1">SISTA</h1>

    <p class="si-hero-sub">{{ section.settings.tagline | default: 'A universal womenswear brand built on sisterhood, connection and self-expression. Created for women of every colour, every shape and every walk of life.' }}</p>

    <div class="si-hero-actions">
      <a class="si-btn-mem" href="#si-shop">Shop The Collection</a>
      <div class="si-stats">
        <div class="si-stat"><span class="si-stat-n">1983</span><span class="si-stat-l">Est.</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-n">B'ham</span><span class="si-stat-l">Born</span></div>
        <div class="si-stat-sep"></div>
        <div class="si-stat"><span class="si-stat-n">Unity</span><span class="si-stat-l">Spirit</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     TICKER — Memphis bold strip
     ============================================================ -->
<div class="si-ticker">
  <div class="si-ticker-track">
    {%- for i in (1..2) -%}
    <div class="si-ticker-set">
      <span>PEACE</span><span class="si-tsep">&#9670;</span>
      <span>LOVE</span><span class="si-tsep">&#9670;</span>
      <span>UNITY</span><span class="si-tsep">&#9670;</span>
      <span>SISTA</span><span class="si-tsep">&#9670;</span>
      <span>SISTERHOOD</span><span class="si-tsep">&#9670;</span>
      <span>SPIRIT</span><span class="si-tsep">&#9670;</span>
      <span>CONNECTION</span><span class="si-tsep">&#9670;</span>
      <span>SELF-EXPRESSION</span><span class="si-tsep">&#9670;</span>
    </div>
    {%- endfor -%}
  </div>
</div>

<!-- ============================================================
     STORY — Bold split with logo
     ============================================================ -->
<section class="si-story">
  <div class="si-story-visual">
    <div class="si-story-dots" aria-hidden="true"></div>
    <div class="si-big-text" aria-hidden="true">SISTA</div>
    <div class="si-story-logo-wrap">
      <div class="si-story-ring"></div>
      <img src="{{ 'logo-sista.jpeg' | asset_url }}" alt="SISTA" class="si-story-logo" />
    </div>
  </div>
  <div class="si-story-text">
    <div class="si-eyebrow">&#9670; The Story</div>
    <h2 class="si-story-h2">Built on<br><em>sisterhood.</em></h2>
    <p class="si-story-p">{{ section.settings.story_text | default: "Born in Birmingham in 1983, SISTA is a universal womenswear brand built on peace, love and unity. Created for women of every colour, every shape and every walk of life — SISTA represents sisterhood. A shared energy that brings women together across cultures, generations and communities." }}</p>
    <div class="si-tags">
      <span class="si-tag">&#9670; Peace</span>
      <span class="si-tag">&#9670; Love</span>
      <span class="si-tag">&#9670; Unity</span>
      <span class="si-tag">&#9670; Spirit</span>
    </div>
  </div>
</section>

<!-- ============================================================
     MANIFESTO — Bold Memphis statement
     ============================================================ -->
<section class="si-manifesto">
  <div class="si-mani-shapes" aria-hidden="true">
    <div class="si-shape si-ms1"></div>
    <div class="si-shape si-ms2"></div>
  </div>
  <div class="si-mani-inner">
    <div class="si-mani-diamond">&#9670;</div>
    <blockquote class="si-quote">
      More than clothing — SISTA represents <em>sisterhood.</em> A shared energy that brings women together across cultures, generations and communities.
    </blockquote>
    <div class="si-mani-line"></div>
    <p class="si-mani-attr">Peace · Love · Unity — Birmingham, 1983</p>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Memphis grid
     ============================================================ -->
<section class="si-shop" id="si-shop">
  <div class="si-shop-inner">
    <div class="si-shop-head">
      <div>
        <div class="si-eyebrow-sm">&#9670; The Collection</div>
        <h2 class="si-shop-h2">For Every Woman.</h2>
      </div>
      <div>
        <p class="si-shop-desc">Soulful womenswear rooted in connection, spirit and self-expression.</p>
        <div class="si-filters">
          <button class="si-filter active" data-filter="all">All</button>
          <button class="si-filter" data-filter="tee">T-Shirts</button>
          <button class="si-filter" data-filter="hood">Hoodies</button>
          <button class="si-filter" data-filter="acc">Accessories</button>
        </div>
      </div>
    </div>

    <div class="si-grid">
      {%- assign si_count = 0 -%}
      {%- for product in sista_col.products limit: 500 -%}
        {%- assign vd = product.vendor | downcase -%}
        {%- unless vd contains 'sista' -%}{%- continue -%}{%- endunless -%}
        {%- assign si_count = si_count | plus: 1 -%}
        {%- assign filter_tag = 'acc' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}
          {%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' or tl contains 'longsleeve' -%}
          {%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="si-prod" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="si-prod-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="si-sale">SALE</span>
            {%- endif -%}
            <div class="si-prod-hover">
              <span>View &#9670;</span>
            </div>
          </div>
          <div class="si-prod-info">
            <span class="si-prod-type">{{ product.type | default: 'SISTA' }}</span>
            <div class="si-prod-name">{{ product.title }}</div>
            <div class="si-prod-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
      {%- if si_count == 0 -%}
        <div class="si-empty">&#9670; No SISTA products found. Check back soon. &#9670;</div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING — Memphis finale with logo
     ============================================================ -->
<section class="si-closing">
  <div class="si-closing-deco" aria-hidden="true">
    <div class="si-dots"></div>
    <div class="si-shape si-ct1"></div>
    <div class="si-shape si-ct2"></div>
  </div>
  <div class="si-closing-inner">
    <div class="si-closing-logo">
      <div class="si-cl-ring"></div>
      <img src="{{ 'logo-sista.jpeg' | asset_url }}" alt="SISTA" />
    </div>
    <h2 class="si-closing-h2">Peace. Love.<br><em>Unity.</em></h2>
    <p>For women of every colour, every shape and every walk of life.</p>
    <a class="si-btn-mem" href="#si-shop">Shop SISTA</a>
  </div>
</section>

</div>

<!-- ============================================================
     STYLES — MEMPHIS PINK POP
     ============================================================ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&display=swap');

.si-page {
  --si-bg: #1a0a1e;
  --si-deep: #120812;
  --si-pink: #FF71CE;
  --si-yellow: #FFCE5C;
  --si-teal: #86CCCA;
  --si-purple: #6A7BB4;
  --si-hot: #FF1493;
  --si-white: #fff;
  --si-cream: #FFF5F9;
  --si-head: 'Syne', 'Arial Black', sans-serif;
  --si-body: 'Manrope', system-ui, sans-serif;
  --si-mono: var(--mono, 'JetBrains Mono'), monospace;
  background: var(--si-bg); color: var(--si-white); overflow-x: hidden;
}

/* ---- HERO ---- */
.si-hero {
  position: relative; min-height: 100vh; min-height: 100dvh;
  background: var(--si-bg); display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 100px 24px 80px; text-align: center;
}

/* Memphis decorations */
.si-deco { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.si-dots {
  position: absolute; inset: 0;
  background-image: radial-gradient(var(--si-pink) 1.5px, transparent 1.5px);
  background-size: 40px 40px; opacity: .04;
}
.si-shape { position: absolute; }
.si-tri1 { width: 0; height: 0; border-left: 55px solid transparent; border-right: 55px solid transparent; border-bottom: 95px solid var(--si-pink); top: 8%; left: 6%; animation: si-spin 20s linear infinite; opacity: .35; }
.si-tri2 { width: 0; height: 0; border-left: 35px solid transparent; border-right: 35px solid transparent; border-bottom: 60px solid var(--si-yellow); bottom: 12%; right: 8%; animation: si-spin 16s linear infinite reverse; opacity: .3; }
.si-circ1 { width: 110px; height: 110px; border-radius: 50%; border: 5px solid var(--si-teal); top: 22%; right: 8%; animation: si-float 7s ease-in-out infinite; opacity: .3; }
.si-circ2 { width: 70px; height: 70px; border-radius: 50%; background: var(--si-purple); bottom: 22%; left: 10%; animation: si-float 9s ease-in-out infinite; opacity: .15; }
.si-circ3 { width: 45px; height: 45px; border-radius: 50%; border: 4px dashed var(--si-yellow); top: 70%; right: 15%; animation: si-spin 12s linear infinite; opacity: .2; }
.si-sq1 { width: 80px; height: 80px; background: var(--si-yellow); top: 55%; left: 4%; transform: rotate(25deg); opacity: .1; }
.si-sq2 { width: 50px; height: 50px; border: 4px solid var(--si-pink); bottom: 35%; right: 5%; transform: rotate(45deg); animation: si-spin 14s linear infinite; opacity: .25; }
.si-zig { width: 140px; height: 6px; position: absolute; top: 15%; right: 22%; background: repeating-linear-gradient(90deg, var(--si-teal) 0 10px, transparent 10px 20px); transform: rotate(-12deg); opacity: .25; }
.si-zig2 { width: 100px; height: 6px; position: absolute; bottom: 18%; left: 22%; background: repeating-linear-gradient(90deg, var(--si-yellow) 0 8px, transparent 8px 16px); transform: rotate(8deg); opacity: .2; }
.si-squig { width: 90px; height: 45px; border: 5px solid var(--si-pink); border-bottom: none; border-radius: 45px 45px 0 0; position: absolute; top: 12%; right: 35%; animation: si-bounce 3s ease-in-out infinite; opacity: .2; }

@keyframes si-spin { to { transform: rotate(360deg); } }
@keyframes si-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-22px); } }
@keyframes si-bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }

/* Hero content */
.si-hero-content { position: relative; z-index: 2; max-width: 650px; display: flex; flex-direction: column; align-items: center; }

.si-hero-badge {
  font-family: var(--si-body); font-size: 11px; font-weight: 700; letter-spacing: .25em;
  text-transform: uppercase; color: var(--si-yellow); margin-bottom: 32px;
  padding: 8px 24px; border: 2px solid rgba(255,206,92,.3); display: inline-block;
}

/* Logo with dashed ring */
.si-hero-logo {
  position: relative; width: clamp(150px, 26vw, 220px); height: clamp(150px, 26vw, 220px);
  margin: 0 auto 28px; display: flex; align-items: center; justify-content: center;
}
.si-logo-ring {
  position: absolute; inset: -16px; border-radius: 50%;
  border: 5px dashed var(--si-pink); animation: si-spin 25s linear infinite;
}
.si-logo-ring2 {
  position: absolute; inset: -6px; border-radius: 50%;
  border: 3px solid var(--si-yellow); opacity: .5;
}
.si-logo-img {
  width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  border: 4px solid var(--si-yellow);
  box-shadow: 0 0 30px rgba(255,113,206,.3), 6px 6px 0 var(--si-pink);
}

.si-hero-h1 {
  font-family: var(--si-head); font-size: clamp(64px, 14vw, 130px); font-weight: 800;
  letter-spacing: .06em; text-transform: uppercase; line-height: .88; margin: 0 0 20px;
  color: var(--si-white);
  text-shadow: 4px 4px 0 var(--si-pink), 8px 8px 0 var(--si-yellow);
}

.si-hero-sub {
  font-family: var(--si-body); font-size: 15px; font-weight: 400;
  line-height: 1.8; color: rgba(255,255,255,.4); margin: 0 0 36px; max-width: 440px;
}

.si-hero-actions { display: flex; align-items: center; justify-content: center; gap: 28px; flex-wrap: wrap; }

/* Memphis button */
.si-btn-mem {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--si-pink); color: var(--si-bg); font-family: var(--si-head); font-size: 14px;
  font-weight: 700; text-transform: uppercase; letter-spacing: .1em; text-decoration: none;
  padding: 16px 34px; border: 3px solid var(--si-yellow); cursor: pointer;
  box-shadow: 5px 5px 0 var(--si-yellow); transition: all .15s;
}
.si-btn-mem:hover { transform: translate(-3px,-3px); box-shadow: 8px 8px 0 var(--si-yellow); background: var(--si-yellow); color: var(--si-bg); }

.si-stats { display: flex; align-items: center; gap: 18px; }
.si-stat { display: flex; flex-direction: column; gap: 2px; align-items: center; }
.si-stat-n { font-family: var(--si-head); font-size: 20px; font-weight: 800; color: var(--si-yellow); }
.si-stat-l { font-family: var(--si-mono); font-size: 8px; letter-spacing: .15em; text-transform: uppercase; color: rgba(255,206,92,.35); }
.si-stat-sep { width: 2px; height: 24px; background: rgba(255,113,206,.2); }

/* ---- TICKER ---- */
.si-ticker {
  background: var(--si-pink); padding: 14px 0; overflow: hidden; white-space: nowrap;
  border-top: 3px solid var(--si-yellow); border-bottom: 3px solid var(--si-yellow);
}
.si-ticker-track { display: flex; width: max-content; animation: si-tick 28s linear infinite; }
.si-ticker-set {
  display: flex; align-items: center; gap: 24px; padding-right: 24px; flex-shrink: 0;
  font-family: var(--si-head); font-size: 16px; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--si-bg);
}
.si-tsep { font-size: 10px; color: var(--si-yellow); }
@keyframes si-tick { to { transform: translateX(-50%); } }

/* ---- STORY ---- */
.si-story { display: grid; grid-template-columns: 1fr 1.4fr; min-height: 520px; background: var(--si-deep); }
@media(max-width:900px) { .si-story { grid-template-columns: 1fr; } }

.si-story-visual {
  position: relative; display: flex; align-items: center; justify-content: center;
  padding: 60px; overflow: hidden; border-right: 3px solid rgba(255,113,206,.15);
}
@media(max-width:900px) { .si-story-visual { min-height: 320px; border-right: none; border-bottom: 3px solid rgba(255,113,206,.15); } }
.si-story-dots {
  position: absolute; inset: 0;
  background-image: radial-gradient(var(--si-pink) 1.5px, transparent 1.5px);
  background-size: 28px 28px; opacity: .04;
}
.si-big-text {
  position: absolute; font-family: var(--si-head); font-size: clamp(100px, 18vw, 200px);
  font-weight: 800; text-transform: uppercase; color: rgba(255,113,206,.04); letter-spacing: -.02em;
  pointer-events: none;
}
.si-story-logo-wrap {
  position: relative; z-index: 2; display: flex; align-items: center; justify-content: center;
}
.si-story-ring {
  position: absolute; inset: -12px; border-radius: 50%;
  border: 4px dashed var(--si-pink); animation: si-spin 20s linear infinite reverse;
  opacity: .5;
}
.si-story-logo {
  width: clamp(140px, 24vw, 200px); height: clamp(140px, 24vw, 200px); border-radius: 50%;
  object-fit: cover; border: 3px solid var(--si-yellow);
  box-shadow: 0 0 25px rgba(255,113,206,.25), 4px 4px 0 var(--si-pink);
}

.si-story-text { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; gap: 22px; }
@media(max-width:768px) { .si-story-text { padding: 48px 24px; } }

.si-eyebrow { font-family: var(--si-mono); font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: var(--si-yellow); }
.si-story-h2 {
  font-family: var(--si-head); font-size: clamp(36px, 5.5vw, 60px); font-weight: 800;
  text-transform: uppercase; line-height: 1; margin: 0; color: var(--si-white);
}
.si-story-h2 em { font-style: normal; color: var(--si-pink); }
.si-story-p { font-family: var(--si-body); font-size: 15px; line-height: 1.85; color: rgba(255,255,255,.4); max-width: 460px; }
.si-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.si-tag {
  font-family: var(--si-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase;
  padding: 8px 16px; border: 2px solid rgba(255,113,206,.25); color: var(--si-pink);
  transition: all .2s; cursor: default;
}
.si-tag:hover { background: var(--si-pink); color: var(--si-bg); border-color: var(--si-pink); box-shadow: 3px 3px 0 var(--si-yellow); }

/* ---- MANIFESTO ---- */
.si-manifesto {
  background: var(--si-pink); padding: 100px 40px; text-align: center; position: relative; overflow: hidden;
}
@media(max-width:768px) { .si-manifesto { padding: 60px 20px; } }
.si-mani-shapes { position: absolute; inset: 0; pointer-events: none; }
.si-ms1 { width: 0; height: 0; border-left: 40px solid transparent; border-right: 40px solid transparent; border-bottom: 70px solid var(--si-yellow); top: 10%; left: 5%; opacity: .2; animation: si-spin 18s linear infinite; }
.si-ms2 { width: 60px; height: 60px; border-radius: 50%; border: 4px solid var(--si-bg); bottom: 15%; right: 8%; opacity: .15; animation: si-float 6s ease-in-out infinite; }
.si-mani-inner { max-width: 720px; margin: 0 auto; position: relative; z-index: 2; }
.si-mani-diamond { font-size: 20px; color: var(--si-bg); margin-bottom: 24px; }
.si-quote {
  font-family: var(--si-head); font-size: clamp(22px, 3.5vw, 34px); font-weight: 600;
  line-height: 1.55; color: var(--si-bg); margin: 0;
}
.si-quote em { font-style: normal; color: var(--si-white); text-shadow: 2px 2px 0 rgba(0,0,0,.1); }
.si-mani-line { width: 80px; height: 3px; background: var(--si-bg); margin: 28px auto; }
.si-mani-attr { font-family: var(--si-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: rgba(26,10,30,.4); }

/* ---- SHOP ---- */
.si-shop { background: var(--si-bg); padding: 80px 60px; }
@media(max-width:768px) { .si-shop { padding: 48px 20px; } }
.si-shop-inner { max-width: 1200px; margin: 0 auto; }
.si-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px) { .si-shop-head { grid-template-columns: 1fr; } }
.si-eyebrow-sm { font-family: var(--si-mono); font-size: 10px; letter-spacing: .25em; text-transform: uppercase; color: var(--si-yellow); }
.si-shop-h2 {
  font-family: var(--si-head); font-size: clamp(36px, 5vw, 56px); font-weight: 800;
  text-transform: uppercase; line-height: 1; margin: 6px 0 0; color: var(--si-white);
}
.si-shop-desc { font-family: var(--si-body); font-size: 14px; line-height: 1.7; color: rgba(255,255,255,.35); }
.si-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
.si-filter {
  font-family: var(--si-head); font-size: 12px; text-transform: uppercase;
  padding: 8px 18px; border: 2px solid rgba(255,113,206,.3); background: transparent;
  color: var(--si-white); cursor: pointer; transition: all .2s;
}
.si-filter:hover, .si-filter.active {
  background: var(--si-pink); color: var(--si-bg); border-color: var(--si-pink);
  box-shadow: 3px 3px 0 var(--si-yellow);
}

.si-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
.si-prod { text-decoration: none; color: inherit; cursor: pointer; transition: transform .2s; }
.si-prod:hover { transform: translate(-3px,-3px); }
.si-prod-img {
  position: relative; overflow: hidden; background: var(--si-deep); aspect-ratio: 1;
  border: 2px solid rgba(255,113,206,.1);
}
.si-prod-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.si-prod:hover .si-prod-img img { transform: scale(1.08); }
.si-prod-hover {
  position: absolute; inset: 0; background: rgba(255,113,206,.85);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--si-head); font-size: 14px; text-transform: uppercase; font-weight: 700;
  color: var(--si-bg); opacity: 0; transition: opacity .2s;
}
.si-prod:hover .si-prod-hover { opacity: 1; }
.si-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-family: var(--si-head); font-size: 28px; color: rgba(255,113,206,.1); font-weight: 800; letter-spacing: .15em; }
.si-sale {
  position: absolute; top: 10px; right: 10px;
  font-family: var(--si-head); font-size: 11px; font-weight: 700;
  background: var(--si-yellow); color: var(--si-bg); padding: 4px 12px;
  box-shadow: 2px 2px 0 var(--si-pink);
}
.si-prod-info { padding: 14px 4px; }
.si-prod-type { font-family: var(--si-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--si-pink); }
.si-prod-name { font-family: var(--si-head); font-size: 15px; font-weight: 600; color: var(--si-white); margin: 6px 0 4px; }
.si-prod-price { font-family: var(--si-mono); font-size: 13px; color: var(--si-yellow); }
.si-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--si-mono); font-size: 12px; letter-spacing: .12em; color: rgba(255,113,206,.25); text-transform: uppercase; }

/* ---- CLOSING ---- */
.si-closing {
  position: relative; background: var(--si-deep); padding: 120px 40px; text-align: center; overflow: hidden;
}
@media(max-width:768px) { .si-closing { padding: 80px 20px; } }
.si-closing-deco { position: absolute; inset: 0; pointer-events: none; }
.si-ct1 { width: 0; height: 0; border-left: 45px solid transparent; border-right: 45px solid transparent; border-bottom: 78px solid var(--si-pink); top: 10%; right: 10%; opacity: .1; animation: si-spin 22s linear infinite; }
.si-ct2 { width: 80px; height: 80px; border-radius: 50%; border: 4px solid var(--si-teal); bottom: 15%; left: 8%; opacity: .1; animation: si-float 8s ease-in-out infinite; }
.si-closing-inner { position: relative; z-index: 2; max-width: 600px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }

.si-closing-logo {
  position: relative; width: 130px; height: 130px; margin-bottom: 28px;
  display: flex; align-items: center; justify-content: center;
}
.si-cl-ring {
  position: absolute; inset: -10px; border-radius: 50%;
  border: 4px dashed var(--si-pink); animation: si-spin 18s linear infinite;
  opacity: .6;
}
.si-closing-logo img {
  width: 100%; height: 100%; border-radius: 50%; object-fit: cover;
  border: 3px solid var(--si-yellow);
  box-shadow: 0 0 25px rgba(255,113,206,.3), 4px 4px 0 var(--si-pink);
}
.si-closing-h2 {
  font-family: var(--si-head); font-size: clamp(40px, 7vw, 72px); font-weight: 800;
  text-transform: uppercase; line-height: .95; color: var(--si-white); margin: 0 0 16px;
  text-shadow: 3px 3px 0 var(--si-pink);
}
.si-closing-h2 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--si-pink), var(--si-yellow), var(--si-teal));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.si-closing-inner p { font-family: var(--si-body); font-size: 15px; color: rgba(255,255,255,.35); margin: 0 0 32px; }

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce) {
  .si-shape,.si-squig,.si-logo-ring,.si-cl-ring,.si-story-ring,.si-ticker-track { animation: none !important; }
  .si-prod:hover { transform: none; }
}
</style>

<!-- SCRIPTS — Motion.dev -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  var fBtns = document.querySelectorAll('.si-filter');
  var cards = document.querySelectorAll('.si-prod');
  fBtns.forEach(function(b) {
    b.addEventListener('click', function() {
      var f = this.dataset.filter;
      fBtns.forEach(function(x) { x.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });
  if (window.Motion) {
    var M = window.Motion;
    M.animate('.si-hero-badge', { opacity: [0,1], y: [-15,0] }, { duration: .5, delay: .2 });
    M.animate('.si-hero-logo', { opacity: [0,1], scale: [.4,1], rotate: ['-120deg','0deg'] }, { duration: 1, delay: .4, easing: [.22,1,.36,1] });
    M.animate('.si-hero-h1', { opacity: [0,1], x: [-60,0] }, { duration: .7, delay: .7, easing: [.22,1,.36,1] });
    M.animate('.si-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: 1 });
    M.animate('.si-hero-actions', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: 1.2 });
    M.inView('.si-story-visual', function() {
      M.animate('.si-story-logo-wrap', { opacity: [0,1], scale: [.5,1], rotate: ['-180deg','0deg'] }, { duration: 1, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.si-story-text', function() {
      M.animate('.si-story-text > *', { opacity: [0,1], x: [30,0] }, { delay: M.stagger(.1), duration: .5, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.si-mani-inner', function() {
      M.animate('.si-mani-diamond', { opacity: [0,1], scale: [0,1] }, { duration: .4 });
      M.animate('.si-quote', { opacity: [0,1], y: [25,0] }, { duration: .7, delay: .2, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    document.querySelectorAll('.si-prod').forEach(function(c) {
      M.inView(c, function() { M.animate(c, { opacity: [0,1], y: [20,0] }, { duration: .4, easing: [.22,1,.36,1] }); }, { margin: '-5% 0px' });
    });
    M.inView('.si-closing-inner', function() {
      M.animate('.si-closing-logo', { opacity: [0,1], scale: [.4,1], rotate: ['-90deg','0deg'] }, { duration: .8, easing: [.22,1,.36,1] });
      M.animate('.si-closing-h2', { opacity: [0,1], y: [30,0] }, { duration: .7, delay: .2, easing: [.22,1,.36,1] });
      M.animate('.si-closing-inner .si-btn-mem', { opacity: [0,1], y: [15,0] }, { duration: .5, delay: .5 });
    }, { margin: '-10% 0px' });
  }
});
</script>

