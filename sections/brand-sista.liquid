{% comment %}
  Brand Page: Sista — Script · Silhouette · Slip Mats
  Feminine energy, flowing script, warm pinks, and vinyl culture
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}

<!-- ============================================================
     HERO — Full viewport, flowing feminine script aesthetic
     ============================================================ -->
<section class="si-hero">

  <!-- Soft gradient orbs -->
  <div class="si-orb si-orb1" aria-hidden="true"></div>
  <div class="si-orb si-orb2" aria-hidden="true"></div>
  <div class="si-orb si-orb3" aria-hidden="true"></div>

  <!-- Floating vinyl rings -->
  <div class="si-rings" aria-hidden="true">
    <div class="si-ring si-r1"></div>
    <div class="si-ring si-r2"></div>
    <div class="si-ring si-r3"></div>
  </div>

  <div class="si-hero-content">
    <div class="si-hero-tag">
      <span class="si-tag-num">09</span>
      <span class="si-tag-sep">/</span>
      <span>Script · Silhouette · Slip Mats</span>
    </div>

    <h1 class="si-hero-h1">
      <span class="si-h1-line si-h1-script">Sister</span>
      <span class="si-h1-line si-h1-solid">From Another</span>
      <span class="si-h1-line si-h1-script si-h1-pink">Mister.</span>
    </h1>

    <div class="si-brand-name-wrap">
      <span class="si-brand-name">SISTA</span>
      <span class="si-brand-tm">™</span>
    </div>

    <p class="si-hero-sub">Feminine energy on heavyweight cotton.<br>Script lettering, bold silhouettes, and a sound that moves through you.</p>

    <div class="si-hero-cta-row">
      <a class="si-cta-primary" href="#si-shop">Shop Sista &#8594;</a>
      <div class="si-hero-stats">
        <div class="si-stat">
          <span class="si-stat-n">{{ collections['sista'].products_count | default: '—' }}</span>
          <span class="si-stat-l">Pieces</span>
        </div>
        <div class="si-stat-div"></div>
        <div class="si-stat">
          <span class="si-stat-n">100%</span>
          <span class="si-stat-l">Organic</span>
        </div>
        <div class="si-stat-div"></div>
        <div class="si-stat">
          <span class="si-stat-n">UK</span>
          <span class="si-stat-l">Printed</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Large watermark -->
  <div class="si-watermark" aria-hidden="true">
    <span>SISTA</span>
  </div>

  <!-- Scroll indicator -->
  <div class="si-scroll-hint" aria-hidden="true">
    <div class="si-scroll-track"><div class="si-scroll-thumb"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     TICKER STRIP
     ============================================================ -->
<div class="si-ticker">
  <div class="si-ticker-inner">
    <span class="si-tw">SCRIPT</span><span class="si-td">◆</span>
    <span class="si-tw">SILHOUETTE</span><span class="si-td">◆</span>
    <span class="si-tw si-tw-dark">SISTA</span><span class="si-td">◆</span>
    <span class="si-tw">SLIP MATS</span><span class="si-td">◆</span>
    <span class="si-tw">VINYL CULTURE</span><span class="si-td">◆</span>
    <span class="si-tw si-tw-dark">FEMININE ENERGY</span><span class="si-td">◆</span>
    <span class="si-tw">SCRIPT</span><span class="si-td">◆</span>
    <span class="si-tw">SILHOUETTE</span><span class="si-td">◆</span>
    <span class="si-tw si-tw-dark">SISTA</span><span class="si-td">◆</span>
    <span class="si-tw">SLIP MATS</span><span class="si-td">◆</span>
    <span class="si-tw">VINYL CULTURE</span><span class="si-td">◆</span>
    <span class="si-tw si-tw-dark">FEMININE ENERGY</span><span class="si-td">◆</span>
  </div>
</div>

<!-- ============================================================
     STORY SECTION — Script-forward editorial
     ============================================================ -->
<section class="si-story">
  <div class="si-story-lhs">
    <div class="si-story-badge">
      <div class="si-badge-inner">
        <span class="si-badge-script">Sista</span>
      </div>
      <div class="si-badge-sub">SCRIPT · SILHOUETTE · SLIP MATS</div>
      <div class="si-badge-vinyl" aria-hidden="true">
        <div class="si-vinyl-ring"></div>
        <div class="si-vinyl-ring si-vinyl-ring-2"></div>
        <div class="si-vinyl-dot"></div>
      </div>
    </div>
  </div>
  <div class="si-story-rhs">
    <div class="si-story-eyebrow">The Vibe</div>
    <h2 class="si-story-h2">Sound<br>meets<br><em>silhouette.</em></h2>
    <p class="si-story-p">{{ section.settings.story_text | default: "Sista was born from the dancefloor — where music, movement, and identity collide. Script lettering that flows like a bassline, silhouettes that capture the energy of the night, and slip mats that bridge fashion and vinyl culture. This is the feminine side of the Have A Nice Day family — bold, unapologetic, and always in rhythm." }}</p>
    <div class="si-story-tags">
      <span class="si-stag">Script Lettering</span>
      <span class="si-stag">Vinyl Culture</span>
      <span class="si-stag">Heavyweight Cotton</span>
      <span class="si-stag">Camden Born</span>
    </div>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Full grid
     ============================================================ -->
<section class="si-shop hand-sec" id="si-shop">
  <div class="hand-container">
    <div class="si-shop-head">
      <div class="si-shop-head-lhs">
        <div class="eyebrow">The Collection</div>
        <h2 class="si-shop-h2">All Products.</h2>
      </div>
      <div class="si-shop-head-rhs">
        <p>Every piece from Sista — script graphics, bold silhouettes, and slip mats. Heavy cotton, UK printed, zero compromise.</p>
      </div>
    </div>

    <div class="hand-grid si-product-grid" id="si-product-grid">
      {%- for product in sista_col.products -%}
        <a class="hand-card si-card" href="{{ product.url }}">
          <div class="imgwrap">
            <span class="tag">{{ product.type | default: 'Sista' }}</span>
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Sista</div>
            <div class="name">{{ product.title }}</div>
            <div class="row2">
              <div class="price">{{ product.price | money }}</div>
              {%- if product.compare_at_price > product.price -%}
                <span class="si-sale-badge">SALE</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <!-- Coming soon state -->
        <div class="si-coming-soon-wrap">
          <div class="si-coming-soon">
            <div class="si-cs-icon" aria-hidden="true">
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="23" stroke="#F59DBA" stroke-width="2"/><circle cx="24" cy="24" r="12" stroke="#F59DBA" stroke-width="1" opacity=".4"/><circle cx="24" cy="24" r="4" fill="#F59DBA"/></svg>
            </div>
            <h3 class="si-cs-title">Coming Soon</h3>
            <p class="si-cs-text">Sista pieces are being prepared for the next drop. Script tees, silhouette graphics, and slip mats — all on heavyweight organic cotton, UK printed.</p>
            <a href="/collections/all" class="si-cta-secondary">Browse All Products &#8594;</a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING CTA
     ============================================================ -->
<section class="si-cta-section">
  <div class="si-cta-glow" aria-hidden="true"></div>
  <div class="si-cta-inner">
    <div class="si-cta-symbol" aria-hidden="true">
      <span class="si-cta-vinyl">
        <svg width="120" height="120" viewBox="0 0 120 120" fill="none">
          <circle cx="60" cy="60" r="58" stroke="#F59DBA" stroke-width="1" opacity=".3"/>
          <circle cx="60" cy="60" r="42" stroke="#F59DBA" stroke-width="1" opacity=".2"/>
          <circle cx="60" cy="60" r="26" stroke="#F59DBA" stroke-width="1" opacity=".15"/>
          <circle cx="60" cy="60" r="8" fill="#F59DBA" opacity=".6"/>
        </svg>
      </span>
    </div>
    <div class="si-cta-text">
      <h2 class="si-cta-h2">Feel the<br><em>rhythm.</em></h2>
      <p>Sista. Script · Silhouette · Slip Mats. The feminine side of Have A Nice Day — heavyweight cotton, UK printed, Camden born.</p>
      <a class="si-cta-primary" href="#si-shop">Shop All Sista &#8594;</a>
    </div>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
/* ---- TOKENS ---- */
:root {
  --si-dark: #0a0a0a;
  --si-darker: #050505;
  --si-pink: #F59DBA;
  --si-pink-dim: rgba(245,157,186,.15);
  --si-pink-glow: rgba(245,157,186,.25);
  --si-pink-deep: #d4708a;
  --si-white: #f0f0f0;
  --si-grey: rgba(240,240,240,.45);
  --si-border: rgba(240,240,240,.08);
}

/* ---- HERO ---- */
.si-hero {
  position: relative;
  min-height: 100vh;
  background: var(--si-dark);
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 120px 60px 80px;
}
@media (max-width: 768px) { .si-hero { padding: 100px 24px 60px; } }

/* Gradient orbs */
.si-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  opacity: .12;
}
.si-orb1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, #F59DBA, transparent 70%);
  top: -10%; right: -5%;
  animation: si-orb-float 12s ease-in-out infinite;
}
.si-orb2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, #e8a0c0, transparent 70%);
  bottom: 10%; left: 10%;
  animation: si-orb-float 16s ease-in-out infinite reverse;
}
.si-orb3 {
  width: 200px; height: 200px;
  background: radial-gradient(circle, #c97090, transparent 70%);
  top: 40%; right: 30%;
  animation: si-orb-float 10s ease-in-out infinite;
  animation-delay: -4s;
}
@keyframes si-orb-float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -20px) scale(1.1); }
  66% { transform: translate(-20px, 15px) scale(0.95); }
}

/* Vinyl rings */
.si-rings { position: absolute; inset: 0; pointer-events: none; }
.si-ring {
  position: absolute;
  border-radius: 50%;
  border: 1px solid var(--si-pink-dim);
  animation: si-ring-spin 30s linear infinite;
}
.si-r1 { width: 600px; height: 600px; right: -200px; top: -200px; }
.si-r2 { width: 400px; height: 400px; right: -100px; top: -100px; animation-duration: 20s; animation-direction: reverse; }
.si-r3 { width: 200px; height: 200px; right: 0; top: 0; animation-duration: 15s; }
@keyframes si-ring-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

/* Hero content */
.si-hero-content {
  position: relative;
  z-index: 2;
  max-width: 720px;
}
.si-hero-tag {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--si-grey);
  margin-bottom: 36px;
}
.si-tag-num {
  font-family: var(--display);
  font-size: 18px;
  font-weight: 900;
  color: var(--si-pink);
  line-height: 1;
}
.si-tag-sep { color: rgba(240,240,240,.2); }

.si-hero-h1 {
  font-family: var(--display);
  font-size: clamp(60px, 12vw, 160px);
  font-weight: 900;
  line-height: .88;
  letter-spacing: -.04em;
  text-transform: uppercase;
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
}
.si-h1-line { display: block; }
.si-h1-script {
  font-style: italic;
  color: var(--si-white);
  letter-spacing: -.02em;
}
.si-h1-solid {
  color: var(--si-white);
  font-size: .5em;
  letter-spacing: .02em;
}
.si-h1-pink {
  color: var(--si-pink);
  text-shadow: 0 0 60px var(--si-pink-glow);
}

.si-brand-name-wrap {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 24px;
}
.si-brand-name {
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: .4em;
  text-transform: uppercase;
  color: var(--si-pink);
  font-weight: 700;
}
.si-brand-tm {
  font-size: 10px;
  color: rgba(245,157,186,.5);
}

.si-hero-sub {
  font-size: 17px;
  line-height: 1.65;
  color: rgba(240,240,240,.75);
  margin: 0 0 40px;
  max-width: 420px;
}

.si-hero-cta-row {
  display: flex;
  align-items: center;
  gap: 40px;
  flex-wrap: wrap;
}
.si-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--si-pink);
  color: #fff;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 28px;
  font-weight: 700;
  transition: background .2s, transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.si-cta-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,.15);
  transform: translateX(-100%);
  transition: transform .3s;
}
.si-cta-primary:hover::before { transform: translateX(0); }
.si-cta-primary:hover {
  background: var(--si-pink-deep);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px var(--si-pink-glow);
}

.si-cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--si-pink);
  text-decoration: none;
  border-bottom: 1px solid var(--si-pink-dim);
  padding-bottom: 4px;
  transition: border-color .2s, gap .2s;
}
.si-cta-secondary:hover { border-color: var(--si-pink); gap: 16px; }

.si-hero-stats {
  display: flex;
  align-items: center;
  gap: 20px;
}
.si-stat { display: flex; flex-direction: column; gap: 2px; }
.si-stat-n {
  font-family: var(--display);
  font-size: 26px;
  font-weight: 900;
  color: var(--si-white);
  line-height: 1;
}
.si-stat-l {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(240,240,240,.3);
}
.si-stat-div {
  width: 1px;
  height: 32px;
  background: var(--si-border);
}

/* Watermark */
.si-watermark {
  position: absolute;
  right: -40px;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  z-index: 1;
}
.si-watermark span {
  font-family: var(--display);
  font-size: clamp(120px, 18vw, 280px);
  font-weight: 900;
  font-style: italic;
  letter-spacing: -.06em;
  text-transform: uppercase;
  color: transparent;
  -webkit-text-stroke: 1px rgba(245,157,186,.08);
  user-select: none;
}
@media (max-width: 1024px) { .si-watermark { display: none; } }

/* Scroll hint */
.si-scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 60px;
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(240,240,240,.2);
}
.si-scroll-track {
  width: 40px;
  height: 1px;
  background: rgba(240,240,240,.1);
  position: relative;
  overflow: hidden;
}
.si-scroll-thumb {
  position: absolute;
  top: 0; left: -100%;
  width: 100%; height: 100%;
  background: var(--si-pink);
  animation: si-scroll-anim 2s ease infinite;
}
@keyframes si-scroll-anim {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* ---- TICKER ---- */
.si-ticker {
  background: var(--si-pink);
  padding: 18px 0;
  overflow: hidden;
  white-space: nowrap;
}
.si-ticker-inner {
  display: inline-flex;
  gap: 24px;
  animation: si-tick 25s linear infinite;
  font-family: var(--display);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: #fff;
}
.si-td { opacity: .4; }
.si-tw-dark { color: var(--si-dark); }
@keyframes si-tick {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ---- STORY ---- */
.si-story {
  display: grid;
  grid-template-columns: 1fr 2fr;
  min-height: 580px;
  background: var(--si-darker);
}
@media (max-width: 768px) { .si-story { grid-template-columns: 1fr; } }

.si-story-lhs {
  background: #0f0f0f;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  position: relative;
  border-right: 1px solid var(--si-pink-dim);
  overflow: hidden;
}
.si-story-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  position: relative;
  z-index: 1;
}
.si-badge-inner {
  line-height: 1;
}
.si-badge-script {
  font-family: var(--display);
  font-size: clamp(56px, 9vw, 100px);
  font-weight: 900;
  font-style: italic;
  letter-spacing: -.02em;
  color: var(--si-pink);
  text-shadow: 0 0 40px var(--si-pink-glow);
}
.si-badge-sub {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: rgba(245,157,186,.5);
}
.si-badge-vinyl {
  position: absolute;
  inset: -30px;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: .06;
  animation: si-vinyl-rotate 30s linear infinite;
}
.si-vinyl-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 1px solid var(--si-pink);
}
.si-vinyl-ring-2 {
  width: 60%;
  height: 60%;
}
.si-vinyl-dot {
  position: absolute;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--si-pink);
}
@keyframes si-vinyl-rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.si-story-rhs {
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
}
@media (max-width: 768px) { .si-story-rhs { padding: 48px 24px; } }

.si-story-eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: var(--si-pink);
}
.si-story-h2 {
  font-family: var(--display);
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -.03em;
  line-height: 1;
  color: var(--si-white);
  margin: 0;
}
.si-story-h2 em {
  font-style: italic;
  color: var(--si-pink);
}
.si-story-p {
  font-size: 16px;
  line-height: 1.75;
  color: rgba(240,240,240,.5);
  margin: 0;
  max-width: 520px;
}
.si-story-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.si-stag {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: 6px 14px;
  border: 1px solid var(--si-pink-dim);
  color: rgba(245,157,186,.7);
}

/* ---- SHOP ---- */
.si-shop { background: var(--paper); }
.si-shop-head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
  margin-bottom: 48px;
}
@media (max-width: 768px) { .si-shop-head { grid-template-columns: 1fr; } }

.si-shop-h2 {
  font-family: var(--display);
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -.03em;
  line-height: 1;
  margin: 8px 0 0;
}
.si-no-img {
  width: 100%; height: 340px;
  background: #111;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--display);
  font-size: 32px;
  font-weight: 900;
  font-style: italic;
  letter-spacing: .1em;
  -webkit-text-stroke: 1px var(--si-pink);
  color: transparent;
}
.si-sale-badge {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .15em;
  background: var(--si-pink);
  color: #fff;
  padding: 3px 8px;
  font-weight: 700;
}

/* Card hover — pink glow */
.si-card {
  transition: transform .3s, box-shadow .3s;
}
.si-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(245,157,186,.15);
}

/* Coming soon */
.si-coming-soon-wrap {
  grid-column: 1 / -1;
  display: flex;
  justify-content: center;
  padding: 60px 0;
}
.si-coming-soon {
  text-align: center;
  max-width: 480px;
  padding: 60px 40px;
  background: #0f0f0f;
  border: 1px solid var(--si-pink-dim);
  position: relative;
}
.si-cs-icon {
  margin-bottom: 24px;
  animation: si-vinyl-rotate 10s linear infinite;
}
.si-cs-title {
  font-family: var(--display);
  font-size: 28px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -.02em;
  color: var(--si-pink);
  margin: 0 0 16px;
}
.si-cs-text {
  font-size: 15px;
  line-height: 1.7;
  color: rgba(240,240,240,.45);
  margin: 0 0 32px;
}

/* ---- CLOSING CTA ---- */
.si-cta-section {
  background: var(--si-dark);
  padding: 100px 60px;
  overflow: hidden;
  position: relative;
}
@media (max-width: 768px) { .si-cta-section { padding: 60px 24px; } }

.si-cta-glow {
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--si-pink-glow), transparent 70%);
  top: 50%;
  left: 20%;
  transform: translateY(-50%);
  filter: blur(60px);
  pointer-events: none;
  opacity: .15;
}

.si-cta-inner {
  display: flex;
  align-items: center;
  gap: 80px;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
@media (max-width: 768px) { .si-cta-inner { flex-direction: column; gap: 40px; } }

.si-cta-symbol {
  flex-shrink: 0;
  width: 160px;
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.si-cta-vinyl {
  animation: si-vinyl-rotate 15s linear infinite;
  display: block;
}

.si-cta-text { flex: 1; }
.si-cta-h2 {
  font-family: var(--display);
  font-size: clamp(32px, 5vw, 60px);
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -.03em;
  line-height: 1;
  color: var(--si-white);
  margin: 0 0 20px;
}
.si-cta-h2 em {
  font-style: italic;
  color: var(--si-pink);
}
.si-cta-text p {
  font-size: 15px;
  line-height: 1.65;
  color: rgba(240,240,240,.45);
  margin: 0 0 32px;
}
</style>

<!-- ============================================================
     SCRIPTS — Motion.dev animations
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  if (window.Motion) {
    var { animate, stagger, inView } = window.Motion;

    // Hero entrance
    animate('.si-hero-tag', { opacity: [0, 1], x: [-20, 0] }, { duration: 0.6, delay: 0.2 });

    animate('.si-h1-line', { opacity: [0, 1], y: [80, 0], skewY: [4, 0] },
      { delay: stagger(0.12, { start: 0.4 }), duration: 0.9, easing: [0.22, 1, 0.36, 1] });

    animate('.si-brand-name-wrap', { opacity: [0, 1], x: [-20, 0] }, { duration: 0.6, delay: 0.8 });
    animate('.si-hero-sub', { opacity: [0, 1], y: [20, 0] }, { duration: 0.6, delay: 1.0 });
    animate('.si-hero-cta-row', { opacity: [0, 1], y: [20, 0] }, { duration: 0.6, delay: 1.2 });

    // Watermark
    animate('.si-watermark', { opacity: [0, 1], x: [60, 0] },
      { duration: 1.2, delay: 0.6, easing: [0.22, 1, 0.36, 1] });

    // Story section
    inView('.si-story-badge', function(el) {
      animate(el, { opacity: [0, 1], scale: [0.8, 1] },
        { duration: 0.8, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-10% 0px' });

    inView('.si-story-rhs', function(el) {
      animate(el.querySelectorAll('.si-story-eyebrow, .si-story-h2, .si-story-p, .si-story-tags'),
        { opacity: [0, 1], x: [40, 0] },
        { delay: stagger(0.1), duration: 0.7, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-10% 0px' });

    // Product cards
    inView('.si-card', function(el) {
      animate(el, { opacity: [0, 1], y: [40, 0] },
        { duration: 0.6, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-5% 0px' });

    // Coming soon
    inView('.si-coming-soon', function(el) {
      animate(el, { opacity: [0, 1], y: [30, 0], scale: [0.95, 1] },
        { duration: 0.8, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-10% 0px' });

    // CTA
    inView('.si-cta-symbol', function(el) {
      animate(el, { opacity: [0, 1], scale: [0.6, 1], rotate: [-15, 0] },
        { duration: 0.9, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-10% 0px' });

    inView('.si-cta-h2', function(el) {
      animate(el, { opacity: [0, 1], y: [40, 0] },
        { duration: 0.8, easing: [0.22, 1, 0.36, 1] });
    }, { margin: '-10% 0px' });
  }
});
</script>

{% schema %}
{
  "name": "Brand: Sista",
  "settings": [
    { "type": "textarea", "id": "story_text", "label": "Brand story text", "default": "Sista was born from the dancefloor — where music, movement, and identity collide. Script lettering that flows like a bassline, silhouettes that capture the energy of the night, and slip mats that bridge fashion and vinyl culture. This is the feminine side of the Have A Nice Day family — bold, unapologetic, and always in rhythm." }
  ],
  "presets": [
    { "name": "Brand: Sista" }
  ]
}
{% endschema %}
