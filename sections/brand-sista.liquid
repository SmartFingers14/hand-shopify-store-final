{% comment %}
  Brand Page: Sista — Script · Silhouette · Slip Mats
  ★ WOW-FACTOR REDESIGN: Immersive, cinematic, full creative expression
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}

<!-- ============================================================
     HERO — Cinematic full-bleed with morphing blobs + magnetic text
     ============================================================ -->
<section class="si-hero" id="si-top">
  <canvas class="si-hero-canvas" id="siCanvas"></canvas>

  <!-- Morphing gradient blobs -->
  <div class="si-blob si-blob-1"></div>
  <div class="si-blob si-blob-2"></div>
  <div class="si-blob si-blob-3"></div>

  <!-- Spinning vinyl in corner -->
  <div class="si-vinyl-hero" aria-hidden="true">
    <div class="si-vinyl-disc">
      <div class="si-vinyl-groove si-vg1"></div>
      <div class="si-vinyl-groove si-vg2"></div>
      <div class="si-vinyl-groove si-vg3"></div>
      <div class="si-vinyl-groove si-vg4"></div>
      <div class="si-vinyl-label">
        <span>SISTA</span>
      </div>
    </div>
  </div>

  <div class="si-hero-inner">
    <div class="si-hero-meta">
      <span class="si-meta-line"></span>
      <span class="si-meta-text">09 / Script · Silhouette · Slip Mats</span>
    </div>

    <h1 class="si-hero-title">
      <span class="si-title-row si-tr1" data-text="SISTER">SISTER</span>
      <span class="si-title-row si-tr2">FROM <em>ANOTHER</em></span>
      <span class="si-title-row si-tr3" data-text="MISTER.">MISTER.</span>
    </h1>

    <div class="si-hero-bottom">
      <p class="si-hero-desc">Feminine energy on heavyweight cotton. Script lettering, bold silhouettes, and a sound that moves through you. Born on the dancefloor. Camden, 1990.</p>
      <a class="si-hero-cta" href="#si-shop">
        <span class="si-cta-text">Explore Sista</span>
        <span class="si-cta-arrow">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="si-scroll-cue">
    <div class="si-scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     MARQUEE — Oversized flowing text
     ============================================================ -->
<div class="si-marquee">
  <div class="si-marquee-track">
    <span class="si-mq-item">SISTA <em>♦</em></span>
    <span class="si-mq-item">SCRIPT <em>♦</em></span>
    <span class="si-mq-item">SILHOUETTE <em>♦</em></span>
    <span class="si-mq-item">SLIP MATS <em>♦</em></span>
    <span class="si-mq-item">VINYL <em>♦</em></span>
    <span class="si-mq-item">RHYTHM <em>♦</em></span>
    <span class="si-mq-item">SISTA <em>♦</em></span>
    <span class="si-mq-item">SCRIPT <em>♦</em></span>
    <span class="si-mq-item">SILHOUETTE <em>♦</em></span>
    <span class="si-mq-item">SLIP MATS <em>♦</em></span>
    <span class="si-mq-item">VINYL <em>♦</em></span>
    <span class="si-mq-item">RHYTHM <em>♦</em></span>
  </div>
</div>

<!-- ============================================================
     STORY — Split screen editorial with parallax
     ============================================================ -->
<section class="si-story">
  <div class="si-story-visual">
    <div class="si-story-vinyl-wrap">
      <div class="si-story-vinyl">
        <div class="si-sv-ring si-sv1"></div>
        <div class="si-sv-ring si-sv2"></div>
        <div class="si-sv-ring si-sv3"></div>
        <div class="si-sv-center">
          <span class="si-sv-label">Sista</span>
          <span class="si-sv-sub">45 RPM</span>
        </div>
      </div>
    </div>
    <div class="si-story-floater si-sf1">Script</div>
    <div class="si-story-floater si-sf2">Vinyl</div>
    <div class="si-story-floater si-sf3">Rhythm</div>
  </div>

  <div class="si-story-content">
    <div class="si-story-eyebrow">
      <span class="si-se-dot"></span>
      The Vibe
    </div>
    <h2 class="si-story-h2">
      <span class="si-sh-line">Sound</span>
      <span class="si-sh-line">meets</span>
      <span class="si-sh-line si-sh-accent">silhouette.</span>
    </h2>
    <p class="si-story-body">Sista was born from the dancefloor — where music, movement, and identity collide. Script lettering that flows like a bassline, silhouettes that capture the energy of the night, and slip mats that bridge fashion and vinyl culture.</p>
    <p class="si-story-body">This is the feminine side of the Have A Nice Day family — bold, unapologetic, and always in rhythm.</p>

    <div class="si-story-pills">
      <span class="si-pill">Script Lettering</span>
      <span class="si-pill">Vinyl Culture</span>
      <span class="si-pill">220gsm Organic</span>
      <span class="si-pill">UK Printed</span>
    </div>

    <div class="si-story-stats">
      <div class="si-ss">
        <span class="si-ss-num">09</span>
        <span class="si-ss-label">Sub-Brand</span>
      </div>
      <div class="si-ss-divider"></div>
      <div class="si-ss">
        <span class="si-ss-num">100%</span>
        <span class="si-ss-label">Organic</span>
      </div>
      <div class="si-ss-divider"></div>
      <div class="si-ss">
        <span class="si-ss-num">UK</span>
        <span class="si-ss-label">Printed</span>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     PRODUCTS
     ============================================================ -->
<section class="si-shop hand-sec" id="si-shop">
  <div class="hand-container">
    <div class="si-shop-header">
      <div class="si-shop-eyebrow">
        <span class="si-se-dot"></span>
        The Collection
      </div>
      <h2 class="si-shop-h2">
        <span class="si-shop-h2-line">All</span>
        <span class="si-shop-h2-line si-shop-h2-accent">Products.</span>
      </h2>
    </div>

    <div class="hand-grid si-product-grid" id="si-product-grid">
      {%- for product in sista_col.products -%}
        <a class="hand-card si-card" href="{{ product.url }}">
          <div class="imgwrap">
            <span class="tag">{{ product.type | default: 'Sista' }}</span>
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            <span class="quick">Quick Add &#8594;</span>
          </div>
          <div class="body">
            <div class="vendor">Sista</div>
            <div class="name">{{ product.title }}</div>
            <div class="row2">
              <div class="price">{{ product.price | money }}</div>
              {%- if product.compare_at_price > product.price -%}
                <span class="si-sale-badge">SALE</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <div class="si-coming-soon-wrap">
          <div class="si-coming-soon">
            <div class="si-cs-vinyl-icon">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="30" stroke="#F59DBA" stroke-width="1.5" opacity=".5"/>
                <circle cx="32" cy="32" r="20" stroke="#F59DBA" stroke-width="1" opacity=".3"/>
                <circle cx="32" cy="32" r="10" stroke="#F59DBA" stroke-width="1" opacity=".2"/>
                <circle cx="32" cy="32" r="4" fill="#F59DBA"/>
              </svg>
            </div>
            <h3 class="si-cs-h3">Dropping Soon</h3>
            <p class="si-cs-p">Sista pieces are being prepared. Script tees, silhouette graphics, and slip mats — all on heavyweight organic cotton, UK printed.</p>
            <a href="/collections/all" class="si-cs-link">Browse All Products →</a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING CTA — Cinematic full-bleed
     ============================================================ -->
<section class="si-closer">
  <div class="si-closer-bg"></div>
  <div class="si-closer-inner">
    <div class="si-closer-eyebrow">
      <span class="si-se-dot"></span>
      Camden Born · UK Made
    </div>
    <h2 class="si-closer-h2">
      <span class="si-ch-line">Feel the</span>
      <span class="si-ch-line si-ch-accent">rhythm.</span>
    </h2>
    <p class="si-closer-p">Sista. Script · Silhouette · Slip Mats. The feminine side of Have A Nice Day.</p>
    <a class="si-closer-cta" href="#si-shop">
      <span>Shop Sista</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
/* ═══════ TOKENS ═══════ */
:root{
  --si:#F59DBA;--si2:#e87da5;--si3:#d4608a;
  --si-g1:rgba(245,157,186,.12);--si-g2:rgba(245,157,186,.06);
  --si-dark:#060608;--si-card:#0c0c10;
}

/* ═══════ HERO ═══════ */
.si-hero{position:relative;min-height:100vh;background:var(--si-dark);display:flex;align-items:center;overflow:hidden;padding:0 clamp(24px,5vw,80px)}
.si-hero-canvas{position:absolute;inset:0;width:100%;height:100%;opacity:.06;pointer-events:none}

/* Morphing blobs */
.si-blob{position:absolute;border-radius:50%;filter:blur(100px);pointer-events:none;mix-blend-mode:screen}
.si-blob-1{width:55vw;height:55vw;max-width:700px;max-height:700px;background:radial-gradient(circle,rgba(245,157,186,.18),transparent 70%);top:-15%;right:-10%;animation:si-bmorph 18s ease-in-out infinite}
.si-blob-2{width:35vw;height:35vw;max-width:450px;max-height:450px;background:radial-gradient(circle,rgba(200,100,160,.12),transparent 70%);bottom:5%;left:5%;animation:si-bmorph 22s ease-in-out infinite reverse}
.si-blob-3{width:25vw;height:25vw;max-width:320px;max-height:320px;background:radial-gradient(circle,rgba(255,180,210,.1),transparent 70%);top:35%;right:25%;animation:si-bmorph 15s ease-in-out infinite;animation-delay:-6s}
@keyframes si-bmorph{
  0%,100%{border-radius:60% 40% 30% 70%/60% 30% 70% 40%;transform:translate(0,0) scale(1)}
  25%{border-radius:30% 60% 70% 40%/50% 60% 30% 60%;transform:translate(30px,-40px) scale(1.05)}
  50%{border-radius:50% 60% 30% 50%/40% 50% 60% 50%;transform:translate(-20px,20px) scale(.95)}
  75%{border-radius:40% 50% 60% 40%/60% 40% 50% 60%;transform:translate(15px,25px) scale(1.02)}
}

/* Vinyl in hero */
.si-vinyl-hero{position:absolute;right:-6vw;top:50%;transform:translateY(-50%);width:clamp(300px,42vw,640px);height:clamp(300px,42vw,640px);opacity:.15;animation:si-vspin 25s linear infinite}
@keyframes si-vspin{to{transform:translateY(-50%) rotate(360deg)}}
.si-vinyl-disc{width:100%;height:100%;border-radius:50%;background:radial-gradient(circle at 50% 50%,#1a1a20 0%,#0d0d12 40%,#1a1a20 41%,#0d0d12 60%,#1a1a20 61%,#0d0d12 80%,#1a1a20 81%,#0d0d12 100%);position:relative}
.si-vinyl-groove{position:absolute;border-radius:50%;border:1px solid rgba(245,157,186,.08);left:50%;top:50%;transform:translate(-50%,-50%)}
.si-vg1{width:90%;height:90%}.si-vg2{width:70%;height:70%}.si-vg3{width:50%;height:50%}.si-vg4{width:30%;height:30%}
.si-vinyl-label{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:22%;height:22%;border-radius:50%;background:var(--si);display:flex;flex-direction:column;align-items:center;justify-content:center}
.si-vinyl-label span{font-family:var(--display);font-size:clamp(10px,1.2vw,18px);font-weight:900;letter-spacing:.1em;color:#fff;text-transform:uppercase}
@media(max-width:1024px){.si-vinyl-hero{display:none}}

/* Hero content */
.si-hero-inner{position:relative;z-index:2;max-width:900px;width:100%}
.si-hero-meta{display:flex;align-items:center;gap:16px;margin-bottom:48px}
.si-meta-line{width:48px;height:1px;background:var(--si);display:block}
.si-meta-text{font-family:var(--mono);font-size:11px;letter-spacing:.25em;text-transform:uppercase;color:rgba(245,157,186,.7)}

.si-hero-title{margin:0 0 48px}
.si-title-row{display:block;font-family:var(--display);font-weight:900;text-transform:uppercase;line-height:.88;letter-spacing:-.04em;position:relative}
.si-tr1{font-size:clamp(64px,13vw,180px);color:transparent;-webkit-text-stroke:2px #fff}
.si-tr2{font-size:clamp(28px,4.5vw,64px);color:rgba(255,255,255,.6);letter-spacing:.02em;margin:8px 0}
.si-tr2 em{font-style:italic;color:var(--si);-webkit-text-stroke:0}
.si-tr3{font-size:clamp(64px,13vw,180px);color:var(--si);text-shadow:0 0 80px rgba(245,157,186,.3)}

.si-hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;gap:40px;flex-wrap:wrap}
.si-hero-desc{font-size:16px;line-height:1.7;color:rgba(255,255,255,.5);max-width:420px;margin:0}
.si-hero-cta{display:inline-flex;align-items:center;gap:12px;background:var(--si);color:#fff;font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;padding:18px 28px;font-weight:700;overflow:hidden;position:relative;transition:transform .3s,box-shadow .3s}
.si-hero-cta:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(245,157,186,.35)}
.si-cta-arrow{display:flex;transition:transform .3s}.si-hero-cta:hover .si-cta-arrow{transform:translateX(4px)}

/* Scroll cue */
.si-scroll-cue{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:12px}
.si-scroll-cue span{font-family:var(--mono);font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.2)}
.si-scroll-line{width:1px;height:48px;background:linear-gradient(to bottom,var(--si),transparent);animation:si-scroll-pulse 2s ease-in-out infinite}
@keyframes si-scroll-pulse{0%,100%{opacity:.3;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.2)}}

/* ═══════ MARQUEE ═══════ */
.si-marquee{background:var(--si);padding:20px 0;overflow:hidden;position:relative}
.si-marquee-track{display:flex;gap:0;animation:si-mq 20s linear infinite;width:max-content}
.si-mq-item{font-family:var(--display);font-size:clamp(14px,2vw,22px);font-weight:900;letter-spacing:.15em;text-transform:uppercase;color:#fff;padding:0 24px;white-space:nowrap}
.si-mq-item em{font-style:normal;color:rgba(0,0,0,.25);font-size:.7em;vertical-align:middle}
@keyframes si-mq{to{transform:translateX(-50%)}}

/* ═══════ STORY ═══════ */
.si-story{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;background:var(--si-dark)}
@media(max-width:900px){.si-story{grid-template-columns:1fr;min-height:auto}}

.si-story-visual{position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#08080c;padding:80px 40px}
.si-story-vinyl-wrap{width:clamp(200px,22vw,360px);height:clamp(200px,22vw,360px);position:relative}
.si-story-vinyl{width:100%;height:100%;border-radius:50%;background:conic-gradient(from 0deg,#1a1a22,#0d0d14,#1a1a22,#0d0d14,#1a1a22,#0d0d14,#1a1a22);position:relative;animation:si-vspin2 12s linear infinite;box-shadow:0 0 60px rgba(245,157,186,.1)}
@keyframes si-vspin2{to{transform:rotate(360deg)}}
.si-sv-ring{position:absolute;border-radius:50%;border:1px solid rgba(245,157,186,.1);left:50%;top:50%;transform:translate(-50%,-50%)}
.si-sv1{width:85%;height:85%}.si-sv2{width:60%;height:60%}.si-sv3{width:35%;height:35%}
.si-sv-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:28%;height:28%;border-radius:50%;background:var(--si);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px}
.si-sv-label{font-family:var(--display);font-size:clamp(12px,1.5vw,20px);font-weight:900;color:#fff;letter-spacing:.08em}
.si-sv-sub{font-family:var(--mono);font-size:7px;letter-spacing:.2em;color:rgba(255,255,255,.6);text-transform:uppercase}

/* Floating words */
.si-story-floater{position:absolute;font-family:var(--display);font-weight:900;text-transform:uppercase;color:transparent;-webkit-text-stroke:1px rgba(245,157,186,.08);pointer-events:none;user-select:none}
.si-sf1{font-size:clamp(60px,8vw,120px);top:10%;left:-10%;transform:rotate(-12deg)}
.si-sf2{font-size:clamp(40px,5vw,80px);bottom:15%;right:-5%;transform:rotate(8deg)}
.si-sf3{font-size:clamp(50px,6vw,90px);top:55%;left:60%;transform:rotate(-5deg)}

.si-story-content{padding:clamp(48px,8vw,100px) clamp(32px,5vw,80px);display:flex;flex-direction:column;justify-content:center;gap:32px}
.si-story-eyebrow,.si-shop-eyebrow,.si-closer-eyebrow{display:flex;align-items:center;gap:12px;font-family:var(--mono);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--si)}
.si-se-dot{width:6px;height:6px;border-radius:50%;background:var(--si);animation:si-dot-pulse 2s ease infinite}
@keyframes si-dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}

.si-story-h2{margin:0}
.si-sh-line{display:block;font-family:var(--display);font-size:clamp(36px,5.5vw,72px);font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:.95;color:#fff}
.si-sh-accent{color:var(--si);font-style:italic}

.si-story-body{font-size:16px;line-height:1.8;color:rgba(255,255,255,.45);margin:0;max-width:480px}

.si-story-pills{display:flex;flex-wrap:wrap;gap:8px}
.si-pill{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;padding:8px 16px;border:1px solid rgba(245,157,186,.15);color:rgba(245,157,186,.65);backdrop-filter:blur(4px);transition:all .3s}
.si-pill:hover{border-color:var(--si);color:var(--si);background:rgba(245,157,186,.05)}

.si-story-stats{display:flex;align-items:center;gap:24px;padding-top:12px}
.si-ss{display:flex;flex-direction:column;gap:3px}
.si-ss-num{font-family:var(--display);font-size:28px;font-weight:900;color:#fff;line-height:1}
.si-ss-label{font-family:var(--mono);font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.25)}
.si-ss-divider{width:1px;height:36px;background:rgba(255,255,255,.08)}

/* ═══════ SHOP ═══════ */
.si-shop{background:var(--paper)}
.si-shop-header{margin-bottom:48px}
.si-shop-h2{margin:12px 0 0}
.si-shop-h2-line{display:block;font-family:var(--display);font-size:clamp(40px,7vw,80px);font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:.92}
.si-shop-h2-accent{color:var(--si);font-style:italic}

.si-no-img{width:100%;height:340px;background:#111;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:36px;font-weight:900;font-style:italic;-webkit-text-stroke:1px var(--si);color:transparent}
.si-sale-badge{font-family:var(--mono);font-size:9px;letter-spacing:.15em;background:var(--si);color:#fff;padding:3px 8px;font-weight:700}
.si-card{transition:transform .4s cubic-bezier(.22,1,.36,1),box-shadow .4s}
.si-card:hover{transform:translateY(-8px) scale(1.01);box-shadow:0 24px 60px rgba(245,157,186,.12)}

/* Coming soon */
.si-coming-soon-wrap{grid-column:1/-1;display:flex;justify-content:center;padding:80px 0}
.si-coming-soon{text-align:center;max-width:520px;padding:64px 48px;background:rgba(245,157,186,.02);border:1px solid rgba(245,157,186,.1);backdrop-filter:blur(10px);position:relative}
.si-coming-soon::before{content:'';position:absolute;inset:-1px;border:1px solid transparent;background:linear-gradient(135deg,rgba(245,157,186,.2),transparent,rgba(245,157,186,.1)) border-box;-webkit-mask:linear-gradient(#fff 0 0) padding-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;border-radius:0;pointer-events:none}
.si-cs-vinyl-icon{margin-bottom:24px;animation:si-vspin2 8s linear infinite;display:inline-block}
.si-cs-h3{font-family:var(--display);font-size:32px;font-weight:900;text-transform:uppercase;letter-spacing:-.02em;color:var(--si);margin:0 0 16px}
.si-cs-p{font-size:15px;line-height:1.7;color:rgba(240,240,240,.4);margin:0 0 32px}
.si-cs-link{font-family:var(--mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--si);text-decoration:none;border-bottom:1px solid rgba(245,157,186,.2);padding-bottom:4px;transition:border-color .2s}
.si-cs-link:hover{border-color:var(--si)}

/* ═══════ CLOSER CTA ═══════ */
.si-closer{position:relative;padding:clamp(80px,12vw,160px) clamp(24px,5vw,80px);background:var(--si-dark);overflow:hidden;text-align:center}
.si-closer-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 80%,rgba(245,157,186,.08),transparent 60%);pointer-events:none}
.si-closer-inner{position:relative;z-index:1;max-width:700px;margin:0 auto}
.si-closer-eyebrow{justify-content:center;margin-bottom:32px}
.si-closer-h2{margin:0 0 24px}
.si-ch-line{display:block;font-family:var(--display);font-size:clamp(48px,9vw,120px);font-weight:900;text-transform:uppercase;letter-spacing:-.04em;line-height:.88;color:#fff}
.si-ch-accent{color:var(--si);font-style:italic;text-shadow:0 0 80px rgba(245,157,186,.25)}
.si-closer-p{font-size:17px;line-height:1.7;color:rgba(255,255,255,.4);margin:0 0 40px}
.si-closer-cta{display:inline-flex;align-items:center;gap:12px;background:var(--si);color:#fff;font-family:var(--mono);font-size:12px;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;padding:20px 36px;font-weight:700;transition:transform .3s,box-shadow .3s}
.si-closer-cta:hover{transform:translateY(-3px);box-shadow:0 16px 48px rgba(245,157,186,.3)}
.si-closer-cta svg{transition:transform .3s}.si-closer-cta:hover svg{transform:translateX(4px)}

/* ═══════ RESPONSIVE ═══════ */
@media(max-width:640px){
  .si-hero-bottom{flex-direction:column;align-items:flex-start}
  .si-story-visual{padding:48px 24px;min-height:300px}
  .si-story-stats{flex-wrap:wrap;gap:16px}
}
</style>

<!-- ============================================================
     SCRIPTS — Motion.dev cinematics
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded',function(){
  /* ——— Particle canvas ——— */
  (function(){
    var c=document.getElementById('siCanvas');if(!c)return;
    var ctx=c.getContext('2d'),w,h,particles=[];
    function resize(){w=c.width=c.offsetWidth;h=c.height=c.offsetHeight}
    resize();window.addEventListener('resize',resize);
    for(var i=0;i<60;i++){
      particles.push({x:Math.random()*w,y:Math.random()*h,r:Math.random()*2+.5,dx:(Math.random()-.5)*.4,dy:(Math.random()-.5)*.4,o:Math.random()*.5+.2});
    }
    function draw(){
      ctx.clearRect(0,0,w,h);
      particles.forEach(function(p){
        p.x+=p.dx;p.y+=p.dy;
        if(p.x<0)p.x=w;if(p.x>w)p.x=0;if(p.y<0)p.y=h;if(p.y>h)p.y=0;
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx.fillStyle='rgba(245,157,186,'+p.o+')';ctx.fill();
      });
      // Draw connecting lines
      for(var i=0;i<particles.length;i++){
        for(var j=i+1;j<particles.length;j++){
          var dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,d=Math.sqrt(dx*dx+dy*dy);
          if(d<120){
            ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);
            ctx.strokeStyle='rgba(245,157,186,'+(0.08*(1-d/120))+')';ctx.lineWidth=.5;ctx.stroke();
          }
        }
      }
      requestAnimationFrame(draw);
    }
    draw();
  })();

  /* ——— Motion.dev animations ——— */
  if(!window.Motion)return;
  var M=window.Motion,animate=M.animate,stagger=M.stagger,inView=M.inView;

  // Hero — cinematic entrance
  animate('.si-meta-line',{scaleX:[0,1]},{duration:.6,delay:.2,easing:[.22,1,.36,1]});
  animate('.si-meta-text',{opacity:[0,1],x:[-20,0]},{duration:.6,delay:.4});

  animate('.si-tr1',{opacity:[0,1],y:[120,0],skewY:[8,0]},{duration:1.2,delay:.5,easing:[.22,1,.36,1]});
  animate('.si-tr2',{opacity:[0,1],y:[60,0]},{duration:.9,delay:.8,easing:[.22,1,.36,1]});
  animate('.si-tr3',{opacity:[0,1],y:[120,0],skewY:[-6,0]},{duration:1.2,delay:1,easing:[.22,1,.36,1]});

  animate('.si-hero-desc',{opacity:[0,1],y:[30,0]},{duration:.8,delay:1.4});
  animate('.si-hero-cta',{opacity:[0,1],y:[20,0]},{duration:.7,delay:1.6});
  animate('.si-scroll-cue',{opacity:[0,1]},{duration:.6,delay:2});

  // Blobs entrance
  animate('.si-blob',{opacity:[0,1],scale:[.5,1]},{delay:stagger(.2,{start:.3}),duration:1.5,easing:'ease-out'});

  // Story section
  inView('.si-story-vinyl-wrap',function(info){
    animate(info.target,{opacity:[0,1],scale:[.6,1],rotate:[-45,0]},{duration:1.2,easing:[.22,1,.36,1]});
  },{margin:'-15% 0px'});

  inView('.si-story-content',function(info){
    var els=info.target.querySelectorAll('.si-story-eyebrow,.si-sh-line,.si-story-body,.si-story-pills,.si-story-stats');
    animate(els,{opacity:[0,1],y:[40,0]},{delay:stagger(.08),duration:.7,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Floating words parallax
  document.querySelectorAll('.si-story-floater').forEach(function(el,i){
    animate(el,{opacity:[0,.15],x:[i%2===0?-60:60,0]},{duration:1.5,delay:.3+i*.2,easing:'ease-out'});
  });

  // Pills stagger
  inView('.si-story-pills',function(info){
    animate(info.target.querySelectorAll('.si-pill'),{opacity:[0,1],y:[20,0],scale:[.9,1]},{delay:stagger(.06),duration:.5,easing:[.22,1,.36,1]});
  },{margin:'-5% 0px'});

  // Product cards
  inView('.si-card',function(info){
    animate(info.target,{opacity:[0,1],y:[50,0]},{duration:.7,easing:[.22,1,.36,1]});
  },{margin:'-5% 0px'});

  // Coming soon
  inView('.si-coming-soon',function(info){
    animate(info.target,{opacity:[0,1],y:[40,0],scale:[.95,1]},{duration:1,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Shop header
  inView('.si-shop-header',function(info){
    animate(info.target.querySelectorAll('.si-shop-eyebrow,.si-shop-h2-line'),{opacity:[0,1],y:[60,0]},{delay:stagger(.1),duration:.8,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Closer — dramatic reveal
  inView('.si-closer-inner',function(info){
    animate(info.target.querySelector('.si-closer-eyebrow'),{opacity:[0,1]},{duration:.6});
    animate(info.target.querySelectorAll('.si-ch-line'),{opacity:[0,1],y:[80,0],skewY:[4,0]},{delay:stagger(.12,{start:.2}),duration:1,easing:[.22,1,.36,1]});
    animate(info.target.querySelector('.si-closer-p'),{opacity:[0,1],y:[30,0]},{duration:.7,delay:.6});
    animate(info.target.querySelector('.si-closer-cta'),{opacity:[0,1],y:[20,0]},{duration:.6,delay:.8});
  },{margin:'-15% 0px'});

  // Marquee — entrance
  inView('.si-marquee',function(info){
    animate(info.target,{opacity:[0,1],y:[20,0]},{duration:.5});
  });
});
</script>

