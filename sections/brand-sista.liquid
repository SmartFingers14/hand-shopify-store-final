{% comment %}
  Brand Page: Sista — Colorful Retro 90s Women's Graphic Tees
  PERSONA: Bold, vibrant, fun feminine energy. 90s rave-era colour pop.
  Camden-born women's streetwear with hand-drawn graphic prints.
{% endcomment %}

{%- assign sista_col = collections['sista'] -%}

<!-- ============================================================
     HERO — Vibrant 90s colour-pop with geometric shapes
     ============================================================ -->
<section class="si-hero" id="si-top">
  <!-- Animated colour shapes -->
  <div class="si-shape si-sh1" aria-hidden="true"></div>
  <div class="si-shape si-sh2" aria-hidden="true"></div>
  <div class="si-shape si-sh3" aria-hidden="true"></div>
  <div class="si-shape si-sh4" aria-hidden="true"></div>
  <div class="si-shape si-sh5" aria-hidden="true"></div>

  <!-- Confetti dots -->
  <div class="si-confetti" aria-hidden="true">
    <span class="si-dot si-d1"></span><span class="si-dot si-d2"></span>
    <span class="si-dot si-d3"></span><span class="si-dot si-d4"></span>
    <span class="si-dot si-d5"></span><span class="si-dot si-d6"></span>
    <span class="si-dot si-d7"></span><span class="si-dot si-d8"></span>
    <span class="si-dot si-d9"></span><span class="si-dot si-d10"></span>
    <span class="si-dot si-d11"></span><span class="si-dot si-d12"></span>
  </div>

  <!-- Squiggle SVGs -->
  <svg class="si-squiggle si-sq1" viewBox="0 0 120 20" aria-hidden="true"><path d="M0 10 Q15 0 30 10 Q45 20 60 10 Q75 0 90 10 Q105 20 120 10" stroke="rgba(255,200,50,.25)" fill="none" stroke-width="2"/></svg>
  <svg class="si-squiggle si-sq2" viewBox="0 0 120 20" aria-hidden="true"><path d="M0 10 Q15 0 30 10 Q45 20 60 10 Q75 0 90 10 Q105 20 120 10" stroke="rgba(245,157,186,.2)" fill="none" stroke-width="2"/></svg>

  <div class="si-hero-inner">
    <div class="si-hero-meta">
      <span class="si-badge-90s">90s</span>
      <span class="si-meta-text">09 / Women's Graphic Tees</span>
    </div>

    <h1 class="si-hero-title">
      <span class="si-title-row si-tr1">SISTA</span>
      <span class="si-title-row si-tr2">From <em>Another</em></span>
      <span class="si-title-row si-tr3">Mister.</span>
    </h1>

    <p class="si-hero-desc">Colourful retro graphic tees made for women who own the room. Hand-drawn 90s prints on heavyweight organic cotton. Camden born, UK printed.</p>

    <div class="si-hero-cta-row">
      <a class="si-cta-main" href="#si-shop">
        Shop Sista
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <div class="si-hero-stats">
        <div class="si-hs"><span class="si-hs-n">100%</span><span class="si-hs-l">Organic</span></div>
        <div class="si-hs-div"></div>
        <div class="si-hs"><span class="si-hs-n">UK</span><span class="si-hs-l">Printed</span></div>
        <div class="si-hs-div"></div>
        <div class="si-hs"><span class="si-hs-n">220g</span><span class="si-hs-l">Cotton</span></div>
      </div>
    </div>
  </div>

  <div class="si-scroll-cue">
    <div class="si-scroll-bar"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     MARQUEE — Bold colourful ticker
     ============================================================ -->
<div class="si-marquee">
  <div class="si-mq-track">
    {%- for i in (1..2) -%}
    <span class="si-mq-w">SISTA</span><span class="si-mq-star">★</span>
    <span class="si-mq-w si-mq-outline">RETRO</span><span class="si-mq-star">★</span>
    <span class="si-mq-w">GRAPHIC TEES</span><span class="si-mq-star">★</span>
    <span class="si-mq-w si-mq-outline">90s VIBES</span><span class="si-mq-star">★</span>
    <span class="si-mq-w">FOR HER</span><span class="si-mq-star">★</span>
    <span class="si-mq-w si-mq-outline">CAMDEN</span><span class="si-mq-star">★</span>
    {%- endfor -%}
  </div>
</div>

<!-- ============================================================
     STORY — Bold editorial, retro energy
     ============================================================ -->
<section class="si-story">
  <div class="si-story-lhs">
    <div class="si-story-badge-wrap">
      <div class="si-story-badge">
        <span class="si-sb-text">S</span>
      </div>
      <div class="si-retro-ring si-rr1"></div>
      <div class="si-retro-ring si-rr2"></div>
    </div>
    <div class="si-story-floats">
      <span class="si-float-word si-fw1">Bold</span>
      <span class="si-float-word si-fw2">Colour</span>
      <span class="si-float-word si-fw3">Retro</span>
    </div>
  </div>

  <div class="si-story-rhs">
    <div class="si-eyebrow"><span class="si-eye-dot"></span>The Vibe</div>
    <h2 class="si-story-h2">
      <span>Colour is</span>
      <span class="si-h2-pop">her weapon.</span>
    </h2>
    <p class="si-story-p">Sista is the women's arm of the Have A Nice Day family — born from the same Camden energy, the same hand-drawn graphics, the same rave-era spirit. But with her own rules.</p>
    <p class="si-story-p">Bold retro prints. Colourful 90s graphics. Heavyweight organic cotton that feels as good as it looks. Made for women who don't blend in — they stand out.</p>
    <div class="si-pills">
      <span class="si-pill">Retro Graphics</span>
      <span class="si-pill">Women's Fit</span>
      <span class="si-pill">Organic Cotton</span>
      <span class="si-pill">UK Printed</span>
      <span class="si-pill">Camden Born</span>
    </div>
  </div>
</section>

<!-- ============================================================
     PRODUCTS
     ============================================================ -->
<section class="si-shop hand-sec" id="si-shop">
  <div class="hand-container">
    <div class="si-shop-head">
      <div>
        <div class="si-eyebrow"><span class="si-eye-dot"></span>The Collection</div>
        <h2 class="si-shop-h2">All Products.</h2>
      </div>
      <p class="si-shop-sub">Every piece from Sista — colourful retro graphic tees on 220gsm organic cotton, UK printed.</p>
    </div>

    <div class="hand-grid si-grid" id="si-product-grid">
      {%- for product in sista_col.products -%}
        <a class="hand-card si-card" href="{{ product.url }}">
          <div class="imgwrap">
            <span class="tag">{{ product.type | default: 'Sista' }}</span>
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="si-no-img">SISTA</div>
            {%- endif -%}
            <span class="quick">Quick Add →</span>
          </div>
          <div class="body">
            <div class="vendor">Sista</div>
            <div class="name">{{ product.title }}</div>
            <div class="row2">
              <div class="price">{{ product.price | money }}</div>
              {%- if product.compare_at_price > product.price -%}
                <span class="si-sale">SALE</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <div class="si-soon-wrap">
          <div class="si-soon">
            <span class="si-soon-star">★</span>
            <h3 class="si-soon-h3">Dropping Soon</h3>
            <p class="si-soon-p">Colourful retro graphic tees are being prepared for the next drop. Heavyweight organic cotton, UK printed, made for women.</p>
            <a href="/collections/all" class="si-soon-link">Browse All Products →</a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING CTA
     ============================================================ -->
<section class="si-closer">
  <div class="si-closer-shapes" aria-hidden="true">
    <div class="si-cs si-cs1"></div>
    <div class="si-cs si-cs2"></div>
    <div class="si-cs si-cs3"></div>
  </div>
  <div class="si-closer-inner">
    <div class="si-eyebrow" style="justify-content:center"><span class="si-eye-dot"></span>Camden Born · UK Made</div>
    <h2 class="si-closer-h2">Own the<br><em>room.</em></h2>
    <p class="si-closer-p">Sista. Colourful retro 90s graphic tees, made for women. Heavyweight organic cotton, UK printed, Camden born.</p>
    <a class="si-cta-main" href="#si-shop" style="margin:0 auto">
      Shop Sista
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
:root{
  --si-pink:#F59DBA;--si-hot:#e84393;--si-purple:#a855f7;
  --si-orange:#ff6b35;--si-yellow:#ffc832;--si-mint:#00d2d3;
  --si-dark:#0a0a0a;--si-cream:#fdf6f0;
}

/* ═══════ HERO ═══════ */
.si-hero{position:relative;min-height:100vh;background:linear-gradient(135deg,#1a0a1a 0%,#0f0515 40%,#0a0a14 100%);display:flex;align-items:center;overflow:hidden;padding:0 clamp(24px,5vw,80px)}

/* Geometric shapes */
.si-shape{position:absolute;border-radius:50%;pointer-events:none;filter:blur(60px);mix-blend-mode:screen}
.si-sh1{width:400px;height:400px;background:radial-gradient(circle,rgba(232,67,147,.15),transparent 70%);top:-10%;right:10%;animation:si-float 16s ease-in-out infinite}
.si-sh2{width:300px;height:300px;background:radial-gradient(circle,rgba(168,85,247,.12),transparent 70%);bottom:10%;left:-5%;animation:si-float 20s ease-in-out infinite reverse}
.si-sh3{width:250px;height:250px;background:radial-gradient(circle,rgba(255,107,53,.1),transparent 70%);top:40%;right:-5%;animation:si-float 14s ease-in-out infinite;animation-delay:-4s}
.si-sh4{width:200px;height:200px;background:radial-gradient(circle,rgba(255,200,50,.08),transparent 70%);bottom:30%;left:30%;animation:si-float 18s ease-in-out infinite;animation-delay:-8s;border-radius:30%}
.si-sh5{width:150px;height:150px;background:radial-gradient(circle,rgba(0,210,211,.08),transparent 70%);top:20%;left:15%;animation:si-float 12s ease-in-out infinite;animation-delay:-2s}
@keyframes si-float{
  0%,100%{transform:translate(0,0) scale(1) rotate(0deg)}
  33%{transform:translate(30px,-25px) scale(1.1) rotate(5deg)}
  66%{transform:translate(-20px,20px) scale(.92) rotate(-3deg)}
}

/* Confetti dots */
.si-confetti{position:absolute;inset:0;pointer-events:none}
.si-dot{position:absolute;border-radius:50%;animation:si-drift 8s ease-in-out infinite}
.si-d1{width:8px;height:8px;background:var(--si-pink);top:15%;left:20%;animation-delay:0s}
.si-d2{width:6px;height:6px;background:var(--si-yellow);top:25%;right:25%;animation-delay:1s;border-radius:2px}
.si-d3{width:10px;height:10px;background:var(--si-purple);top:60%;left:10%;animation-delay:2s}
.si-d4{width:5px;height:5px;background:var(--si-orange);top:70%;right:15%;animation-delay:.5s;border-radius:0}
.si-d5{width:7px;height:7px;background:var(--si-mint);top:35%;left:45%;animation-delay:1.5s}
.si-d6{width:6px;height:6px;background:var(--si-hot);bottom:20%;left:35%;animation-delay:3s;border-radius:2px}
.si-d7{width:9px;height:9px;background:var(--si-yellow);top:10%;left:60%;animation-delay:2.5s}
.si-d8{width:5px;height:5px;background:var(--si-pink);bottom:35%;right:30%;animation-delay:4s;border-radius:0}
.si-d9{width:7px;height:7px;background:var(--si-purple);top:80%;left:55%;animation-delay:1.2s}
.si-d10{width:6px;height:6px;background:var(--si-orange);top:45%;right:8%;animation-delay:3.5s;border-radius:2px}
.si-d11{width:8px;height:8px;background:var(--si-mint);bottom:15%;right:45%;animation-delay:.8s}
.si-d12{width:4px;height:4px;background:var(--si-hot);top:50%;left:70%;animation-delay:2.8s}
@keyframes si-drift{
  0%,100%{transform:translateY(0) rotate(0deg);opacity:.6}
  50%{transform:translateY(-30px) rotate(180deg);opacity:1}
}

/* Squiggles */
.si-squiggle{position:absolute;width:clamp(100px,12vw,180px);pointer-events:none;opacity:.4}
.si-sq1{top:18%;right:12%;transform:rotate(-15deg)}
.si-sq2{bottom:22%;left:8%;transform:rotate(10deg)}

/* Hero content */
.si-hero-inner{position:relative;z-index:2;max-width:860px;width:100%}
.si-hero-meta{display:flex;align-items:center;gap:14px;margin-bottom:40px}
.si-badge-90s{background:linear-gradient(135deg,var(--si-hot),var(--si-purple));color:#fff;font-family:var(--display);font-size:14px;font-weight:900;padding:6px 12px;letter-spacing:.05em;border-radius:4px}
.si-meta-text{font-family:var(--mono);font-size:11px;letter-spacing:.25em;text-transform:uppercase;color:rgba(245,157,186,.6)}

.si-hero-title{margin:0 0 32px}
.si-title-row{display:block;font-family:var(--display);font-weight:900;text-transform:uppercase;line-height:.88}
.si-tr1{font-size:clamp(72px,14vw,200px);letter-spacing:-.04em;background:linear-gradient(135deg,var(--si-pink),var(--si-hot),var(--si-purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.si-tr2{font-size:clamp(28px,4.5vw,60px);color:rgba(255,255,255,.5);letter-spacing:.02em;margin:8px 0}
.si-tr2 em{font-style:italic;background:linear-gradient(90deg,var(--si-orange),var(--si-yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.si-tr3{font-size:clamp(56px,11vw,150px);letter-spacing:-.03em;color:#fff}

.si-hero-desc{font-size:17px;line-height:1.7;color:rgba(255,255,255,.55);max-width:480px;margin:0 0 40px}

.si-hero-cta-row{display:flex;align-items:center;gap:40px;flex-wrap:wrap}
.si-cta-main{display:inline-flex;align-items:center;gap:10px;background:linear-gradient(135deg,var(--si-hot),var(--si-purple));color:#fff;font-family:var(--mono);font-size:12px;letter-spacing:.18em;text-transform:uppercase;text-decoration:none;padding:18px 32px;font-weight:700;transition:transform .3s,box-shadow .3s;border-radius:4px}
.si-cta-main:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(232,67,147,.35)}
.si-cta-main svg{transition:transform .3s}.si-cta-main:hover svg{transform:translateX(4px)}

.si-hero-stats{display:flex;align-items:center;gap:20px}
.si-hs{display:flex;flex-direction:column;gap:2px}
.si-hs-n{font-family:var(--display);font-size:26px;font-weight:900;color:#fff;line-height:1}
.si-hs-l{font-family:var(--mono);font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25)}
.si-hs-div{width:1px;height:32px;background:rgba(255,255,255,.08)}

.si-scroll-cue{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:10px}
.si-scroll-cue span{font-family:var(--mono);font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.2)}
.si-scroll-bar{width:1px;height:40px;background:linear-gradient(to bottom,var(--si-pink),transparent);animation:si-sb 2s ease infinite}
@keyframes si-sb{0%,100%{opacity:.3;transform:scaleY(1)}50%{opacity:1;transform:scaleY(1.2)}}

/* ═══════ MARQUEE ═══════ */
.si-marquee{background:linear-gradient(90deg,var(--si-hot),var(--si-purple),var(--si-orange));padding:18px 0;overflow:hidden}
.si-mq-track{display:flex;gap:0;animation:si-mq 22s linear infinite;width:max-content}
.si-mq-w{font-family:var(--display);font-size:clamp(16px,2.2vw,24px);font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:#fff;padding:0 20px;white-space:nowrap}
.si-mq-outline{-webkit-text-stroke:1.5px #fff;color:transparent;-webkit-text-fill-color:transparent}
.si-mq-star{color:rgba(255,255,255,.4);font-size:12px;padding:0 8px}
@keyframes si-mq{to{transform:translateX(-50%)}}

/* ═══════ STORY ═══════ */
.si-story{display:grid;grid-template-columns:1fr 1.3fr;min-height:600px;background:var(--si-dark)}
@media(max-width:900px){.si-story{grid-template-columns:1fr;min-height:auto}}

.si-story-lhs{background:linear-gradient(135deg,#120818,#0a0510);display:flex;align-items:center;justify-content:center;padding:80px 40px;position:relative;overflow:hidden;border-right:1px solid rgba(232,67,147,.1)}
.si-story-badge-wrap{position:relative;width:180px;height:180px;display:flex;align-items:center;justify-content:center}
.si-story-badge{width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--si-hot),var(--si-purple));display:flex;align-items:center;justify-content:center;position:relative;z-index:1}
.si-sb-text{font-family:var(--display);font-size:64px;font-weight:900;color:#fff}
.si-retro-ring{position:absolute;border-radius:50%;left:50%;top:50%;transform:translate(-50%,-50%);border:2px dashed}
.si-rr1{width:160px;height:160px;border-color:rgba(245,157,186,.15);animation:si-rspin 20s linear infinite}
.si-rr2{width:200px;height:200px;border-color:rgba(168,85,247,.1);animation:si-rspin 30s linear infinite reverse}
@keyframes si-rspin{to{transform:translate(-50%,-50%) rotate(360deg)}}

.si-story-floats{position:absolute;inset:0;pointer-events:none}
.si-float-word{position:absolute;font-family:var(--display);font-weight:900;text-transform:uppercase;opacity:.06;user-select:none}
.si-fw1{font-size:clamp(48px,7vw,90px);top:8%;left:-5%;color:var(--si-orange);transform:rotate(-10deg)}
.si-fw2{font-size:clamp(36px,5vw,70px);bottom:12%;right:-5%;color:var(--si-yellow);transform:rotate(8deg)}
.si-fw3{font-size:clamp(40px,6vw,80px);top:55%;left:55%;color:var(--si-pink);transform:rotate(-5deg)}

.si-story-rhs{padding:clamp(48px,8vw,100px) clamp(32px,5vw,80px);display:flex;flex-direction:column;justify-content:center;gap:28px}
.si-eyebrow{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--si-pink)}
.si-eye-dot{width:6px;height:6px;border-radius:50%;background:var(--si-hot);animation:si-pulse 2s ease infinite}
@keyframes si-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}

.si-story-h2{font-family:var(--display);font-size:clamp(36px,5.5vw,72px);font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:.95;color:#fff;margin:0}
.si-story-h2 span{display:block}
.si-h2-pop{background:linear-gradient(90deg,var(--si-hot),var(--si-orange),var(--si-yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

.si-story-p{font-size:16px;line-height:1.8;color:rgba(255,255,255,.45);margin:0;max-width:500px}

.si-pills{display:flex;flex-wrap:wrap;gap:8px}
.si-pill{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;padding:8px 16px;border:1px solid rgba(232,67,147,.15);color:rgba(245,157,186,.6);transition:all .3s;border-radius:20px}
.si-pill:hover{border-color:var(--si-hot);color:var(--si-hot);background:rgba(232,67,147,.05)}

/* ═══════ SHOP ═══════ */
.si-shop{background:var(--paper)}
.si-shop-head{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start;margin-bottom:48px}
@media(max-width:768px){.si-shop-head{grid-template-columns:1fr}}
.si-shop-h2{font-family:var(--display);font-size:clamp(40px,7vw,80px);font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:.92;margin:12px 0 0}
.si-shop-sub{font-size:15px;line-height:1.7;color:rgba(255,255,255,.4)}

.si-no-img{width:100%;height:340px;background:linear-gradient(135deg,#1a0a1a,#0f0515);display:flex;align-items:center;justify-content:center;font-family:var(--display);font-size:36px;font-weight:900;background:linear-gradient(135deg,var(--si-hot),var(--si-purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.si-sale{font-family:var(--mono);font-size:9px;letter-spacing:.15em;background:linear-gradient(135deg,var(--si-hot),var(--si-purple));color:#fff;padding:3px 8px;font-weight:700;border-radius:2px}
.si-card{transition:transform .4s cubic-bezier(.22,1,.36,1),box-shadow .4s}
.si-card:hover{transform:translateY(-8px) scale(1.01);box-shadow:0 24px 60px rgba(232,67,147,.12)}

/* Coming soon */
.si-soon-wrap{grid-column:1/-1;display:flex;justify-content:center;padding:80px 0}
.si-soon{text-align:center;max-width:520px;padding:64px 48px;background:rgba(232,67,147,.03);border:1px solid rgba(232,67,147,.12);border-radius:8px;position:relative}
.si-soon-star{font-size:48px;display:block;margin-bottom:20px;background:linear-gradient(135deg,var(--si-hot),var(--si-yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:si-rspin 10s linear infinite;display:inline-block}
.si-soon-h3{font-family:var(--display);font-size:32px;font-weight:900;text-transform:uppercase;background:linear-gradient(135deg,var(--si-hot),var(--si-purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin:0 0 16px}
.si-soon-p{font-size:15px;line-height:1.7;color:rgba(255,255,255,.4);margin:0 0 32px}
.si-soon-link{font-family:var(--mono);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--si-hot);text-decoration:none;border-bottom:1px solid rgba(232,67,147,.2);padding-bottom:4px;transition:border-color .2s}
.si-soon-link:hover{border-color:var(--si-hot)}

/* ═══════ CLOSER ═══════ */
.si-closer{position:relative;padding:clamp(80px,12vw,160px) clamp(24px,5vw,80px);background:linear-gradient(135deg,#1a0a1a,#0f0515,#0a0a14);overflow:hidden;text-align:center}
.si-closer-shapes{position:absolute;inset:0;pointer-events:none}
.si-cs{position:absolute;border-radius:50%;filter:blur(80px);mix-blend-mode:screen}
.si-cs1{width:300px;height:300px;background:radial-gradient(circle,rgba(232,67,147,.1),transparent 70%);top:10%;left:20%}
.si-cs2{width:250px;height:250px;background:radial-gradient(circle,rgba(168,85,247,.08),transparent 70%);bottom:10%;right:15%}
.si-cs3{width:200px;height:200px;background:radial-gradient(circle,rgba(255,200,50,.06),transparent 70%);top:50%;left:60%}

.si-closer-inner{position:relative;z-index:1;max-width:650px;margin:0 auto}
.si-closer-h2{font-family:var(--display);font-size:clamp(48px,9vw,120px);font-weight:900;text-transform:uppercase;letter-spacing:-.04em;line-height:.88;color:#fff;margin:24px 0}
.si-closer-h2 em{font-style:italic;background:linear-gradient(135deg,var(--si-hot),var(--si-orange),var(--si-yellow));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.si-closer-p{font-size:17px;line-height:1.7;color:rgba(255,255,255,.4);margin:0 0 40px}

/* ═══════ RESPONSIVE ═══════ */
@media(max-width:640px){
  .si-hero-cta-row{flex-direction:column;align-items:flex-start;gap:24px}
  .si-story-lhs{padding:48px 24px;min-height:280px}
}
</style>

<!-- ============================================================
     MOTION.DEV ANIMATIONS
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded',function(){
  if(!window.Motion)return;
  var M=window.Motion,animate=M.animate,stagger=M.stagger,inView=M.inView;

  // Hero entrance — cinematic staggered reveal
  animate('.si-badge-90s',{opacity:[0,1],scale:[.5,1],rotate:[-10,0]},{duration:.6,delay:.2,easing:[.22,1,.36,1]});
  animate('.si-meta-text',{opacity:[0,1],x:[-20,0]},{duration:.5,delay:.3});

  animate('.si-tr1',{opacity:[0,1],y:[100,0],skewY:[6,0]},{duration:1.1,delay:.4,easing:[.22,1,.36,1]});
  animate('.si-tr2',{opacity:[0,1],y:[60,0]},{duration:.8,delay:.7,easing:[.22,1,.36,1]});
  animate('.si-tr3',{opacity:[0,1],y:[100,0],skewY:[-5,0]},{duration:1.1,delay:.9,easing:[.22,1,.36,1]});

  animate('.si-hero-desc',{opacity:[0,1],y:[30,0]},{duration:.7,delay:1.2});
  animate('.si-cta-main',{opacity:[0,1],y:[20,0],scale:[.9,1]},{duration:.6,delay:1.4,easing:[.22,1,.36,1]});
  animate('.si-hero-stats',{opacity:[0,1],x:[30,0]},{duration:.6,delay:1.5});
  animate('.si-scroll-cue',{opacity:[0,1]},{duration:.5,delay:1.8});

  // Shapes entrance
  animate('.si-shape',{opacity:[0,1],scale:[.3,1]},{delay:stagger(.15,{start:.3}),duration:1.5,easing:'ease-out'});

  // Confetti entrance
  animate('.si-dot',{opacity:[0,.6],scale:[0,1]},{delay:stagger(.08,{start:.6}),duration:.8,easing:[.22,1,.36,1]});

  // Story section
  inView('.si-story-badge-wrap',function(info){
    animate(info.target.querySelector('.si-story-badge'),{opacity:[0,1],scale:[.4,1],rotate:[-20,0]},{duration:1,easing:[.22,1,.36,1]});
    animate(info.target.querySelectorAll('.si-retro-ring'),{opacity:[0,1],scale:[.5,1]},{delay:stagger(.15,{start:.3}),duration:.8});
  },{margin:'-15% 0px'});

  inView('.si-story-rhs',function(info){
    var els=info.target.querySelectorAll('.si-eyebrow,.si-story-h2 span,.si-story-p,.si-pills');
    animate(els,{opacity:[0,1],y:[40,0]},{delay:stagger(.08),duration:.7,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Pills stagger
  inView('.si-pills',function(info){
    animate(info.target.querySelectorAll('.si-pill'),{opacity:[0,1],y:[15,0],scale:[.9,1]},{delay:stagger(.05),duration:.5,easing:[.22,1,.36,1]});
  },{margin:'-5% 0px'});

  // Product cards
  inView('.si-card',function(info){
    animate(info.target,{opacity:[0,1],y:[50,0]},{duration:.7,easing:[.22,1,.36,1]});
  },{margin:'-5% 0px'});

  // Coming soon
  inView('.si-soon',function(info){
    animate(info.target,{opacity:[0,1],y:[40,0],scale:[.95,1]},{duration:.9,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Shop header
  inView('.si-shop-head',function(info){
    animate(info.target.querySelectorAll('.si-eyebrow,.si-shop-h2,.si-shop-sub'),{opacity:[0,1],y:[50,0]},{delay:stagger(.1),duration:.8,easing:[.22,1,.36,1]});
  },{margin:'-10% 0px'});

  // Closer
  inView('.si-closer-inner',function(info){
    animate(info.target.querySelector('.si-eyebrow'),{opacity:[0,1]},{duration:.5});
    animate(info.target.querySelector('.si-closer-h2'),{opacity:[0,1],y:[80,0],skewY:[3,0]},{duration:1,delay:.2,easing:[.22,1,.36,1]});
    animate(info.target.querySelector('.si-closer-p'),{opacity:[0,1],y:[30,0]},{duration:.7,delay:.5});
    animate(info.target.querySelector('.si-cta-main'),{opacity:[0,1],y:[20,0]},{duration:.6,delay:.7});
  },{margin:'-15% 0px'});
});
</script>

{% schema %}
{
  "name": "Brand: Sista",
  "settings": [
    { "type": "textarea", "id": "story_text", "label": "Brand story text", "default": "Colourful retro 90s graphic tees, made for women. Camden born, UK printed." }
  ],
  "presets": [{ "name": "Brand: Sista" }]
}
{% endschema %}
