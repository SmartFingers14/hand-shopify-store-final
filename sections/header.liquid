  .hd-topbar-right { display: none; }
  .hd-topbar-inner { grid-template-columns: 1fr; }
  .hd-logo img { height: 44px; max-height: 44px; }
  .hd-cart-btn { padding: 8px 14px; font-size: 9px; }
