<!-- HAVE A NICE DAY LONDON — Immersive Mega-Menu Header -->
<style>
/* ================================================================
   DESIGN TOKENS
   ================================================================ */
:root {
  --hd-ink: #0a0a0a;
  --hd-cream: #f4f1ea;
  --hd-pink: #F59DBA;
  --hd-hot: #E91E8C;
  --hd-gold: #e6b422;
  --hd-white: #fff;
  --hd-glass: rgba(244,241,234,.92);
  --hd-glass-blur: 20px;
  --hd-mono: 'JetBrains Mono', 'SF Mono', 'Courier New', monospace;
  --hd-display: 'Anton', 'Impact', sans-serif;
  --hd-body: 'Poppins', system-ui, sans-serif;
  --hd-ease: cubic-bezier(.22,1,.36,1);
  --hd-topbar-h: 36px;
  --hd-nav-h: 72px;
}

/* ================================================================
   TOP ANNOUNCEMENT BAR
   ================================================================ */
.hd-topbar {
  background: var(--hd-ink);
  color: var(--hd-white);
  height: var(--hd-topbar-h);
  display: flex;
  align-items: center;
  position: relative;
  z-index: 100;
  overflow: hidden;
}
.hd-topbar-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 28px;
}
.hd-topbar-left {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.6);
}
.hd-pulse-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--hd-pink);
  box-shadow: 0 0 8px var(--hd-hot), 0 0 16px rgba(233,30,140,.3);
  animation: hd-pulse 2s ease-in-out infinite;
}
@keyframes hd-pulse {
  0%,100% { box-shadow: 0 0 6px var(--hd-hot), 0 0 12px rgba(233,30,140,.3); }
  50% { box-shadow: 0 0 12px var(--hd-hot), 0 0 24px rgba(233,30,140,.5); }
}
.hd-topbar-center {
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--hd-white);
  text-align: center;
  white-space: nowrap;
}
.hd-topbar-right {
  display: flex;
  align-items: center;
  gap: 14px;
  justify-content: flex-end;
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
}
.hd-topbar-right a {
  color: rgba(255,255,255,.6);
  text-decoration: none;
  transition: color .2s;
}
.hd-topbar-right a:hover { color: var(--hd-pink); }

/* ================================================================
   MAIN NAVIGATION — Glassmorphic sticky
   ================================================================ */
.hd-nav {
  position: sticky;
  top: 0;
  z-index: 90;
  background: var(--hd-glass);
  backdrop-filter: blur(var(--hd-glass-blur));
  -webkit-backdrop-filter: blur(var(--hd-glass-blur));
  border-bottom: 1px solid rgba(0,0,0,.06);
  transition: background .3s, box-shadow .3s, border-color .3s;
}
.hd-nav.scrolled {
  background: rgba(244,241,234,.97);
  box-shadow: 0 4px 30px rgba(0,0,0,.08);
  border-color: rgba(0,0,0,.08);
}
.hd-nav-inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  height: var(--hd-nav-h);
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
  gap: 32px;
}

/* ---- Logo ---- */
.hd-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  color: var(--hd-ink);
  flex-shrink: 0;
  transition: transform .2s var(--hd-ease);
}
.hd-logo:hover { transform: scale(1.02); }
.hd-logo img {
  display: block;
  width: auto;
  height: 52px;
  max-height: 52px;
  object-fit: contain;
}

/* ---- Center Nav Links ---- */
.hd-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
}
.hd-link-wrap {
  position: relative;
}
.hd-link {
  font-family: var(--hd-mono);
  text-transform: uppercase;
  font-size: 10px;
  letter-spacing: .18em;
  font-weight: 600;
  color: var(--hd-ink);
  padding: 26px 18px;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: color .2s;
  cursor: pointer;
  position: relative;
}
.hd-link::before {
  content: '';
  position: absolute;
  bottom: 18px;
  left: 18px;
  right: 18px;
  height: 2px;
  background: var(--hd-hot);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform .25s var(--hd-ease);
}
.hd-link:hover::before,
.hd-link-wrap:hover > .hd-link::before,
.hd-link.active::before { transform: scaleX(1); }
.hd-link:hover { color: var(--hd-hot); }
.hd-link-wrap:hover > .hd-link { color: var(--hd-hot); }

/* Dropdown chevron */
.hd-chev {
  width: 10px; height: 10px;
  transition: transform .3s var(--hd-ease);
}
.hd-link-wrap:hover .hd-chev { transform: rotate(180deg); }

/* ---- Right Actions ---- */
.hd-actions {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-shrink: 0;
}
.hd-act-btn {
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border: none; background: none;
  color: var(--hd-ink);
  cursor: pointer;
  border-radius: 50%;
  transition: background .2s, color .2s, transform .2s;
  position: relative;
}
.hd-act-btn:hover {
  background: rgba(0,0,0,.05);
  color: var(--hd-hot);
  transform: scale(1.08);
}
.hd-act-btn svg { width: 20px; height: 20px; }

/* Cart button — special */
.hd-cart-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--hd-ink);
  color: var(--hd-white);
  font-family: var(--hd-mono);
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  font-weight: 700;
  border: none;
  text-decoration: none;
  cursor: pointer;
  border-radius: 0;
  transition: all .25s var(--hd-ease);
  margin-left: 8px;
  position: relative;
  overflow: hidden;
}
.hd-cart-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--hd-hot), var(--hd-pink));
  transform: translateX(-100%);
  transition: transform .35s var(--hd-ease);
}
.hd-cart-btn:hover::before { transform: translateX(0); }
.hd-cart-btn span { position: relative; z-index: 1; }
.hd-cart-count {
  background: var(--hd-hot);
  color: var(--hd-white);
  font-size: 9px;
  font-weight: 800;
  width: 18px; height: 18px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative; z-index: 1;
  transition: transform .3s var(--hd-ease);
}
.hd-cart-btn:hover .hd-cart-count { transform: scale(1.15); background: var(--hd-white); color: var(--hd-hot); }

/* ---- Animated Hamburger ---- */
.hd-burger {
  display: none;
  width: 44px; height: 44px;
  align-items: center; justify-content: center;
  border: none; background: none;
  cursor: pointer; flex-shrink: 0;
  position: relative;
}
.hd-burger-lines {
  width: 22px; height: 16px;
  position: relative;
}
.hd-burger-lines span {
  position: absolute;
  left: 0;
  width: 100%;
  height: 2px;
  background: var(--hd-ink);
  border-radius: 1px;
  transition: all .3s var(--hd-ease);
}
.hd-burger-lines span:nth-child(1) { top: 0; }
.hd-burger-lines span:nth-child(2) { top: 7px; width: 70%; }
.hd-burger-lines span:nth-child(3) { top: 14px; }
.hd-burger.open .hd-burger-lines span:nth-child(1) { top: 7px; transform: rotate(45deg); }
.hd-burger.open .hd-burger-lines span:nth-child(2) { opacity: 0; transform: translateX(-10px); }
.hd-burger.open .hd-burger-lines span:nth-child(3) { top: 7px; transform: rotate(-45deg); }

/* ================================================================
   MEGA DROPDOWN — Brands
   ================================================================ */
.hd-mega {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 960px;
  background: var(--hd-white);
  box-shadow: 0 20px 60px rgba(0,0,0,.12), 0 0 0 1px rgba(0,0,0,.04);
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(8px);
  transition: opacity .25s var(--hd-ease), visibility .25s, transform .25s var(--hd-ease);
  pointer-events: none;
  z-index: 200;
  padding: 0;
  overflow: hidden;
}
.hd-link-wrap:hover .hd-mega {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
  pointer-events: auto;
}

/* Brands mega grid */
.hd-mega-brands {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.hd-brand-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36px 20px 28px;
  text-decoration: none;
  color: var(--hd-ink);
  position: relative;
  overflow: hidden;
  transition: all .3s var(--hd-ease);
  cursor: pointer;
  border-right: 1px solid rgba(0,0,0,.04);
}
.hd-brand-card:last-child { border-right: none; }

/* Brand card colored overlay on hover */
.hd-brand-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity .3s var(--hd-ease);
  z-index: 0;
}
.hd-brand-card[data-brand="dready"]::before { background: linear-gradient(135deg, #c62828, #e6b422, #2e7d32); }
.hd-brand-card[data-brand="sista"]::before { background: linear-gradient(135deg, #D4368C, #FFCE5C); }
.hd-brand-card[data-brand="handspun"]::before { background: linear-gradient(135deg, #0e0e24, #e8c547); }
.hd-brand-card[data-brand="funky-dog"]::before { background: linear-gradient(135deg, #ff6b00, #ffd000, #a3e635); }
.hd-brand-card[data-brand="btka"]::before { background: linear-gradient(135deg, #dc2626, #0a0a0a, #dc2626); }
.hd-brand-card[data-brand="vortex"]::before { background: linear-gradient(135deg, #1a0030, #7c3aed, #06b6d4); }
.hd-brand-card[data-brand="dodo"]::before { background: linear-gradient(135deg, #065f46, #34d399, #fbbf24); }
.hd-brand-card[data-brand="hand"]::before { background: linear-gradient(135deg, #F59DBA, #E91E8C, #ffd000); }
.hd-brand-card[data-brand="incubator"]::before { background: linear-gradient(135deg, #050505, #00FF88, #050505); }

.hd-brand-card:hover::before { opacity: 1; }
.hd-brand-card:hover { transform: scale(1); }
.hd-brand-card:hover * { position: relative; z-index: 1; }

/* Brand logo circle */
.hd-brand-logo {
  width: 72px; height: 72px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid rgba(0,0,0,.08);
  transition: all .3s var(--hd-ease);
  margin-bottom: 14px;
  box-shadow: 0 4px 16px rgba(0,0,0,.08);
}
.hd-brand-card:hover .hd-brand-logo {
  border-color: var(--hd-white);
  transform: scale(1.08);
  box-shadow: 0 8px 24px rgba(0,0,0,.2);
}

/* Fix specific logos that overflow circles */
.hd-brand-card[data-brand="dready"] .hd-brand-logo,
.hd-brand-card[data-brand="funky-dog"] .hd-brand-logo,
.hd-brand-card[data-brand="incubator"] .hd-brand-logo {
  object-fit: contain;
  padding: 6px;
  background: #fff;
}

.hd-brand-name {
  font-family: var(--hd-display);
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: 4px;
  transition: color .2s;
}
.hd-brand-card:hover .hd-brand-name { color: var(--hd-white); }

.hd-brand-tagline {
  font-family: var(--hd-mono);
  font-size: 8px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: rgba(0,0,0,.35);
  transition: color .2s;
  text-align: center;
}
.hd-brand-card:hover .hd-brand-tagline { color: rgba(255,255,255,.7); }

/* Mega footer strip */
.hd-mega-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 28px;
  background: rgba(0,0,0,.02);
  border-top: 1px solid rgba(0,0,0,.06);
}
.hd-mega-foot-text {
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: rgba(0,0,0,.3);
}
.hd-mega-foot-link {
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--hd-hot);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: gap .2s var(--hd-ease);
}
.hd-mega-foot-link:hover { gap: 10px; }

/* ================================================================
   MEGA DROPDOWN — Shop
   ================================================================ */
.hd-mega-shop {
  width: 680px;
  padding: 28px;
}
.hd-mega-shop-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.hd-shop-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  padding: 24px 16px;
  text-decoration: none;
  color: var(--hd-ink);
  border: 1px solid rgba(0,0,0,.06);
  transition: all .25s var(--hd-ease);
  cursor: pointer;
}
.hd-shop-card:hover {
  border-color: var(--hd-hot);
  box-shadow: 0 8px 24px rgba(233,30,140,.1);
  transform: translateY(-3px);
}
.hd-shop-card svg {
  width: 28px; height: 28px;
  color: rgba(0,0,0,.3);
  transition: color .2s;
}
.hd-shop-card:hover svg { color: var(--hd-hot); }
.hd-shop-card-label {
  font-family: var(--hd-mono);
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 600;
}
.hd-shop-card-count {
  font-family: var(--hd-mono);
  font-size: 8px;
  letter-spacing: .1em;
  color: rgba(0,0,0,.3);
}

/* ================================================================
   SEARCH OVERLAY — Full-screen immersive
   ================================================================ */
.hd-search-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,10,10,.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  z-index: 700;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 15vh;
  opacity: 0;
  pointer-events: none;
  transition: opacity .3s var(--hd-ease);
}
.hd-search-overlay.open {
  opacity: 1;
  pointer-events: all;
}
.hd-search-inner {
  width: 100%;
  max-width: 640px;
  padding: 0 24px;
  transform: translateY(20px);
  transition: transform .35s var(--hd-ease);
}
.hd-search-overlay.open .hd-search-inner { transform: translateY(0); }

.hd-search-label {
  font-family: var(--hd-mono);
  font-size: 10px;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  margin-bottom: 16px;
}
.hd-search-form {
  display: flex;
  align-items: center;
  border-bottom: 2px solid rgba(255,255,255,.15);
  padding-bottom: 8px;
  transition: border-color .2s;
}
.hd-search-form:focus-within { border-color: var(--hd-pink); }
.hd-search-input {
  flex: 1;
  border: none; outline: none;
  background: transparent;
  color: var(--hd-white);
  font-family: var(--hd-display);
  font-size: clamp(28px, 5vw, 48px);
  letter-spacing: .02em;
  padding: 8px 0;
}
.hd-search-input::placeholder {
  color: rgba(255,255,255,.15);
}
.hd-search-submit {
  background: none; border: none;
  color: rgba(255,255,255,.3);
  cursor: pointer;
  padding: 8px;
  transition: color .2s, transform .2s;
}
.hd-search-submit:hover { color: var(--hd-pink); transform: scale(1.1); }
.hd-search-submit svg { width: 28px; height: 28px; }

.hd-search-hint {
  margin-top: 20px;
  font-family: var(--hd-mono);
  font-size: 10px;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
}
.hd-search-hint a {
  color: var(--hd-pink);
  text-decoration: none;
  transition: color .2s;
}
.hd-search-hint a:hover { color: var(--hd-white); }

.hd-search-close {
  position: absolute;
  top: 32px; right: 32px;
  width: 48px; height: 48px;
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 50%;
  background: none;
  color: rgba(255,255,255,.4);
  font-size: 18px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all .25s var(--hd-ease);
}
.hd-search-close:hover {
  background: var(--hd-pink);
  border-color: var(--hd-pink);
  color: var(--hd-white);
  transform: rotate(90deg);
}

/* ================================================================
   MOBILE MENU — Full-screen immersive
   ================================================================ */
.hd-mob-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 499;
  opacity: 0;
  pointer-events: none;
  transition: opacity .3s;
}
.hd-mob-overlay.open { opacity: 1; pointer-events: all; }

.hd-mob {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: min(380px, 90vw);
  background: var(--hd-ink);
  z-index: 500;
  transform: translateX(100%);
  transition: transform .45s var(--hd-ease);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.hd-mob.open { transform: translateX(0); }

/* Mobile menu header */
.hd-mob-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.hd-mob-logo {
  font-family: var(--hd-display);
  font-size: 16px;
  text-transform: uppercase;
  color: var(--hd-white);
  letter-spacing: .04em;
}
.hd-mob-close {
  width: 40px; height: 40px;
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 50%;
  background: none; color: var(--hd-white);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all .2s;
}
.hd-mob-close:hover { background: var(--hd-pink); border-color: var(--hd-pink); }

/* Mobile nav links */
.hd-mob-body {
  flex: 1; overflow-y: auto;
  padding: 16px 0;
}
.hd-mob-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 24px;
  font-family: var(--hd-display);
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--hd-white);
  text-decoration: none;
  transition: all .2s var(--hd-ease);
  border-bottom: 1px solid rgba(255,255,255,.04);
  position: relative;
  overflow: hidden;
}
.hd-mob-link::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--hd-pink);
  transform: scaleY(0);
  transition: transform .2s var(--hd-ease);
}
.hd-mob-link:hover::before { transform: scaleY(1); }
.hd-mob-link:hover {
  padding-left: 32px;
  color: var(--hd-pink);
  background: rgba(255,255,255,.02);
}
.hd-mob-arr {
  font-size: 16px;
  opacity: .3;
  transition: opacity .2s, transform .2s;
}
.hd-mob-link:hover .hd-mob-arr { opacity: 1; transform: translateX(4px); }

/* Mobile brands section */
.hd-mob-section-title {
  padding: 24px 24px 10px;
  font-family: var(--hd-mono);
  font-size: 9px;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
}
.hd-mob-brands {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 0 24px 20px;
}
.hd-mob-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border: 1px solid rgba(255,255,255,.06);
  text-decoration: none;
  color: var(--hd-white);
  transition: all .2s var(--hd-ease);
  cursor: pointer;
}
.hd-mob-brand:hover {
  border-color: var(--hd-pink);
  background: rgba(255,255,255,.04);
}
.hd-mob-brand img {
  width: 36px; height: 36px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255,255,255,.1);
  flex-shrink: 0;
}

/* Fix logos that overflow circles in mobile menu */
.hd-mob-brand[data-brand="dready"] img,
.hd-mob-brand[data-brand="btka"] img,
.hd-mob-brand[data-brand="incubator"] img,
.hd-mob-brand[data-brand="funky-dog"] img,
.hd-mob-brand[data-brand="dodo"] img,
.hd-mob-brand[data-brand="vortex"] img {
  object-fit: contain;
  padding: 4px;
  background: #fff;
}
.hd-mob-brand-name {
  font-family: var(--hd-display);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: .06em;
}

/* Mobile footer actions */
.hd-mob-foot {
  padding: 16px 24px;
  border-top: 1px solid rgba(255,255,255,.06);
  display: flex;
  gap: 10px;
}
.hd-mob-foot-btn {
  flex: 1;
  padding: 14px;
