  .hd-burger { display: flex; }
  .hd-nav-inner { grid-template-columns: auto 1fr auto; }
  .hd-actions { grid-column: 3; justify-self: end; }
  .hd-cart-btn { margin-left: 0; }
}
@media (max-width: 600px) {
