<section style="background:#FFD400;color:#000;padding:90px 24px;border-bottom:6px solid #000;text-align:center">
  <div style="max-width:780px;margin:0 auto">
    <p style="font-family:'Bungee',sans-serif;font-size:11px;letter-spacing:.22em;text-transform:uppercase">{{ section.settings.eyebrow }}</p>
    <h2 style="font-family:'Fjalla One',sans-serif;font-size:clamp(40px,7vw,84px);text-transform:uppercase;line-height:.95;margin:14px 0 18px">
      {{ section.settings.heading_pre }}
      <span style="background:#000;color:#FFD400;padding:0 14px">{{ section.settings.heading_em }}</span>
      ☻
    </h2>
    <p style="font-size:17px;max-width:560px;margin:0 auto 32px">{{ section.settings.body }}</p>

    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div style="display:flex;gap:8px;background:#000;border-radius:99px;padding:6px;flex-wrap:wrap;max-width:560px;margin:0 auto">
        <input type="email" name="contact[email]" required placeholder="your@email.com" autocomplete="email" style="flex:1;min-width:200px;background:transparent;border:0;padding:14px 22px;color:#FFD400;font-size:15px;outline:none;font-family:inherit">
        <button type="submit" name="commit" style="background:#FFD400;color:#000;padding:14px 26px;border-radius:99px;font-family:'Bungee',sans-serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase;border:0;cursor:pointer">{{ section.settings.cta }} →</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="margin-top:18px;font-family:'Bungee',sans-serif;font-size:13px;letter-spacing:.16em;text-transform:uppercase">☻ You're on the list. Check your inbox.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p style="margin-top:18px;font-size:13px">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {% endform %}

    <p style="font-family:'Permanent Marker',cursive;font-size:24px;margin-top:24px">{{ section.settings.signoff }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Home newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the family" },
    { "type": "text", "id": "heading_pre", "label": "Heading start", "default": "Don't miss the next" },
    { "type": "text", "id": "heading_em", "label": "Highlight", "default": "drop" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Early access to drops, secret colourways, and a hand-drawn smiley sticker with your first order." },
    { "type": "text", "id": "cta", "label": "Button label", "default": "Get 10% Off" },
    { "type": "text", "id": "signoff", "label": "Signoff", "default": "have a nice day ☻" }
  ],
  "presets": [ { "name": "Home newsletter" } ]
}
{% endschema %}
