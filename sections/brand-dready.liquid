{% comment %}
  Brand Page: Dready OG — Immersive Music-Culture Experience
  Roots · Culture · Peace — Camden 1990
{% endcomment %}

{%- assign brand_col = collections['dready'] -%}
{%- if brand_col == blank or brand_col.products_count == 0 -%}
  {%- assign brand_col = collections['dready-1'] -%}
{%- endif -%}
{%- if brand_col == blank or brand_col.products_count == 0 -%}
  {%- assign brand_col = collections['dready-og'] -%}
{%- endif -%}
{%- if brand_col == blank or brand_col.products_count == 0 -%}
  {%- assign brand_col = collections['all'] -%}
{%- endif -%}

<!-- ============================================================
     HERO — Full-bleed immersive with speaker cone + equalizer
     ============================================================ -->
<section class="dr-hero">
  <!-- Animated equalizer bars background -->
  <div class="dr-eq-bg" aria-hidden="true">
    <div class="dr-eq-bar" style="--i:0"></div>
    <div class="dr-eq-bar" style="--i:1"></div>
    <div class="dr-eq-bar" style="--i:2"></div>
    <div class="dr-eq-bar" style="--i:3"></div>
    <div class="dr-eq-bar" style="--i:4"></div>
    <div class="dr-eq-bar" style="--i:5"></div>
    <div class="dr-eq-bar" style="--i:6"></div>
    <div class="dr-eq-bar" style="--i:7"></div>
    <div class="dr-eq-bar" style="--i:8"></div>
    <div class="dr-eq-bar" style="--i:9"></div>
    <div class="dr-eq-bar" style="--i:10"></div>
    <div class="dr-eq-bar" style="--i:11"></div>
    <div class="dr-eq-bar" style="--i:12"></div>
    <div class="dr-eq-bar" style="--i:13"></div>
    <div class="dr-eq-bar" style="--i:14"></div>
    <div class="dr-eq-bar" style="--i:15"></div>
  </div>

  <!-- Speaker cone — the hero centrepiece -->
  <div class="dr-speaker-wrap" aria-hidden="true">
    <div class="dr-speaker">
      <div class="dr-speaker-ring dr-speaker-ring-1"></div>
      <div class="dr-speaker-ring dr-speaker-ring-2"></div>
      <div class="dr-speaker-ring dr-speaker-ring-3"></div>
      <div class="dr-speaker-cone"></div>
      <div class="dr-speaker-dust-cap">
        <img src="{{ 'logo-dready-vinyl.png' | asset_url }}" alt="Dready OG" class="dr-speaker-logo" />
      </div>
    </div>
    <!-- Sound wave rings -->
    <div class="dr-sound-wave dr-sw1"></div>
    <div class="dr-sound-wave dr-sw2"></div>
    <div class="dr-sound-wave dr-sw3"></div>
  </div>

  <div class="dr-hero-content">
    <div class="dr-hero-tag">
      <span class="dr-tag-line"></span>
      <span>02 / Roots · Culture · Peace</span>
    </div>

    <h1 class="dr-hero-h1">
      <span class="dr-h1-word" data-word="DREADY OG">DREADY <span class="dr-h1-accent">OG</span></span>
    </h1>

    <p class="dr-hero-sub">Born on a Camden market stall in 1990.<br>Roots reggae, Rastafarian philosophy &amp; the underground sound of London — printed on heavyweight cotton.</p>

    <div class="dr-hero-cta-row">
      <a class="dr-cta-primary" href="#dr-shop">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Shop The Drop
      </a>
      <div class="dr-hero-stats">
        <div class="dr-stat"><span class="dr-stat-n">{{ brand_col.products_count | default: '69' }}</span><span class="dr-stat-l">Products</span></div>
        <div class="dr-stat-div"></div>
        <div class="dr-stat"><span class="dr-stat-n">1990</span><span class="dr-stat-l">Est.</span></div>
        <div class="dr-stat-div"></div>
        <div class="dr-stat"><span class="dr-stat-n">30+</span><span class="dr-stat-l">Years</span></div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="dr-scroll-hint" aria-hidden="true">
    <div class="dr-scroll-track"><div class="dr-scroll-thumb"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     WAVEFORM TICKER — Animated marquee
     ============================================================ -->
<div class="dr-ticker">
  <div class="dr-ticker-track">
    <div class="dr-ticker-inner">
      <span>ROOTS</span><span class="dr-ticker-dot">◆</span>
      <span>REGGAE</span><span class="dr-ticker-dot">◆</span>
      <span>CAMDEN 1990</span><span class="dr-ticker-dot">◆</span>
      <span>CULTURE</span><span class="dr-ticker-dot">◆</span>
      <span>DJ DREADY</span><span class="dr-ticker-dot">◆</span>
      <span>PEACE</span><span class="dr-ticker-dot">◆</span>
      <span>HEAVYWEIGHT COTTON</span><span class="dr-ticker-dot">◆</span>
      <span>UK PRINTED</span><span class="dr-ticker-dot">◆</span>
    </div>
    <div class="dr-ticker-inner" aria-hidden="true">
      <span>ROOTS</span><span class="dr-ticker-dot">◆</span>
      <span>REGGAE</span><span class="dr-ticker-dot">◆</span>
      <span>CAMDEN 1990</span><span class="dr-ticker-dot">◆</span>
      <span>CULTURE</span><span class="dr-ticker-dot">◆</span>
      <span>DJ DREADY</span><span class="dr-ticker-dot">◆</span>
      <span>PEACE</span><span class="dr-ticker-dot">◆</span>
      <span>HEAVYWEIGHT COTTON</span><span class="dr-ticker-dot">◆</span>
      <span>UK PRINTED</span><span class="dr-ticker-dot">◆</span>
    </div>
  </div>
</div>

<!-- ============================================================
     STORY — Split layout with sound system + narrative
     ============================================================ -->
<section class="dr-story">
  <div class="dr-story-visual-side">
    <!-- Rasta sound system stack -->
    <div class="dr-soundsys">
      <div class="dr-ss-stripe dr-ss-red"></div>
      <div class="dr-ss-stripe dr-ss-gold"></div>
      <div class="dr-ss-stripe dr-ss-green"></div>
      <div class="dr-ss-cab dr-ss-cab-1">
        <div class="dr-ss-grille">
          <div class="dr-ss-speaker-unit">
            <div class="dr-ss-cone"></div>
            <div class="dr-ss-dust">
              <img src="{{ 'logo-dready-vinyl.png' | asset_url }}" alt="Dready OG" class="dr-ss-logo" />
            </div>
          </div>
        </div>
      </div>
      <div class="dr-ss-cab dr-ss-cab-2">
        <div class="dr-ss-grille">
          <div class="dr-ss-mid"></div>
          <div class="dr-ss-mid"></div>
        </div>
      </div>
      <div class="dr-ss-cab dr-ss-cab-3">
        <div class="dr-ss-grille">
          <div class="dr-ss-tweet"></div>
          <div class="dr-ss-tweet"></div>
          <div class="dr-ss-tweet"></div>
          <div class="dr-ss-tweet"></div>
        </div>
      </div>
      <!-- Bass pulse rings -->
      <div class="dr-ss-pulse dr-ss-p1"></div>
      <div class="dr-ss-pulse dr-ss-p2"></div>
      <!-- Year stamp -->
      <div class="dr-ss-year">EST. 1990</div>
    </div>
  </div>
  <div class="dr-story-text-side">
    <div class="dr-story-eyebrow">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
      The Origin Story
    </div>
    <h2 class="dr-story-h2">Where the <em>dub plates</em><br>meet the cotton.</h2>
    <p class="dr-story-p">Established in 1983, DREADY is rooted in a blend of Jamaican and English subcultures.</p>
    <p class="dr-story-p">More than a brand, DREADY is a lifestyle that resonates with everyone — built on unity, creativity, and community.</p>
    <p class="dr-story-p">From the very beginning, DREADY has been about connection, bringing people together through style, sound, and shared culture.</p>
    <p class="dr-story-p">Every piece carries bold design, rich heritage, and good vibes made to last.</p>
    <p class="dr-story-p" style="font-style:italic;color:var(--dr-gold);">Feel the vibe. Wear the culture!</p>
    <div class="dr-story-tags">
      <span class="dr-stag">Roots Reggae</span>
      <span class="dr-stag">Camden Market</span>
      <span class="dr-stag">UK Made</span>
      <span class="dr-stag">Since 1990</span>
      <span class="dr-stag">Organic Cotton</span>
    </div>
  </div>
</section>

<!-- ============================================================
     CULTURE STRIP — Three pillars with icons
     ============================================================ -->
<section class="dr-culture">
  <div class="dr-culture-grid">
    <div class="dr-culture-card">
      <div class="dr-culture-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--dr-gold)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      </div>
      <h3>Since 1990</h3>
      <p>Over three decades of underground culture, printed on cotton in small UK batches.</p>
    </div>
    <div class="dr-culture-card dr-culture-card-accent">
      <div class="dr-culture-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--dr-dark)" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      </div>
      <h3>Roots & Reggae</h3>
      <p>Every print tells a story of music, identity and Rastafarian philosophy from the heart of London.</p>
    </div>
    <div class="dr-culture-card">
      <div class="dr-culture-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--dr-gold)" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h3>Roots · Culture · Peace</h3>
      <p>Built on authenticity, community and cultural pride. Not fast fashion — a movement.</p>
    </div>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Full grid with filters + equalizer header
     ============================================================ -->
<section class="dr-shop" id="dr-shop">
  <div class="dr-shop-inner">
    <div class="dr-shop-head">
        <div class="dr-shop-head-lhs">
        <div class="dr-shop-eyebrow">The Collection</div>
        <h2 class="dr-shop-h2">All Drops.</h2>
        <a class="dr-view-all" href="/collections/dready">View All &#8594;</a>
      </div>
      <div class="dr-shop-head-rhs">
        <p>Every piece from Dready OG — from classic 90s prints to the latest drops. All small-batch, UK production, heavyweight organic cotton.</p>
        <div class="dr-filters">
          <button class="dr-filter active" data-filter="all">All</button>
          <button class="dr-filter" data-filter="tee">Tees & Longsleeves</button>
          <button class="dr-filter" data-filter="hood">Hoodies & Sweats</button>
          <button class="dr-filter" data-filter="dj">DJ Dready</button>
          <button class="dr-filter" data-filter="other">Accessories</button>
        </div>
      </div>
    </div>

    <div class="dr-product-grid" id="dr-product-grid">
      {%- for product in brand_col.products -%}
        {%- assign filter_tag = 'other' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'dj dready' or tl contains 'dj ' -%}{%- assign filter_tag = 'dj' -%}
        {%- elsif tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}{%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' or tl contains 'longsleeve' or tl contains 'long sleeve' -%}{%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="dr-card" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="dr-card-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="dr-no-img">DREADY<br>OG</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="dr-sale-badge">SALE</span>
            {%- endif -%}
            <div class="dr-card-overlay">
              <span>View Product</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
          <div class="dr-card-body">
            <span class="dr-card-type">{{ product.type | default: 'Dready OG' }}</span>
            <div class="dr-card-title">{{ product.title }}</div>
            <div class="dr-card-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- else -%}
        <div class="dr-empty">No products yet — check back soon.</div>
      {%- endfor -%}
    </div>
    <!-- View All Products CTA -->
    <div style="text-align:center;padding:3rem 0 1.5rem">
      <a href="/collections/dready" style="display:inline-block;font-family:var(--dr-mono,var(--mono,'JetBrains Mono',monospace));font-size:.95rem;letter-spacing:.14em;text-transform:uppercase;color:var(--dr-white,#f5f5f0);background:transparent;border:2px solid var(--dr-gold,#e6b422);padding:1.1rem 3.5rem;text-decoration:none;transition:all .3s ease;border-radius:0" onmouseover="this.style.background='var(--dr-gold,#e6b422)';this.style.color='#0a0a0a'" onmouseout="this.style.background='transparent';this.style.color='var(--dr-white,#f5f5f0)'">VIEW ALL DREADY PRODUCTS →</a>
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING CTA — Speaker with call to action
     ============================================================ -->
<section class="dr-closing">
  <div class="dr-closing-eq" aria-hidden="true">
    <div class="dr-ceq" style="--i:0"></div>
    <div class="dr-ceq" style="--i:1"></div>
    <div class="dr-ceq" style="--i:2"></div>
    <div class="dr-ceq" style="--i:3"></div>
    <div class="dr-ceq" style="--i:4"></div>
    <div class="dr-ceq" style="--i:5"></div>
    <div class="dr-ceq" style="--i:6"></div>
    <div class="dr-ceq" style="--i:7"></div>
  </div>
  <div class="dr-closing-inner">
    <h2 class="dr-closing-h2">The bass never<br>stops dropping.</h2>
    <p>30+ years of underground culture. New drops, same roots, same heavyweight cotton.</p>
    <a class="dr-cta-primary" href="#dr-shop">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      Shop Dready OG
    </a>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
/* ---- TOKENS ---- */
:root {
  --dr-dark: #0a0a0a;
  --dr-deep: #111;
  --dr-green: #0d1f0d;
  --dr-lime: #e6b422;
  --dr-gold: #e6b422;
  --dr-red: #c62828;
  --dr-rasta-green: #2e7d32;
  --dr-white: #f5f5f0;
  --dr-grey: rgba(245,245,240,.45);
  --dr-rasta: linear-gradient(135deg, #c62828 0%, #e6b422 50%, #2e7d32 100%);
  --dr-rasta-h: linear-gradient(90deg, #c62828 0%, #e6b422 50%, #2e7d32 100%);
  --dr-font: 'Righteous', var(--display), sans-serif;
  --dr-body: 'Poppins', var(--body), sans-serif;
  --dr-mono: var(--mono), monospace;
}

/* ---- HERO ---- */
.dr-hero {
  position: relative;
  min-height: 100vh;
  min-height: 100dvh;
  background: var(--dr-dark);
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 120px 60px 80px;
}
@media(max-width:768px){.dr-hero{padding:100px 24px 60px;}}

/* Equalizer bars in background */
.dr-eq-bg {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  padding: 0 5%;
  pointer-events: none;
  opacity: .06;
}
.dr-eq-bar {
  width: 3%;
  background: var(--dr-lime);
  border-radius: 4px 4px 0 0;
  animation: dr-eq 1.8s ease-in-out infinite alternate;
  animation-delay: calc(var(--i) * .12s);
  transform-origin: bottom;
}
@keyframes dr-eq {
  0%   { height: 8%; }
  25%  { height: 45%; }
  50%  { height: 20%; }
  75%  { height: 65%; }
  100% { height: 15%; }
}

/* Speaker cone */
.dr-speaker-wrap {
  position: absolute;
  right: 5%;
  top: 50%;
  transform: translateY(-50%);
  width: clamp(280px, 40vw, 560px);
  aspect-ratio: 1;
  pointer-events: none;
}
@media(max-width:768px){.dr-speaker-wrap{width:180px;right:-30px;top:12%;opacity:.25;}}
@media(max-width:480px){.dr-speaker-wrap{width:140px;right:-20px;top:8%;opacity:.18;}}

.dr-speaker {
  width: 100%; height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle at 50%, #1e1e1e 0%, #151515 40%, #0d0d0d 100%);
  position: relative;
  box-shadow: 0 0 0 6px #2a2a2a, 0 0 0 10px #1a1a1a, 0 0 0 14px #111, 0 0 80px rgba(230,180,34,.15);
}
/* Rubber surround */
.dr-speaker-ring {
  position: absolute;
  border-radius: 50%;
}
.dr-speaker-ring-1 {
  inset: 3%;
  border: 3px solid #2a2a2a;
  background: radial-gradient(circle, transparent 85%, rgba(40,40,40,.6) 100%);
}
.dr-speaker-ring-2 {
  inset: 7%;
  border: 1px solid #333;
  background: repeating-radial-gradient(circle at 50%, transparent 0px, transparent 6px, rgba(255,255,255,.015) 6px, rgba(255,255,255,.015) 7px);
}
/* Cone */
.dr-speaker-ring-3 { display: none; }
.dr-speaker-cone {
  position: absolute;
  inset: 12%;
  border-radius: 50%;
  background: radial-gradient(circle at 42% 42%, #383838 0%, #252525 30%, #1a1a1a 60%, #111 100%);
  box-shadow: inset 0 2px 20px rgba(0,0,0,.6), inset 0 -2px 10px rgba(255,255,255,.03);
}
/* Dust cap — large with visible logo */
.dr-speaker-dust-cap {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 44%;
  height: 44%;
  border-radius: 50%;
  background: var(--dr-rasta);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 4%;
  animation: dr-pulse 2s ease-in-out infinite;
  box-shadow: 0 0 50px rgba(230,180,34,.45), inset 0 -3px 8px rgba(0,0,0,.12);
}
.dr-speaker-logo {
  width: 92%;
  height: 92%;
  object-fit: contain;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,.25));
}
@keyframes dr-pulse {
  0%, 100% { transform: translate(-50%,-50%) scale(1); box-shadow: 0 0 30px rgba(230,180,34,.3); }
  50%      { transform: translate(-50%,-50%) scale(1.06); box-shadow: 0 0 50px rgba(230,180,34,.5); }
}

/* Sound waves emanating from speaker */
.dr-sound-wave {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 1px solid var(--dr-lime);
  opacity: 0;
  animation: dr-wave 3s ease-out infinite;
  pointer-events: none;
}
.dr-sw1 { width: 110%; height: 110%; animation-delay: 0s; }
.dr-sw2 { width: 130%; height: 130%; animation-delay: 1s; }
.dr-sw3 { width: 150%; height: 150%; animation-delay: 2s; }
@keyframes dr-wave {
  0%   { opacity: .4; transform: translate(-50%,-50%) scale(.9); }
  100% { opacity: 0;  transform: translate(-50%,-50%) scale(1.3); }
}

/* Hero content */
.dr-hero-content {
  position: relative;
  z-index: 2;
  max-width: 640px;
}
.dr-hero-tag {
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--dr-mono);
  font-size: 12px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--dr-gold);
  margin-bottom: 28px;
}
.dr-tag-line { display: block; width: 32px; height: 2px; background: var(--dr-gold); }
.dr-hero-h1 {
  font-family: var(--dr-font);
  font-size: clamp(72px, 12vw, 160px);
  font-weight: 900;
  line-height: .85;
  letter-spacing: -.03em;
  text-transform: uppercase;
  color: var(--dr-white);
  margin: 0 0 28px;
}
.dr-h1-word { display: inline; }
.dr-h1-accent { background: var(--dr-rasta-h); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 30px rgba(230,180,34,.3)); }
.dr-hero-sub {
  font-family: var(--dr-body);
  font-size: 16px;
  line-height: 1.7;
  color: var(--dr-grey);
  margin: 0 0 36px;
  max-width: 420px;
}
.dr-hero-cta-row {
  display: flex;
  align-items: center;
  gap: 36px;
  flex-wrap: wrap;
}
.dr-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--dr-rasta-h);
  color: var(--dr-dark);
  font-family: var(--dr-mono);
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 28px;
  font-weight: 700;
  cursor: pointer;
  transition: background .25s, transform .25s, box-shadow .25s;
}
.dr-cta-primary:hover {
  background: var(--dr-gold);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(230,180,34,.3);
}
.dr-hero-stats { display: flex; align-items: center; gap: 20px; }
.dr-stat { display: flex; flex-direction: column; gap: 2px; }
.dr-stat-n { font-family: var(--dr-font); font-size: 28px; color: var(--dr-white); line-height: 1; }
.dr-stat-l { font-family: var(--dr-mono); font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: rgba(245,245,240,.3); }
.dr-stat-div { width: 1px; height: 32px; background: rgba(245,245,240,.1); }

/* Scroll hint */
.dr-scroll-hint {
  position: absolute;
  bottom: 30px; left: 60px;
  display: flex; align-items: center; gap: 12px;
  font-family: var(--dr-mono); font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: rgba(245,245,240,.2);
}
.dr-scroll-track { width: 40px; height: 1px; background: rgba(245,245,240,.12); position: relative; overflow: hidden; }
.dr-scroll-thumb { position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--dr-rasta-h); animation: dr-scr 2s ease infinite; }
@keyframes dr-scr { to { left: 100%; } }

/* ---- TICKER ---- */
.dr-ticker {
  background: var(--dr-rasta-h);
  padding: 16px 0;
  overflow: hidden;
  white-space: nowrap;
}
.dr-ticker-track {
  display: flex;
  width: max-content;
  animation: dr-tick 20s linear infinite;
}
.dr-ticker-inner {
  display: flex;
  align-items: center;
  gap: 20px;
  padding-right: 20px;
  flex-shrink: 0;
  font-family: var(--dr-font);
  font-size: 13px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--dr-dark);
}
.dr-ticker-dot { color: var(--dr-red); font-size: 8px; }
@keyframes dr-tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ---- STORY ---- */
.dr-story {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
  background: var(--dr-dark);
}
@media(max-width:900px){.dr-story{grid-template-columns:1fr;}}

/* Story visual side — Sound System Stack */
.dr-story-visual-side {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px;
  position: relative;
  background: var(--dr-green);
  border-right: 1px solid rgba(230,180,34,.1);
}
@media(max-width:900px){.dr-story-visual-side{padding:48px 24px;min-height:420px;border-right:none;border-bottom:1px solid rgba(230,180,34,.1);}}

.dr-soundsys {
  position: relative;
  width: 280px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
@media(max-width:500px){.dr-soundsys{width:220px;}}

/* Rasta stripes at top */
.dr-ss-stripe { height: 4px; border-radius: 2px; }
.dr-ss-red   { background: #c62828; }
.dr-ss-gold  { background: #e6b422; }
.dr-ss-green { background: #2e7d32; }

/* Speaker cabinets */
.dr-ss-cab {
  background: #1a1a1a;
  border: 2px solid #2a2a2a;
  border-radius: 6px;
  position: relative;
  box-shadow: 0 4px 20px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.04);
}
.dr-ss-cab-1 { padding: 24px; }
.dr-ss-cab-2 { padding: 16px; }
.dr-ss-cab-3 { padding: 12px; }

.dr-ss-grille {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  background: repeating-linear-gradient(0deg, transparent 0px, transparent 2px, rgba(255,255,255,.02) 2px, rgba(255,255,255,.02) 3px);
  border-radius: 4px;
  padding: 12px;
}

/* Main subwoofer */
.dr-ss-speaker-unit {
  width: 160px;
  height: 160px;
  border-radius: 50%;
  background: radial-gradient(circle at 45% 45%, #333 0%, #1a1a1a 50%, #111 100%);
  position: relative;
  box-shadow: 0 0 0 3px #222, 0 0 0 6px #1a1a1a, inset 0 0 20px rgba(0,0,0,.5);
}
@media(max-width:500px){.dr-ss-speaker-unit{width:120px;height:120px;}}
.dr-ss-cone {
  position: absolute;
  inset: 15%;
  border-radius: 50%;
  background: radial-gradient(circle at 45% 45%, #2a2a2a 0%, #181818 60%, #111 100%);
  box-shadow: inset 0 0 15px rgba(0,0,0,.6);
}
.dr-ss-dust {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 50%;
  height: 50%;
  border-radius: 50%;
  background: var(--dr-rasta);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 6%;
  animation: dr-ss-bump 1.2s ease-in-out infinite;
  box-shadow: 0 0 25px rgba(230,180,34,.4);
}
.dr-ss-logo { width: 92%; height: 92%; object-fit: contain; filter: drop-shadow(0 1px 3px rgba(0,0,0,.2)); }
@keyframes dr-ss-bump {
  0%, 100% { transform: translate(-50%,-50%) scale(1); }
  50%      { transform: translate(-50%,-50%) scale(1.08); }
}

/* Mid-range speakers */
.dr-ss-mid {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: radial-gradient(circle at 45% 45%, #2a2a2a 0%, #151515 100%);
  box-shadow: 0 0 0 2px #222, inset 0 0 10px rgba(0,0,0,.5);
  position: relative;
}
.dr-ss-mid::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 30%;
  height: 30%;
  border-radius: 50%;
  background: #333;
}

/* Tweeters */
.dr-ss-tweet {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: radial-gradient(circle, #333 0%, #1a1a1a 100%);
  box-shadow: 0 0 0 1px #222, inset 0 0 6px rgba(0,0,0,.5);
  position: relative;
}
.dr-ss-tweet::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--dr-gold);
}

/* Bass pulse rings */
.dr-ss-pulse {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%,-50%);
  border: 1px solid var(--dr-lime);
  border-radius: 50%;
  opacity: 0;
  animation: dr-ss-wave 2.4s ease-out infinite;
  pointer-events: none;
}
.dr-ss-p1 { width: 320px; height: 320px; animation-delay: 0s; }
.dr-ss-p2 { width: 400px; height: 400px; animation-delay: 1.2s; }
@keyframes dr-ss-wave {
  0%   { opacity: .35; transform: translate(-50%,-50%) scale(.8); }
  100% { opacity: 0;   transform: translate(-50%,-50%) scale(1.4); }
}

/* Year stamp */
.dr-ss-year {
  text-align: center;
  font-family: var(--dr-mono);
  font-size: 9px;
  letter-spacing: .3em;
  text-transform: uppercase;
  color: rgba(230,180,34,.35);
  margin-top: 12px;
}

.dr-story-text-side {
  padding: 80px 60px;
  display: flex; flex-direction: column; justify-content: center; gap: 24px;
}
@media(max-width:768px){.dr-story-text-side{padding:48px 24px;}}

.dr-story-eyebrow {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--dr-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--dr-gold);
}
.dr-story-h2 {
  font-family: var(--dr-font);
  font-size: clamp(32px, 4.5vw, 56px);
  text-transform: uppercase;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: var(--dr-white);
  margin: 0;
}
.dr-story-h2 em { font-style: normal; color: var(--dr-gold); }
.dr-story-p {
  font-family: var(--dr-body);
  font-size: 15px; line-height: 1.8;
  color: rgba(245,245,240,.5);
  max-width: 480px; margin: 0;
}
.dr-story-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.dr-stag {
  font-family: var(--dr-mono); font-size: 9px; letter-spacing: .16em; text-transform: uppercase;
  padding: 6px 14px; border: 1px solid rgba(230,180,34,.15); color: rgba(230,180,34,.6);
  transition: border-color .25s, color .25s; cursor: default;
}
.dr-stag:hover { border-color: var(--dr-gold); color: var(--dr-gold); }

/* ---- CULTURE STRIP ---- */
.dr-culture {
  background: var(--dr-green);
  padding: 80px 60px;
  border-top: 1px solid rgba(230,180,34,.06);
  border-bottom: 1px solid rgba(230,180,34,.06);
}
@media(max-width:768px){.dr-culture{padding:48px 24px;}}
.dr-culture-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}
@media(max-width:768px){.dr-culture-grid{grid-template-columns:1fr;}}
.dr-culture-card {
  padding: 40px 32px;
  border: 1px solid rgba(230,180,34,.1);
  transition: border-color .3s, transform .3s;
  cursor: default;
}
.dr-culture-card:hover { border-color: var(--dr-gold); transform: translateY(-4px); }
.dr-culture-card h3 {
  font-family: var(--dr-font); font-size: 20px; color: var(--dr-white);
  margin: 20px 0 12px; text-transform: uppercase;
}
.dr-culture-card p { font-family: var(--dr-body); font-size: 14px; line-height: 1.7; color: rgba(245,245,240,.45); margin: 0; }
.dr-culture-card-accent {
  background: var(--dr-rasta);
  border-color: transparent;
}
.dr-culture-card-accent h3 { color: var(--dr-dark); }
.dr-culture-card-accent p { color: rgba(10,10,10,.6); }
.dr-culture-card-accent:hover { transform: translateY(-4px); }
.dr-culture-icon { margin-bottom: 4px; }

/* ---- SHOP ---- */
.dr-shop { background: var(--dr-dark); padding: 80px 60px; }
@media(max-width:768px){.dr-shop{padding:48px 24px;}}
.dr-shop-inner { max-width: 1200px; margin: 0 auto; }
.dr-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px){.dr-shop-head{grid-template-columns:1fr;}}
.dr-shop-eyebrow { font-family: var(--dr-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--dr-gold); }
.dr-shop-h2 {
  font-family: var(--dr-font);
  font-size: clamp(40px, 6vw, 72px);
  text-transform: uppercase;
  letter-spacing: -.03em; line-height: 1;
  margin: 8px 0 0; color: var(--dr-white);
}
.dr-shop-head-rhs p { font-family: var(--dr-body); font-size: 14px; line-height: 1.7; color: rgba(245,245,240,.4); }
.dr-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
.dr-filter {
  font-family: var(--dr-mono); font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
  padding: 9px 18px; border: 1px solid rgba(245,245,240,.2); background: transparent; color: var(--dr-white);
  cursor: pointer; transition: all .25s;
}
.dr-filter:hover, .dr-filter.active { background: var(--dr-rasta-h); color: var(--dr-dark); border-color: transparent; }

.dr-product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 24px;
}
.dr-card {
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: transform .3s;
}
.dr-card:hover { transform: translateY(-6px); }
.dr-card[style*="display:none"] { display: none !important; }
.dr-card-img {
  position: relative;
  overflow: hidden;
  background: #111;
  aspect-ratio: 1;
}
.dr-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.dr-card:hover .dr-card-img img { transform: scale(1.06); }
.dr-card-overlay {
  position: absolute; inset: 0;
  background: rgba(10,10,10,.7);
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font-family: var(--dr-mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--dr-gold);
  opacity: 0; transition: opacity .3s;
}
.dr-card:hover .dr-card-overlay { opacity: 1; }
.dr-no-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--dr-mono); font-size: 11px; letter-spacing: .15em; color: #333; text-align: center; line-height: 1.6;
}
.dr-sale-badge {
  position: absolute; top: 12px; right: 12px;
  font-family: var(--dr-mono); font-size: 9px; letter-spacing: .12em;
  background: var(--dr-red); color: #fff; padding: 4px 10px; font-weight: 700;
}
.dr-card-body { padding: 16px 0; }
.dr-card-type { font-family: var(--dr-mono); font-size: 9px; letter-spacing: .16em; text-transform: uppercase; color: var(--dr-gold); }
.dr-card-title { font-family: var(--dr-body); font-size: 15px; color: var(--dr-white); margin: 6px 0 4px; }
.dr-card-price { font-family: var(--dr-mono); font-size: 13px; color: var(--dr-grey); }
.dr-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--dr-mono); font-size: 11px; letter-spacing: .15em; color: #555; text-transform: uppercase; }

/* ---- CLOSING ---- */
.dr-closing {
  background: var(--dr-green);
  padding: 120px 60px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
@media(max-width:768px){.dr-closing{padding:60px 24px;}}
.dr-closing-eq {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 60%;
  display: flex; align-items: flex-end; justify-content: center; gap: 20px;
  pointer-events: none; opacity: .04;
}
.dr-ceq {
  width: 40px; background: var(--dr-gold); border-radius: 4px 4px 0 0;
  animation: dr-eq 2s ease-in-out infinite alternate;
  animation-delay: calc(var(--i) * .15s);
}
.dr-closing-inner { position: relative; z-index: 2; max-width: 600px; margin: 0 auto; }
.dr-closing-h2 {
  font-family: var(--dr-font);
  font-size: clamp(36px, 5vw, 64px);
  text-transform: uppercase;
  letter-spacing: -.03em; line-height: 1.05;
  color: var(--dr-white); margin: 0 0 20px;
}
.dr-closing p { font-family: var(--dr-body); font-size: 15px; line-height: 1.7; color: rgba(245,245,240,.45); margin: 0 0 32px; }

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce){
  .dr-ss-bump,.dr-ss-wave,.dr-eq-bar,.dr-ceq,.dr-sound-wave,.dr-scroll-thumb,.dr-ticker-inner,.dr-speaker-dust-cap{animation:none!important;}
  .dr-card:hover{transform:none;}
}
</style>

<!-- ============================================================
     SCRIPTS — Motion.dev animations
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  /* ---- Filters ---- */
  var filterBtns = document.querySelectorAll('.dr-filter');
  var cards = document.querySelectorAll('.dr-card');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var f = this.dataset.filter;
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });

  /* ---- Motion.dev ---- */
  if (window.Motion) {
    var M = window.Motion;

    /* Hero entrance */
    M.animate('.dr-hero-tag', { opacity: [0,1], x: [-30,0] }, { duration: .6, delay: .3 });
    M.animate('.dr-h1-word', { opacity: [0,1], y: [80,0], clipPath: ['inset(100% 0 0 0)','inset(0% 0 0 0)'] },
      { delay: M.stagger(.15, { start: .5 }), duration: .8, easing: [.22,1,.36,1] });
    M.animate('.dr-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: .9 });
    M.animate('.dr-hero-cta-row', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: 1.1 });
    M.animate('.dr-speaker-wrap', { opacity: [0,1], scale: [.7,1] }, { duration: 1, delay: .4, easing: [.22,1,.36,1] });

    /* Story section — sound system */
    M.inView('.dr-story-visual-side', function(info) {
      M.animate('.dr-ss-stripe', { opacity: [0,1], scaleX: [0,1] },
        { delay: M.stagger(.08), duration: .4, easing: [.22,1,.36,1] });
      M.animate('.dr-ss-cab', { opacity: [0,1], y: [40,0] },
        { delay: M.stagger(.12, { start: .3 }), duration: .6, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    M.inView('.dr-story-text-side', function(info) {
      M.animate('.dr-story-text-side > *', { opacity: [0,1], x: [40,0] },
        { delay: M.stagger(.1), duration: .6, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    /* Culture cards */
    M.inView('.dr-culture-grid', function(info) {
      M.animate('.dr-culture-card', { opacity: [0,1], y: [40,0] },
        { delay: M.stagger(.12), duration: .7, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    /* Product cards */
    document.querySelectorAll('.dr-card').forEach(function(card) {
      M.inView(card, function() {
        M.animate(card, { opacity: [0,1], y: [30,0] }, { duration: .5, easing: [.22,1,.36,1] });
      }, { margin: '-5% 0px' });
    });

    /* Closing CTA */
    M.inView('.dr-closing-inner', function() {
      M.animate('.dr-closing-h2', { opacity: [0,1], y: [40,0] }, { duration: .8, easing: [.22,1,.36,1] });
      M.animate('.dr-closing p', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: .2 });
      M.animate('.dr-closing .dr-cta-primary', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: .4 });
    }, { margin: '-10% 0px' });
  }
});
</script>

{% schema %}
{
  "name": "Brand: Dready OG",
  "settings": [
    { "type": "textarea", "id": "story_text", "label": "Brand story text", "default": "Established in 1983, DREADY is rooted in a blend of Jamaican and English subcultures. More than a brand, DREADY is a lifestyle that resonates with everyone — built on unity, creativity, and community. From the very beginning, DREADY has been about connection, bringing people together through style, sound, and shared culture. Every piece carries bold design, rich heritage, and good vibes made to last. Feel the vibe. Wear the culture!" }
  ],
  "presets": [
    { "name": "Brand: Dready OG" }
  ]
}
{% endschema %}
