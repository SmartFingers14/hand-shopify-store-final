{% comment %}
  Brand Page: FUNKY DOG
  Playful music & lifestyle brand. Rhythm, vinyl culture, individuality.
  Expressive · Funky · Collectible · Creative
{% endcomment %}

{%- assign fd_col = collections['funky-dog'] -%}
{%- if fd_col == blank or fd_col.products_count == 0 -%}
  {%- assign fd_col = collections['funky-dog-1'] -%}
{%- endif -%}

<div class="fd-page">

<!-- ============================================================
     HERO — Vinyl record meets street funk
     ============================================================ -->
<section class="fd-hero" id="fd-top">
  <!-- Bouncing vinyl grooves -->
  <div class="fd-grooves" aria-hidden="true">
    <div class="fd-groove fd-g1"></div>
    <div class="fd-groove fd-g2"></div>
    <div class="fd-groove fd-g3"></div>
    <div class="fd-groove fd-g4"></div>
    <div class="fd-groove fd-g5"></div>
  </div>

  <!-- Floating music notes -->
  <div class="fd-notes" aria-hidden="true">
    <span class="fd-note" style="--nx:8%;--ny:20%;--nd:0s">&#9835;</span>
    <span class="fd-note" style="--nx:92%;--ny:35%;--nd:1s">&#9834;</span>
    <span class="fd-note" style="--nx:15%;--ny:75%;--nd:2s">&#9833;</span>
    <span class="fd-note" style="--nx:85%;--ny:80%;--nd:3s">&#9835;</span>
    <span class="fd-note" style="--nx:50%;--ny:10%;--nd:4s">&#9834;</span>
    <span class="fd-note" style="--nx:70%;--ny:60%;--nd:5s">&#9833;</span>
  </div>

  <!-- Halftone dots -->
  <div class="fd-halftone" aria-hidden="true"></div>

  <div class="fd-hero-content">
    <div class="fd-hero-badge">
      <span class="fd-badge-icon">&#9836;</span>
      <span>Rhythm · Vinyl · Character</span>
    </div>

    <h1 class="fd-hero-h1">
      <span class="fd-h1-line fd-h1-l1">FUNKY</span>
      <span class="fd-h1-line fd-h1-l2">DOG</span>
    </h1>

    <p class="fd-hero-sub">A playful music and lifestyle brand inspired by rhythm, vinyl culture, individuality and character. Expressive, funky, collectible.</p>

    <div class="fd-hero-actions">
      <a class="fd-btn-funk" href="#fd-shop">
        <span class="fd-btn-bounce">&#9836;</span>
        Shop The Groove
      </a>
      <div class="fd-hero-stats">
        <div class="fd-hs"><span class="fd-hs-n">100%</span><span class="fd-hs-l">Organic</span></div>
        <div class="fd-hs-sep"></div>
        <div class="fd-hs"><span class="fd-hs-n">UK</span><span class="fd-hs-l">Printed</span></div>
        <div class="fd-hs-sep"></div>
        <div class="fd-hs"><span class="fd-hs-n">220g</span><span class="fd-hs-l">Heavy</span></div>
      </div>
    </div>
  </div>

  <!-- Spinning vinyl -->
  <div class="fd-vinyl" aria-hidden="true">
    <div class="fd-vinyl-disc">
      <div class="fd-vinyl-label">FD</div>
    </div>
  </div>
</section>

<!-- ============================================================
     TICKER — Bouncy funk strip
     ============================================================ -->
<div class="fd-ticker">
  <div class="fd-ticker-track">
    {%- for i in (1..2) -%}
    <div class="fd-ticker-set">
      <span>FUNKY DOG</span><span class="fd-tsep">&#9836;</span>
      <span>ATOMIC DOG</span><span class="fd-tsep">&#9836;</span>
      <span>MONGREL SOUP</span><span class="fd-tsep">&#9836;</span>
      <span>VINYL VIBES</span><span class="fd-tsep">&#9836;</span>
      <span>RHYTHM</span><span class="fd-tsep">&#9836;</span>
      <span>FUNK NATION</span><span class="fd-tsep">&#9836;</span>
      <span>COLLECTIBLE</span><span class="fd-tsep">&#9836;</span>
      <span>GROOVE</span><span class="fd-tsep">&#9836;</span>
    </div>
    {%- endfor -%}
  </div>
</div>

<!-- ============================================================
     STORY — Split with vinyl culture vibe
     ============================================================ -->
<section class="fd-story">
  <div class="fd-story-visual">
    <div class="fd-story-pattern" aria-hidden="true"></div>
    <div class="fd-big-text" aria-hidden="true">FUNK</div>
    <div class="fd-story-vinyl-mini">
      <div class="fd-svm-disc">
        <div class="fd-svm-hole"></div>
      </div>
    </div>
  </div>
  <div class="fd-story-text">
    <div class="fd-eyebrow">&#9836; The Vibe</div>
    <h2 class="fd-story-h2">Feel The<br><em>Groove.</em></h2>
    <p class="fd-story-p">Funky Dog is a playful music and lifestyle brand inspired by rhythm, vinyl culture, individuality and character. Every piece is expressive, funky, collectible and creative — designed to move with you.</p>
    <div class="fd-tags">
      <span class="fd-tag">&#9836; Rhythm</span>
      <span class="fd-tag">&#9836; Vinyl</span>
      <span class="fd-tag">&#9836; Character</span>
      <span class="fd-tag">&#9836; Funk</span>
    </div>
  </div>
</section>

<!-- ============================================================
     MANIFESTO — Big statement
     ============================================================ -->
<section class="fd-manifesto">
  <div class="fd-mani-inner">
    <div class="fd-mani-note">&#9835;</div>
    <blockquote class="fd-quote">
      The tone is expressive, the vibe is funky, the character is <em>collectible.</em> Every print tells a story, every tee has a beat.
    </blockquote>
    <div class="fd-mani-line"></div>
    <p class="fd-mani-attr">Rhythm · Vinyl · Individuality</p>
  </div>
</section>

<!-- ============================================================
     PRODUCTS — Funky grid
     ============================================================ -->
<section class="fd-shop" id="fd-shop">
  <div class="fd-shop-inner">
    <div class="fd-shop-head">
      <div>
        <div class="fd-eyebrow-sm">&#9836; The Collection</div>
        <h2 class="fd-shop-h2">Drop The Beat.</h2>
      </div>
      <div>
        <p class="fd-shop-desc">Expressive streetwear rooted in rhythm, vinyl culture and individuality. Every piece is a collectible.</p>
        <div class="fd-filters">
          <button class="fd-filter active" data-filter="all">All</button>
          <button class="fd-filter" data-filter="tee">T-Shirts</button>
          <button class="fd-filter" data-filter="hood">Hoodies</button>
          <button class="fd-filter" data-filter="acc">Accessories</button>
        </div>
      </div>
    </div>

    <div class="fd-grid">
      {%- assign fd_count = 0 -%}
      {%- for product in fd_col.products limit: 500 -%}
        {%- assign vd = product.vendor | downcase -%}
        {%- unless vd contains 'funky' -%}{%- continue -%}{%- endunless -%}
        {%- assign fd_count = fd_count | plus: 1 -%}
        {%- assign filter_tag = 'acc' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}
          {%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' -%}
          {%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="fd-prod" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="fd-prod-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="fd-no-img">&#9836;</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="fd-sale">SALE</span>
            {%- endif -%}
            <div class="fd-prod-hover">
              <span>Groove In &#9836;</span>
            </div>
          </div>
          <div class="fd-prod-info">
            <span class="fd-prod-type">{{ product.type | default: 'FUNKY DOG' }}</span>
            <div class="fd-prod-name">{{ product.title }}</div>
            <div class="fd-prod-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
      {%- if fd_count == 0 -%}
        <div class="fd-empty">&#9836; No Funky Dog products found. The groove is loading... &#9836;</div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING — Grand funk finale
     ============================================================ -->
<section class="fd-closing">
  <div class="fd-closing-grooves" aria-hidden="true">
    <div class="fd-groove fd-g1"></div>
    <div class="fd-groove fd-g2"></div>
    <div class="fd-groove fd-g3"></div>
  </div>
  <div class="fd-closing-inner">
    <div class="fd-closing-note">&#9835;</div>
    <h2 class="fd-closing-h2">Feel The<br><em>Funk.</em></h2>
    <p>Expressive. Funky. Collectible. Creative.</p>
    <a class="fd-btn-funk" href="#fd-shop">
      <span class="fd-btn-bounce">&#9836;</span>
      Shop Funky Dog
    </a>
  </div>
</section>

</div>

<!-- ============================================================
     STYLES — FUNKY · BOLD · PLAYFUL
     ============================================================ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;600;700;800&display=swap');

.fd-page {
  --fd-black: #0a0a0a;
  --fd-dark: #1a1418;
  --fd-orange: #ff6b00;
  --fd-yellow: #ffd000;
  --fd-lime: #a3e635;
  --fd-cyan: #06b6d4;
  --fd-pink: #ec4899;
  --fd-white: #fff;
  --fd-cream: #fff8ee;
  --fd-funk: 'Fredoka', 'Arial Black', sans-serif;
  --fd-body: 'Nunito', system-ui, sans-serif;
  --fd-mono: var(--mono, 'JetBrains Mono'), monospace;
  background: var(--fd-black); color: var(--fd-white); overflow-x: hidden;
}

/* ---- HERO ---- */
.fd-hero {
  position: relative; min-height: 100vh; min-height: 100dvh;
  background: var(--fd-black); display: flex; align-items: center; justify-content: center;
  overflow: hidden; padding: 100px 24px 80px; text-align: center;
}

/* Bouncing groove circles */
.fd-grooves { position: absolute; inset: 0; pointer-events: none; }
.fd-groove {
  position: absolute; border-radius: 50%; border: 2px solid;
  animation: fd-groove-pulse 4s ease-in-out infinite;
}
.fd-g1 { width: 600px; height: 600px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(255,107,0,.08); animation-delay: 0s; }
.fd-g2 { width: 450px; height: 450px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(236,72,153,.06); animation-delay: .5s; }
.fd-g3 { width: 300px; height: 300px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(255,208,0,.06); animation-delay: 1s; }
.fd-g4 { width: 150px; height: 150px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(6,182,212,.05); animation-delay: 1.5s; }
.fd-g5 { width: 750px; height: 750px; top: 50%; left: 50%; transform: translate(-50%,-50%); border-color: rgba(163,230,53,.04); animation-delay: 2s; }
@keyframes fd-groove-pulse { 0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.5} 50%{transform:translate(-50%,-50%) scale(1.08);opacity:1} }

/* Floating music notes */
.fd-notes { position: absolute; inset: 0; pointer-events: none; }
.fd-note {
  position: absolute; left: var(--nx); top: var(--ny);
  font-size: 28px; color: var(--fd-orange); opacity: .15;
  animation: fd-note-float 6s ease-in-out infinite;
  animation-delay: var(--nd);
}
@keyframes fd-note-float {
  0%,100% { transform: translateY(0) rotate(0deg); opacity: .1; }
  50% { transform: translateY(-30px) rotate(15deg); opacity: .25; }
}

/* Halftone */
.fd-halftone {
  position: absolute; inset: 0; pointer-events: none;
  background-image: radial-gradient(circle, var(--fd-orange) 1px, transparent 1px);
  background-size: 32px 32px; opacity: .04;
}

/* Hero content */
.fd-hero-content { position: relative; z-index: 3; max-width: 700px; display: flex; flex-direction: column; align-items: center; }

.fd-hero-badge {
  display: inline-flex; align-items: center; gap: 12px;
  font-family: var(--fd-mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--fd-orange); margin-bottom: 28px;
  padding: 8px 20px; border: 2px solid rgba(255,107,0,.3); border-radius: 50px;
}
.fd-badge-icon { font-size: 14px; animation: fd-note-float 2s ease-in-out infinite; }

.fd-hero-h1 { margin: 0 0 20px; }
.fd-h1-line {
  display: block; font-family: var(--fd-funk); font-weight: 700; text-transform: uppercase; line-height: .88;
}
.fd-h1-l1 {
  font-size: clamp(72px, 14vw, 180px); letter-spacing: -.02em;
  color: var(--fd-white);
  text-shadow: 4px 4px 0 var(--fd-orange), 8px 8px 0 rgba(255,107,0,.15);
}
.fd-h1-l2 {
  font-size: clamp(80px, 16vw, 200px); letter-spacing: -.02em;
  background: linear-gradient(135deg, var(--fd-orange) 0%, var(--fd-yellow) 40%, var(--fd-lime) 70%, var(--fd-cyan) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  filter: drop-shadow(3px 3px 0 rgba(255,107,0,.2));
}

.fd-hero-sub {
  font-family: var(--fd-body); font-size: 16px; font-weight: 400;
  line-height: 1.8; color: rgba(255,255,255,.5); margin: 0 0 40px; max-width: 480px;
}

.fd-hero-actions { display: flex; align-items: center; justify-content: center; gap: 28px; flex-wrap: wrap; }

/* Funky button */
.fd-btn-funk {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--fd-orange); color: var(--fd-black); font-family: var(--fd-funk); font-size: 14px;
  font-weight: 700; text-transform: uppercase; text-decoration: none; padding: 16px 32px;
  border: 3px solid var(--fd-orange); cursor: pointer; transition: all .2s;
  box-shadow: 4px 4px 0 var(--fd-yellow);
}
.fd-btn-funk:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--fd-yellow); background: var(--fd-yellow); border-color: var(--fd-yellow); }
.fd-btn-bounce { display: inline-block; animation: fd-bounce 1s ease infinite; }
@keyframes fd-bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }

.fd-hero-stats { display: flex; align-items: center; gap: 16px; }
.fd-hs { display: flex; flex-direction: column; gap: 2px; align-items: center; }
.fd-hs-n { font-family: var(--fd-funk); font-size: 20px; font-weight: 700; color: var(--fd-yellow); }
.fd-hs-l { font-family: var(--fd-mono); font-size: 8px; letter-spacing: .15em; text-transform: uppercase; color: rgba(255,255,255,.3); }
.fd-hs-sep { width: 2px; height: 24px; background: rgba(255,107,0,.2); border-radius: 1px; }

/* Spinning vinyl */
.fd-vinyl {
  position: absolute; right: -60px; bottom: -60px; z-index: 1; opacity: .12;
}
@media(max-width:768px){ .fd-vinyl { display: none; } }
.fd-vinyl-disc {
  width: 300px; height: 300px; border-radius: 50%;
  background: repeating-radial-gradient(circle, transparent 0px, transparent 8px, rgba(255,107,0,.1) 8px, rgba(255,107,0,.1) 10px);
  border: 3px solid rgba(255,107,0,.15);
  animation: fd-spin 20s linear infinite;
  display: flex; align-items: center; justify-content: center;
}
.fd-vinyl-label {
  width: 60px; height: 60px; border-radius: 50%; background: var(--fd-orange);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--fd-funk); font-weight: 700; font-size: 18px; color: var(--fd-black);
}
@keyframes fd-spin { to { transform: rotate(360deg); } }

/* ---- TICKER ---- */
.fd-ticker {
  background: var(--fd-orange); padding: 14px 0; overflow: hidden; white-space: nowrap;
  border-top: 3px solid var(--fd-yellow); border-bottom: 3px solid var(--fd-yellow);
}
.fd-ticker-track { display: flex; width: max-content; animation: fd-tick 25s linear infinite; }
.fd-ticker-set {
  display: flex; align-items: center; gap: 24px; padding-right: 24px; flex-shrink: 0;
  font-family: var(--fd-funk); font-size: 16px; font-weight: 700; letter-spacing: .08em;
  text-transform: uppercase; color: var(--fd-black);
}
.fd-tsep { font-size: 12px; }
@keyframes fd-tick { to { transform: translateX(-50%); } }

/* ---- STORY ---- */
.fd-story { display: grid; grid-template-columns: 1fr 1.3fr; min-height: 500px; background: var(--fd-dark); }
@media(max-width:900px){.fd-story{grid-template-columns:1fr;}}

.fd-story-visual {
  position: relative; display: flex; align-items: center; justify-content: center;
  padding: 60px; overflow: hidden; border-right: 3px solid rgba(255,107,0,.15);
}
@media(max-width:900px){.fd-story-visual{min-height:300px;border-right:none;border-bottom:3px solid rgba(255,107,0,.15);}}
.fd-story-pattern {
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, var(--fd-orange) 1px, transparent 1px);
  background-size: 24px 24px; opacity: .04;
}
.fd-big-text {
  position: absolute; font-family: var(--fd-funk); font-size: clamp(120px, 20vw, 240px);
  font-weight: 700; text-transform: uppercase; color: rgba(255,107,0,.04); letter-spacing: -.02em;
  pointer-events: none;
}
.fd-story-vinyl-mini { position: relative; z-index: 2; }
.fd-svm-disc {
  width: 180px; height: 180px; border-radius: 50%;
  background: repeating-radial-gradient(circle, transparent 0px, transparent 6px, rgba(255,107,0,.12) 6px, rgba(255,107,0,.12) 8px);
  border: 3px solid rgba(255,107,0,.25); display: flex; align-items: center; justify-content: center;
  animation: fd-spin 15s linear infinite;
}
.fd-svm-hole { width: 20px; height: 20px; border-radius: 50%; background: var(--fd-orange); }

.fd-story-text { padding: 80px 60px; display: flex; flex-direction: column; justify-content: center; gap: 22px; }
@media(max-width:768px){.fd-story-text{padding:48px 24px;}}

.fd-eyebrow { font-family: var(--fd-mono); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--fd-orange); }
.fd-story-h2 {
  font-family: var(--fd-funk); font-size: clamp(36px, 5.5vw, 64px); font-weight: 700;
  text-transform: uppercase; line-height: 1; margin: 0; color: var(--fd-white);
}
.fd-story-h2 em { font-style: normal; color: var(--fd-orange); }
.fd-story-p { font-family: var(--fd-body); font-size: 15px; line-height: 1.85; color: rgba(255,255,255,.45); max-width: 460px; }
.fd-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.fd-tag {
  font-family: var(--fd-mono); font-size: 9px; letter-spacing: .12em; text-transform: uppercase;
  padding: 7px 16px; border: 2px solid rgba(255,107,0,.25); color: var(--fd-orange);
  transition: all .2s; cursor: default;
}
.fd-tag:hover { background: var(--fd-orange); color: var(--fd-black); border-color: var(--fd-orange); box-shadow: 3px 3px 0 var(--fd-yellow); }

/* ---- MANIFESTO ---- */
.fd-manifesto { background: var(--fd-orange); padding: 100px 40px; text-align: center; }
@media(max-width:768px){.fd-manifesto{padding:60px 20px;}}
.fd-mani-inner { max-width: 720px; margin: 0 auto; }
.fd-mani-note { font-size: 28px; color: var(--fd-black); margin-bottom: 24px; animation: fd-bounce 2s ease infinite; }
.fd-quote {
  font-family: var(--fd-funk); font-size: clamp(22px, 3.5vw, 36px); font-weight: 600;
  line-height: 1.5; color: var(--fd-black); margin: 0;
}
.fd-quote em { font-style: normal; color: var(--fd-white); text-shadow: 2px 2px 0 rgba(0,0,0,.15); }
.fd-mani-line { width: 80px; height: 3px; background: var(--fd-black); margin: 28px auto; border-radius: 2px; }
.fd-mani-attr { font-family: var(--fd-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: rgba(0,0,0,.45); }

/* ---- SHOP ---- */
.fd-shop { background: var(--fd-black); padding: 80px 60px; }
@media(max-width:768px){.fd-shop{padding:48px 20px;}}
.fd-shop-inner { max-width: 1200px; margin: 0 auto; }
.fd-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px){.fd-shop-head{grid-template-columns:1fr;}}
.fd-eyebrow-sm { font-family: var(--fd-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--fd-orange); }
.fd-shop-h2 {
  font-family: var(--fd-funk); font-size: clamp(36px, 5vw, 60px); font-weight: 700;
  text-transform: uppercase; line-height: 1; margin: 6px 0 0; color: var(--fd-white);
}
.fd-shop-desc { font-family: var(--fd-body); font-size: 14px; line-height: 1.7; color: rgba(255,255,255,.35); }
.fd-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }
.fd-filter {
  font-family: var(--fd-funk); font-size: 12px; text-transform: uppercase;
  padding: 8px 18px; border: 2px solid rgba(255,107,0,.3); background: transparent;
  color: var(--fd-white); cursor: pointer; transition: all .2s;
}
.fd-filter:hover, .fd-filter.active {
  background: var(--fd-orange); color: var(--fd-black); border-color: var(--fd-orange);
  box-shadow: 3px 3px 0 var(--fd-yellow);
}

.fd-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
.fd-prod { text-decoration: none; color: inherit; cursor: pointer; transition: transform .2s; }
.fd-prod:hover { transform: translate(-3px,-3px); }
.fd-prod-img {
  position: relative; overflow: hidden; background: var(--fd-dark); aspect-ratio: 1;
  border: 2px solid rgba(255,107,0,.1);
}
.fd-prod-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.fd-prod:hover .fd-prod-img img { transform: scale(1.08); }
.fd-prod-hover {
  position: absolute; inset: 0; background: rgba(255,107,0,.85);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--fd-funk); font-size: 14px; text-transform: uppercase; font-weight: 700;
  color: var(--fd-black); opacity: 0; transition: opacity .2s;
}
.fd-prod:hover .fd-prod-hover { opacity: 1; }
.fd-no-img { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; color: rgba(255,107,0,.1); }
.fd-sale {
  position: absolute; top: 10px; right: 10px;
  font-family: var(--fd-funk); font-size: 11px; font-weight: 700;
  background: var(--fd-yellow); color: var(--fd-black); padding: 4px 12px;
  box-shadow: 2px 2px 0 var(--fd-orange);
}
.fd-prod-info { padding: 14px 4px; }
.fd-prod-type { font-family: var(--fd-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--fd-orange); }
.fd-prod-name { font-family: var(--fd-funk); font-size: 15px; font-weight: 600; color: var(--fd-white); margin: 6px 0 4px; }
.fd-prod-price { font-family: var(--fd-mono); font-size: 13px; color: var(--fd-yellow); }
.fd-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--fd-mono); font-size: 12px; letter-spacing: .12em; color: rgba(255,107,0,.25); text-transform: uppercase; }

/* ---- CLOSING ---- */
.fd-closing {
  position: relative; background: var(--fd-dark); padding: 120px 40px; text-align: center; overflow: hidden;
}
@media(max-width:768px){.fd-closing{padding:80px 20px;}}
.fd-closing-grooves { position: absolute; inset: 0; pointer-events: none; }
.fd-closing-inner { position: relative; z-index: 2; max-width: 600px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
.fd-closing-note { font-size: 36px; color: var(--fd-orange); margin-bottom: 24px; animation: fd-bounce 2s ease infinite; }
.fd-closing-h2 {
  font-family: var(--fd-funk); font-size: clamp(40px, 7vw, 80px); font-weight: 700;
  text-transform: uppercase; line-height: .95; color: var(--fd-white); margin: 0 0 16px;
}
.fd-closing-h2 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--fd-orange), var(--fd-yellow), var(--fd-lime));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.fd-closing-inner p { font-family: var(--fd-body); font-size: 15px; color: rgba(255,255,255,.4); margin: 0 0 32px; }

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce){
  .fd-groove,.fd-note,.fd-vinyl-disc,.fd-svm-disc,.fd-btn-bounce,.fd-mani-note,.fd-closing-note,.fd-ticker-track{animation:none!important;}
  .fd-prod:hover{transform:none;}
}
</style>

<!-- SCRIPTS -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  var fBtns = document.querySelectorAll('.fd-filter');
  var cards = document.querySelectorAll('.fd-prod');
  fBtns.forEach(function(b) {
    b.addEventListener('click', function() {
      var f = this.dataset.filter;
      fBtns.forEach(function(x) { x.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });
  if (window.Motion) {
    var M = window.Motion;
    M.animate('.fd-hero-badge', { opacity: [0,1], y: [-15,0] }, { duration: .5, delay: .2 });
    M.animate('.fd-h1-l1', { opacity: [0,1], x: [-60,0] }, { duration: .7, delay: .4, easing: [.22,1,.36,1] });
    M.animate('.fd-h1-l2', { opacity: [0,1], x: [60,0] }, { duration: .7, delay: .6, easing: [.22,1,.36,1] });
    M.animate('.fd-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: .9 });
    M.animate('.fd-hero-actions', { opacity: [0,1], y: [20,0] }, { duration: .6, delay: 1.1 });
    M.inView('.fd-story-visual', function() {
      M.animate('.fd-story-vinyl-mini', { opacity: [0,1], scale: [.5,1], rotate: ['-180deg','0deg'] }, { duration: 1, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.fd-story-text', function() {
      M.animate('.fd-story-text > *', { opacity: [0,1], x: [30,0] }, { delay: M.stagger(.1), duration: .5, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    M.inView('.fd-mani-inner', function() {
      M.animate('.fd-mani-note', { opacity: [0,1], scale: [0,1] }, { duration: .4 });
      M.animate('.fd-quote', { opacity: [0,1], y: [25,0] }, { duration: .7, delay: .2, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });
    document.querySelectorAll('.fd-prod').forEach(function(c) {
      M.inView(c, function() { M.animate(c, { opacity: [0,1], y: [20,0] }, { duration: .4, easing: [.22,1,.36,1] }); }, { margin: '-5% 0px' });
    });
    M.inView('.fd-closing-inner', function() {
      M.animate('.fd-closing-note', { opacity: [0,1], scale: [0,1.2,1] }, { duration: .6 });
      M.animate('.fd-closing-h2', { opacity: [0,1], y: [30,0] }, { duration: .7, delay: .2, easing: [.22,1,.36,1] });
      M.animate('.fd-closing-inner .fd-btn-funk', { opacity: [0,1], y: [15,0] }, { duration: .5, delay: .5 });
    }, { margin: '-10% 0px' });
  }
});
</script>

{% schema %}
{
  "name": "Funky Dog Brand Page",
  "settings": [
    { "type": "collection", "id": "brand_collection", "label": "Funky Dog Collection" },
    { "type": "textarea", "id": "tagline", "label": "Hero tagline", "default": "A playful music and lifestyle brand inspired by rhythm, vinyl culture, individuality and character. Expressive, funky, collectible." }
  ],
  "presets": [{ "name": "Funky Dog Brand Page" }]
}
{% endschema %}
