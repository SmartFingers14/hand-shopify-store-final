{% comment %}
  Brand Page: Handspun Records — Redesigned
  Vinyl · Sound · Wax — Analogue music culture on cotton
{% endcomment %}

{%- comment -%}
  Use the collection picker from section settings first,
  then fall back to known collection handles.
  Vendor filter in the loop ensures ONLY Handspun Records products show.
{%- endcomment -%}
{%- if section.settings.brand_collection != blank -%}
  {%- assign brand_col = section.settings.brand_collection -%}
{%- else -%}
  {%- assign brand_col = collections['handspun-records'] -%}
  {%- if brand_col == blank or brand_col.products_count == 0 -%}
    {%- assign brand_col = collections['handspun'] -%}
  {%- endif -%}
  {%- if brand_col == blank or brand_col.products_count == 0 -%}
    {%- assign brand_col = collections['handspun-records-1'] -%}
  {%- endif -%}
{%- endif -%}

<!-- ============================================================
     HERO — Full viewport turntable with logo vinyl
     ============================================================ -->
<section class="hs-hero">
  <!-- Subtle groove lines background -->
  <div class="hs-groove-bg" aria-hidden="true">
    <div class="hs-groove-line" style="--j:0"></div>
    <div class="hs-groove-line" style="--j:1"></div>
    <div class="hs-groove-line" style="--j:2"></div>
    <div class="hs-groove-line" style="--j:3"></div>
    <div class="hs-groove-line" style="--j:4"></div>
    <div class="hs-groove-line" style="--j:5"></div>
  </div>

  <!-- Turntable with real logo in vinyl label -->
  <div class="hs-turntable" aria-hidden="true">
    <div class="hs-platter">
      <div class="hs-platter-ring"></div>
      <div class="hs-vinyl">
        <div class="hs-vinyl-grooves"></div>
        <div class="hs-vinyl-sheen"></div>
        <div class="hs-vinyl-label">
          <img src="{{ 'logo-handspun-records.jpeg' | asset_url }}" alt="Handspun Records" class="hs-label-logo" />
        </div>
      </div>
    </div>
    <!-- Tonearm -->
    <div class="hs-arm">
      <div class="hs-arm-base"></div>
      <div class="hs-arm-bar"></div>
      <div class="hs-arm-head">
        <div class="hs-arm-cartridge"></div>
      </div>
    </div>
    <!-- Warm glow -->
    <div class="hs-glow"></div>
  </div>

  <div class="hs-hero-content">
    <div class="hs-hero-tag">
      <span class="hs-tag-dash"></span>
      <span>Vinyl · Sound · Analogue · Culture</span>
    </div>

    <h1 class="hs-hero-h1">
      <span class="hs-h1-word">HAND</span><span class="hs-h1-word hs-h1-gold">SPUN</span> <span class="hs-h1-word hs-h1-rec">RECORDS<span class="hs-reg">®</span></span>
    </h1>

    <p class="hs-hero-sub">{{ section.settings.tagline | default: 'A vinyl and music culture brand celebrating sound, analogue music, DJs, records and underground creativity. Authentic, timeless and rooted in music heritage.' }}</p>

    <div class="hs-hero-actions">
      <a class="hs-btn" href="#hs-shop">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        Shop The Collection
      </a>
      <div class="hs-stats">
        <div class="hs-stat"><span class="hs-stat-val">{{ brand_col.products_count | default: '80+' }}</span><span class="hs-stat-lbl">Products</span></div>
        <div class="hs-stat-sep"></div>
        <div class="hs-stat"><span class="hs-stat-val">1990</span><span class="hs-stat-lbl">Est.</span></div>
        <div class="hs-stat-sep"></div>
        <div class="hs-stat"><span class="hs-stat-val">Vinyl</span><span class="hs-stat-lbl">Culture</span></div>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="hs-scroll" aria-hidden="true">
    <div class="hs-scroll-bar"><div class="hs-scroll-fill"></div></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ============================================================
     TICKER — Seamless infinite marquee
     ============================================================ -->
<div class="hs-ticker">
  <div class="hs-ticker-track">
    <div class="hs-ticker-set">
      <span>HANDSPUN RECORDS</span><span class="hs-tdot">◆</span>
      <span>VINYL CULTURE</span><span class="hs-tdot">◆</span>
      <span>ANALOGUE MUSIC</span><span class="hs-tdot">◆</span>
      <span>DJs</span><span class="hs-tdot">◆</span>
      <span>RECORDS</span><span class="hs-tdot">◆</span>
      <span>UNDERGROUND CREATIVITY</span><span class="hs-tdot">◆</span>
      <span>AUTHENTIC</span><span class="hs-tdot">◆</span>
      <span>TIMELESS</span><span class="hs-tdot">◆</span>
    </div>
    <div class="hs-ticker-set" aria-hidden="true">
      <span>HANDSPUN RECORDS</span><span class="hs-tdot">◆</span>
      <span>VINYL CULTURE</span><span class="hs-tdot">◆</span>
      <span>ANALOGUE MUSIC</span><span class="hs-tdot">◆</span>
      <span>DJs</span><span class="hs-tdot">◆</span>
      <span>RECORDS</span><span class="hs-tdot">◆</span>
      <span>UNDERGROUND CREATIVITY</span><span class="hs-tdot">◆</span>
      <span>AUTHENTIC</span><span class="hs-tdot">◆</span>
      <span>TIMELESS</span><span class="hs-tdot">◆</span>
    </div>
  </div>
</div>

<!-- ============================================================
     STORY — Vinyl sleeve split layout
     ============================================================ -->
<section class="hs-story">
  <div class="hs-story-visual">
    <div class="hs-sleeve">
      <div class="hs-sleeve-inner">
        <img src="{{ 'logo-handspun-records.jpeg' | asset_url }}" alt="Handspun Records" class="hs-sleeve-logo" />
      </div>
      <div class="hs-sleeve-edge"></div>
    </div>
    <div class="hs-story-disc" aria-hidden="true">
      <div class="hs-mini-vinyl">
        <div class="hs-mini-grooves"></div>
        <div class="hs-mini-label"></div>
      </div>
    </div>
  </div>
  <div class="hs-story-text">
    <div class="hs-eyebrow">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
      The Sound
    </div>
    <h2 class="hs-story-h2">Rooted in<br>music<br><em>heritage.</em></h2>
    <p class="hs-story-p">{{ section.settings.story_text | default: "Handspun Records celebrates the culture of vinyl — the sound, the analogue warmth, the DJs who keep it alive and the underground creativity that connects it all. Every piece we make carries that heritage. Authentic, timeless and made for those who still believe the record matters more than the algorithm." }}</p>
    <div class="hs-tags">
      <span class="hs-tag">Vinyl</span>
      <span class="hs-tag">Analogue</span>
      <span class="hs-tag">DJs</span>
      <span class="hs-tag">Records</span>
      <span class="hs-tag">Underground</span>
    </div>
  </div>
</section>


<!-- ============================================================
     PRODUCTS — Full grid with filters
     ============================================================ -->
<section class="hs-shop" id="hs-shop">
  <div class="hs-shop-inner">
    <div class="hs-shop-head">
      <div>
        <div class="hs-eyebrow-sm">The Full Drop</div>
        <h2 class="hs-shop-h2">All Products.</h2>
      </div>
      <div>
        <p class="hs-shop-desc">Vinyl and music culture on cotton. Tees, hoodies, slip mats, record bags — authentic, timeless and rooted in heritage.</p>
        <div class="hs-filters">
          <button class="hs-filter active" data-filter="all">All</button>
          <button class="hs-filter" data-filter="tee">T-Shirts</button>
          <button class="hs-filter" data-filter="hood">Hoodies</button>
          <button class="hs-filter" data-filter="acc">Accessories</button>
        </div>
      </div>
    </div>

    <div class="hs-grid" id="hs-product-grid">
      {%- assign hs_count = 0 -%}
      {%- for product in brand_col.products limit: 500 -%}
        {%- assign vd = product.vendor | downcase -%}
        {%- unless vd contains 'handspun' -%}
          {%- continue -%}
        {%- endunless -%}
        {%- unless product.available -%}
          {%- continue -%}
        {%- endunless -%}
        {%- assign hs_count = hs_count | plus: 1 -%}
        {%- assign filter_tag = 'acc' -%}
        {%- assign tl = product.title | downcase -%}
        {%- if tl contains 'hoodie' or tl contains 'hood' or tl contains 'sweatshirt' or tl contains 'zip' -%}
          {%- assign filter_tag = 'hood' -%}
        {%- elsif tl contains 't-shirt' or tl contains 'tee' or tl contains 'long-sleeve' or tl contains 'longsleeve' or tl contains 'long sleeve' -%}
          {%- assign filter_tag = 'tee' -%}
        {%- endif -%}
        <a class="hs-prod" href="{{ product.url }}" data-filter="{{ filter_tag }}">
          <div class="hs-prod-img">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" width="600" height="600" />
            {%- else -%}
              <div class="hs-no-img">HANDSPUN<br>RECORDS</div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="hs-badge">SALE</span>
            {%- endif -%}
            <div class="hs-prod-hover">
              <span>View Product</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
          <div class="hs-prod-info">
            <span class="hs-prod-type">{{ product.type | default: 'Handspun Records' }}</span>
            <div class="hs-prod-name">{{ product.title }}</div>
            <div class="hs-prod-price">{{ product.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
      {%- if hs_count == 0 -%}
        <div class="hs-empty">No Handspun Records products found. Check back soon.</div>
      {%- endif -%}
    </div>
  </div>
</section>

<!-- ============================================================
     CLOSING CTA — Stacked records
     ============================================================ -->
<section class="hs-closing">
  <div class="hs-closing-waves" aria-hidden="true">
    <div class="hs-cw" style="--j:0"></div>
    <div class="hs-cw" style="--j:1"></div>
    <div class="hs-cw" style="--j:2"></div>
    <div class="hs-cw" style="--j:3"></div>
    <div class="hs-cw" style="--j:4"></div>
  </div>
  <div class="hs-closing-inner">
    <div class="hs-closing-discs" aria-hidden="true">
      <div class="hs-cd hs-cd-back"></div>
      <div class="hs-cd hs-cd-mid"></div>
      <div class="hs-cd hs-cd-front">
        <img src="{{ 'logo-handspun-records.jpeg' | asset_url }}" alt="Handspun Records" class="hs-cd-logo" />
      </div>
    </div>
    <div class="hs-closing-text">
      <h2 class="hs-closing-h2">Authentic.<br>Timeless.</h2>
      <p>Celebrating sound, analogue music, DJs, records and underground creativity. Rooted in music heritage — always.</p>
      <a class="hs-btn" href="#hs-shop">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        Shop Handspun Records
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     STYLES
     ============================================================ -->
<style>
/* ---- TOKENS ---- */
:root {
  --hs-dark: #08081a;
  --hs-navy: #0e0e24;
  --hs-gold: #e8c547;
  --hs-gold-dim: rgba(232,197,71,.12);
  --hs-gold-mid: rgba(232,197,71,.5);
  --hs-warm: #f5e6b8;
  --hs-white: #f5f5f0;
  --hs-grey: rgba(245,245,240,.55);
  --hs-display: 'Righteous', var(--display), sans-serif;
  --hs-body: 'Poppins', var(--body), sans-serif;
  --hs-mono: var(--mono), monospace;
}

/* ---- HERO ---- */
.hs-hero {
  position: relative;
  min-height: 100vh;
  min-height: 100dvh;
  background: var(--hs-dark);
  display: flex;
  align-items: center;
  overflow: hidden;
  padding: 120px 60px 80px;
}
@media(max-width:768px){.hs-hero{padding:100px 24px 60px;}}

/* Groove lines background */
.hs-groove-bg {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  pointer-events: none;
  opacity: .04;
}
.hs-groove-line {
  width: 1px;
  height: 100%;
  background: linear-gradient(to bottom, transparent, var(--hs-gold), transparent);
  animation: hs-groove-pulse 4s ease-in-out infinite;
  animation-delay: calc(var(--j) * .5s);
}
@keyframes hs-groove-pulse {
  0%, 100% { opacity: .3; transform: scaleY(.6); }
  50% { opacity: 1; transform: scaleY(1); }
}

/* Turntable */
.hs-turntable {
  position: absolute;
  right: 2%;
  top: 50%;
  transform: translateY(-50%);
  width: clamp(300px, 42vw, 580px);
  aspect-ratio: 1;
  pointer-events: none;
}
@media(max-width:768px){.hs-turntable{width:220px;right:-50px;top:22%;opacity:.5;}}

.hs-platter {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, #18182e 0%, #0c0c1e 70%, #08081a 100%);
  position: relative;
  box-shadow: 0 0 0 6px rgba(232,197,71,.05), 0 0 100px rgba(232,197,71,.06);
}
.hs-platter-ring {
  position: absolute;
  inset: 2%;
  border-radius: 50%;
  border: 1px solid rgba(232,197,71,.06);
}

.hs-vinyl {
  position: absolute;
  inset: 4%;
  border-radius: 50%;
  background: radial-gradient(circle, #1a1a1a 0%, #0c0c0c 50%, #060606 100%);
  animation: hs-spin 16s linear infinite;
  box-shadow: inset 0 0 40px rgba(0,0,0,.8), 0 0 30px rgba(0,0,0,.4);
}
@keyframes hs-spin { to { transform: rotate(360deg); } }

.hs-vinyl-grooves {
  position: absolute;
  inset: 4%;
  border-radius: 50%;
  background: repeating-radial-gradient(
    circle at 50%,
    transparent 0px, transparent 3px,
    rgba(255,255,255,.02) 3px, rgba(255,255,255,.02) 4px
  );
}
.hs-vinyl-sheen {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,.03) 45%, transparent 60%);
}

/* Vinyl label with LOGO */
.hs-vinyl-label {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 34%;
  height: 34%;
  border-radius: 50%;
  background: linear-gradient(145deg, var(--hs-gold) 0%, #c9a830 60%, #a88a20 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 0 30px rgba(232,197,71,.35), inset 0 -2px 6px rgba(0,0,0,.2);
  padding: 8%;
}
.hs-label-logo {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;
  filter: drop-shadow(0 1px 3px rgba(0,0,0,.3));
}

/* Tonearm */
.hs-arm {
  position: absolute;
  top: 6%;
  right: 8%;
  width: 45%;
  height: 55%;
  transform-origin: top right;
  animation: hs-arm-sway 7s ease-in-out infinite;
}
@keyframes hs-arm-sway {
  0%, 100% { transform: rotate(-6deg); }
  50% { transform: rotate(-2deg); }
}
.hs-arm-base {
  position: absolute;
  top: 0;
  right: 0;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #333;
  border: 2px solid rgba(232,197,71,.3);
}
.hs-arm-bar {
  position: absolute;
  top: 9px;
  right: 8px;
  width: 3px;
  height: 85%;
  background: linear-gradient(to bottom, rgba(232,197,71,.5), rgba(232,197,71,.15));
  border-radius: 2px;
  transform-origin: top;
  transform: rotate(-28deg);
}
.hs-arm-head {
  position: absolute;
  bottom: 5%;
  left: 15%;
  transform: rotate(-28deg);
}
.hs-arm-cartridge {
  width: 10px;
  height: 16px;
  background: #444;
  border-radius: 2px;
  box-shadow: 0 2px 4px rgba(0,0,0,.5);
}

.hs-glow {
  position: absolute;
  inset: -30px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,197,71,.05) 0%, transparent 65%);
  pointer-events: none;
}

/* Hero content */
.hs-hero-content {
  position: relative;
  z-index: 2;
  max-width: 660px;
}
.hs-hero-tag {
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--hs-mono);
  font-size: 12px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--hs-gold);
  margin-bottom: 28px;
}
.hs-tag-dash { display: block; width: 32px; height: 1px; background: var(--hs-gold); }

.hs-hero-h1 {
  font-family: var(--hs-display);
  font-size: clamp(36px, 5.5vw, 72px);
  font-weight: 400;
  line-height: 1;
  letter-spacing: -.02em;
  text-transform: uppercase;
  color: var(--hs-white);
  margin: 0 0 28px;
  white-space: nowrap;
}
.hs-h1-word { display: inline; }
.hs-h1-gold { color: var(--hs-gold); text-shadow: 0 0 40px rgba(232,197,71,.2); }
.hs-h1-rec { color: rgba(245,245,240,.7); }
.hs-reg { font-size: .35em; vertical-align: super; color: var(--hs-gold); opacity: .6; }

.hs-hero-sub {
  font-family: var(--hs-body);
  font-size: 15px;
  font-weight: 300;
  line-height: 1.75;
  color: var(--hs-grey);
  margin: 0 0 36px;
  max-width: 440px;
}

.hs-hero-actions {
  display: flex;
  align-items: center;
  gap: 36px;
  flex-wrap: wrap;
}

.hs-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--hs-gold);
  color: var(--hs-dark);
  font-family: var(--hs-mono);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 16px 28px;
  font-weight: 700;
  cursor: pointer;
  transition: background .25s, transform .25s, box-shadow .25s;
}
.hs-btn:hover {
  background: #f0d060;
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(232,197,71,.3);
}

.hs-stats { display: flex; align-items: center; gap: 20px; }
.hs-stat { display: flex; flex-direction: column; gap: 2px; }
.hs-stat-val { font-family: var(--hs-display); font-size: 24px; font-weight: 400; color: var(--hs-white); line-height: 1; }
.hs-stat-lbl { font-family: var(--hs-mono); font-size: 9px; letter-spacing: .15em; text-transform: uppercase; color: rgba(245,245,240,.3); }
.hs-stat-sep { width: 1px; height: 32px; background: rgba(245,245,240,.1); }

/* Scroll cue */
.hs-scroll {
  position: absolute;
  bottom: 30px; left: 60px;
  display: flex; align-items: center; gap: 12px;
  font-family: var(--hs-mono); font-size: 9px; letter-spacing: .15em; text-transform: uppercase; color: rgba(245,245,240,.2);
}
.hs-scroll-bar { width: 40px; height: 1px; background: rgba(245,245,240,.1); position: relative; overflow: hidden; }
.hs-scroll-fill { position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: var(--hs-gold); animation: hs-scr 2s ease infinite; }
@keyframes hs-scr { to { left: 100%; } }

/* ---- TICKER ---- */
.hs-ticker {
  background: var(--hs-gold);
  padding: 16px 0;
  overflow: hidden;
  white-space: nowrap;
}
.hs-ticker-track {
  display: flex;
  width: max-content;
  animation: hs-tick 22s linear infinite;
}
.hs-ticker-set {
  display: flex;
  align-items: center;
  gap: 20px;
  padding-right: 20px;
  flex-shrink: 0;
  font-family: var(--hs-display);
  font-size: 13px;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--hs-dark);
}
.hs-tdot { opacity: .25; font-size: 8px; }
@keyframes hs-tick { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* ---- STORY ---- */
.hs-story {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  min-height: 580px;
  background: var(--hs-dark);
}
@media(max-width:900px){.hs-story{grid-template-columns:1fr;}}

.hs-story-visual {
  background: var(--hs-navy);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  position: relative;
  border-right: 1px solid var(--hs-gold-dim);
}
@media(max-width:900px){.hs-story-visual{min-height:380px;border-right:none;border-bottom:1px solid var(--hs-gold-dim);}}

/* Vinyl sleeve */
.hs-sleeve {
  width: 220px;
  height: 220px;
  position: relative;
  z-index: 2;
}
.hs-sleeve-inner {
  width: 100%;
  height: 100%;
  background: var(--hs-dark);
  border: 1px solid rgba(232,197,71,.15);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  position: relative;
  overflow: hidden;
}
.hs-sleeve-logo {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,.4));
}
.hs-sleeve-edge {
  position: absolute;
  right: -3px;
  top: 4px;
  width: 3px;
  height: calc(100% - 8px);
  background: linear-gradient(to bottom, rgba(232,197,71,.1), rgba(232,197,71,.05));
  border-radius: 0 2px 2px 0;
}

/* Mini vinyl peeking out */
.hs-story-disc {
  position: absolute;
  right: 20%;
  bottom: 15%;
  z-index: 1;
}
.hs-mini-vinyl {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  background: radial-gradient(circle, #1a1a1a 0%, #080808 100%);
  animation: hs-spin 12s linear infinite;
  box-shadow: 0 0 30px rgba(0,0,0,.5);
  position: relative;
}
.hs-mini-grooves {
  position: absolute;
  inset: 6%;
  border-radius: 50%;
  background: repeating-radial-gradient(
    circle at 50%,
    transparent 0px, transparent 4px,
    rgba(255,255,255,.02) 4px, rgba(255,255,255,.02) 5px
  );
}
.hs-mini-label {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 30%;
  height: 30%;
  border-radius: 50%;
  background: var(--hs-gold);
}

.hs-story-text {
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
}
@media(max-width:768px){.hs-story-text{padding:48px 24px;}}

.hs-eyebrow {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--hs-mono);
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--hs-gold);
}
.hs-story-h2 {
  font-family: var(--hs-display);
  font-size: clamp(30px, 4vw, 48px);
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: -.02em;
  line-height: 1.05;
  color: var(--hs-white);
  margin: 0;
}
.hs-story-h2 em { font-style: normal; color: var(--hs-gold); }
.hs-story-p {
  font-family: var(--hs-body);
  font-size: 14px;
  font-weight: 300;
  line-height: 1.85;
  color: rgba(245,245,240,.6);
  max-width: 500px;
  margin: 0;
}
.hs-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.hs-tag {
  font-family: var(--hs-mono);
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 6px 14px;
  border: 1px solid var(--hs-gold-dim);
  color: var(--hs-gold-mid);
  transition: border-color .25s, color .25s;
  cursor: default;
}
.hs-tag:hover { border-color: var(--hs-gold); color: var(--hs-gold); }


/* ---- SHOP ---- */
.hs-shop { background: var(--hs-dark); padding: 80px 60px; }
@media(max-width:768px){.hs-shop{padding:48px 24px;}}
.hs-shop-inner { max-width: 1200px; margin: 0 auto; }
.hs-shop-head { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; margin-bottom: 48px; }
@media(max-width:768px){.hs-shop-head{grid-template-columns:1fr;}}
.hs-eyebrow-sm { font-family: var(--hs-mono); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--hs-gold); }
.hs-shop-h2 {
  font-family: var(--hs-display);
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: -.02em;
  line-height: 1;
  margin: 8px 0 0;
  color: var(--hs-white);
}
.hs-shop-desc { font-family: var(--hs-body); font-size: 13px; font-weight: 300; line-height: 1.75; color: rgba(245,245,240,.45); }
.hs-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
.hs-filter {
  font-family: var(--hs-mono);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: 9px 18px;
  border: 1px solid rgba(245,245,240,.2);
  background: transparent;
  color: var(--hs-white);
  cursor: pointer;
  transition: all .25s;
}
.hs-filter:hover, .hs-filter.active { background: var(--hs-gold); color: var(--hs-dark); border-color: var(--hs-gold); }

.hs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 24px;
}
.hs-prod {
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: transform .3s;
}
.hs-prod:hover { transform: translateY(-6px); }
.hs-prod[style*="display:none"] { display: none !important; }
.hs-prod-img {
  position: relative;
  overflow: hidden;
  background: #111;
  aspect-ratio: 1;
}
.hs-prod-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.hs-prod:hover .hs-prod-img img { transform: scale(1.06); }
.hs-prod-hover {
  position: absolute; inset: 0;
  background: rgba(8,8,26,.75);
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font-family: var(--hs-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--hs-gold);
  opacity: 0; transition: opacity .3s;
}
.hs-prod:hover .hs-prod-hover { opacity: 1; }
.hs-no-img {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--hs-mono); font-size: 11px; letter-spacing: .12em; color: #333; text-align: center; line-height: 1.6;
}
.hs-badge {
  position: absolute; top: 12px; right: 12px;
  font-family: var(--hs-mono); font-size: 9px; letter-spacing: .1em;
  background: var(--hs-gold); color: var(--hs-dark); padding: 4px 10px; font-weight: 700;
}
.hs-prod-info { padding: 16px 0; }
.hs-prod-type { font-family: var(--hs-mono); font-size: 9px; letter-spacing: .14em; text-transform: uppercase; color: var(--hs-gold); }
.hs-prod-name { font-family: var(--hs-body); font-size: 14px; font-weight: 400; color: var(--hs-white); margin: 6px 0 4px; }
.hs-prod-price { font-family: var(--hs-mono); font-size: 13px; color: var(--hs-grey); }
.hs-empty { grid-column: 1/-1; padding: 80px; text-align: center; font-family: var(--hs-mono); font-size: 11px; letter-spacing: .12em; color: #555; text-transform: uppercase; }

/* ---- CLOSING ---- */
.hs-closing {
  background: var(--hs-navy);
  padding: 100px 60px;
  position: relative;
  overflow: hidden;
}
@media(max-width:768px){.hs-closing{padding:60px 24px;}}

.hs-closing-waves {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.hs-cw {
  position: absolute;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(232,197,71,.06), transparent);
  animation: hs-groove-pulse 4s ease-in-out infinite;
  animation-delay: calc(var(--j) * .6s);
}
.hs-cw:nth-child(1) { top: 15%; }
.hs-cw:nth-child(2) { top: 30%; }
.hs-cw:nth-child(3) { top: 50%; }
.hs-cw:nth-child(4) { top: 70%; }
.hs-cw:nth-child(5) { top: 85%; }

.hs-closing-inner {
  display: flex;
  align-items: center;
  gap: 80px;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
@media(max-width:768px){.hs-closing-inner{flex-direction:column;gap:40px;text-align:center;}}

.hs-closing-discs {
  flex-shrink: 0;
  width: 200px;
  height: 200px;
  position: relative;
}
.hs-cd {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, #1a1a1a 0%, #060606 100%);
}
.hs-cd-back {
  width: 180px; height: 180px;
  bottom: 0; right: 0;
  opacity: .3;
  animation: hs-spin 20s linear infinite reverse;
}
.hs-cd-mid {
  width: 170px; height: 170px;
  bottom: 10px; right: 10px;
  opacity: .5;
  animation: hs-spin 16s linear infinite;
}
.hs-cd-front {
  width: 160px; height: 160px;
  top: 0; left: 0;
  animation: hs-spin 12s linear infinite;
  box-shadow: 0 0 40px rgba(232,197,71,.1);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hs-cd-logo {
  width: 40%;
  height: 40%;
  object-fit: contain;
  border-radius: 50%;
  position: relative;
  z-index: 1;
}
.hs-cd-front::before {
  content: '';
  position: absolute;
  inset: 5%;
  border-radius: 50%;
  background: repeating-radial-gradient(
    circle at 50%,
    transparent 0px, transparent 3px,
    rgba(255,255,255,.02) 3px, rgba(255,255,255,.02) 4px
  );
}
.hs-cd-front::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 36%;
  height: 36%;
  border-radius: 50%;
  background: var(--hs-gold);
  z-index: 0;
}

.hs-closing-text { flex: 1; }
.hs-closing-h2 {
  font-family: var(--hs-display);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: -.03em;
  line-height: 1.05;
  color: var(--hs-white);
  margin: 0 0 20px;
}
.hs-closing-text p {
  font-family: var(--hs-body);
  font-size: 14px;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(245,245,240,.55);
  margin: 0 0 32px;
}

/* ---- REDUCED MOTION ---- */
@media(prefers-reduced-motion:reduce){
  .hs-vinyl,.hs-mini-vinyl,.hs-cd,.hs-groove-line,.hs-cw,.hs-scroll-fill,.hs-ticker-track,.hs-arm{animation:none!important;}
  .hs-prod:hover{transform:none;}
}
</style>

<!-- ============================================================
     SCRIPTS — Motion.dev animations
     ============================================================ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  /* ---- Filters ---- */
  var filterBtns = document.querySelectorAll('.hs-filter');
  var cards = document.querySelectorAll('.hs-prod');
  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var f = this.dataset.filter;
      filterBtns.forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      cards.forEach(function(c) { c.style.display = (f === 'all' || c.dataset.filter === f) ? '' : 'none'; });
    });
  });

  /* ---- Motion.dev ---- */
  if (window.Motion) {
    var M = window.Motion;

    /* Hero entrance */
    M.animate('.hs-hero-tag', { opacity: [0,1], x: [-20,0] }, { duration: .7, delay: .3 });
    M.animate('.hs-hero-h1', { opacity: [0,1], y: [30,0] },
      { duration: .8, delay: .5, easing: [.22,1,.36,1] });
    M.animate('.hs-hero-sub', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: .9 });
    M.animate('.hs-hero-actions', { opacity: [0,1], y: [20,0] }, { duration: .7, delay: 1.1 });
    M.animate('.hs-turntable', { opacity: [0,1], scale: [.8,1] },
      { duration: 1.2, delay: .4, easing: [.22,1,.36,1] });

    /* Story */
    M.inView('.hs-story-visual', function() {
      M.animate('.hs-sleeve', { opacity: [0,1], x: [-30,0] },
        { duration: .8, easing: [.22,1,.36,1] });
      M.animate('.hs-story-disc', { opacity: [0,1], scale: [.7,1] },
        { duration: .8, delay: .2, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    M.inView('.hs-story-text', function() {
      M.animate('.hs-story-text > *', { opacity: [0,1], x: [40,0] },
        { delay: M.stagger(.1), duration: .7, easing: [.22,1,.36,1] });
    }, { margin: '-10% 0px' });

    /* Product cards */
    document.querySelectorAll('.hs-prod').forEach(function(card) {
      M.inView(card, function() {
        M.animate(card, { opacity: [0,1], y: [30,0] },
          { duration: .5, easing: [.22,1,.36,1] });
      }, { margin: '-5% 0px' });
    });

    /* Closing */
    M.inView('.hs-closing-inner', function() {
      M.animate('.hs-closing-discs', { opacity: [0,1], scale: [.7,1] },
        { duration: 1, easing: [.22,1,.36,1] });
      M.animate('.hs-closing-h2', { opacity: [0,1], y: [40,0] },
        { duration: .8, delay: .2, easing: [.22,1,.36,1] });
      M.animate('.hs-closing-text p', { opacity: [0,1], y: [20,0] },
        { duration: .6, delay: .4 });
      M.animate('.hs-closing-text .hs-btn', { opacity: [0,1], y: [20,0] },
        { duration: .6, delay: .5 });
    }, { margin: '-10% 0px' });
  }
});
</script>

