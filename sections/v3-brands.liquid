<section class="hand-sec" id="brands">
  <div class="hand-container">
    <div class="hand-sec-head">
      <div class="lhs">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="rhs">
        <p>{{ section.settings.subtext }}</p>
        <a class="more" href="{{ section.settings.link | default: '/collections' }}">{{ section.settings.link_label }} &#8594;</a>
      </div>
    </div>

    <div class="hand-roster">
      {% for block in section.blocks %}
        {% if block.type == 'brand' %}
          {%- comment -%} Map brand name to logo asset {%- endcomment -%}
          {%- assign brand_lower = block.settings.name | downcase -%}
          {%- assign logo_file = '' -%}
          {%- if brand_lower contains 'have a nice' -%}{%- assign logo_file = 'logo-have-a-nice-day.png' -%}
          {%- elsif brand_lower contains 'dready' -%}{%- assign logo_file = 'logo-dready.png' -%}
          {%- elsif brand_lower contains 'handspun' -%}{%- assign logo_file = 'logo-handspun.png' -%}
          {%- elsif brand_lower contains 'btka' -%}{%- assign logo_file = 'logo-btka.png' -%}
          {%- elsif brand_lower contains 'vortex' -%}{%- assign logo_file = 'logo-vortex.png' -%}
          {%- elsif brand_lower contains 'funky' -%}{%- assign logo_file = 'logo-funky-dog.png' -%}
          {%- elsif brand_lower contains 'dodo' -%}{%- assign logo_file = 'logo-dodo.png' -%}
          {%- elsif brand_lower contains 'incubator' -%}{%- assign logo_file = 'logo-incubator.png' -%}
          {%- elsif brand_lower contains 'sista' -%}{%- assign logo_file = 'logo-sista.png' -%}
          {%- endif -%}

          <a href="{{ block.settings.link | default: '/collections/all' }}" class="{{ block.settings.style }}" {{ block.shopify_attributes }}>
            <span class="num">{{ block.settings.number }}</span>
            <span class="arrow">&#8599;</span>
            {% if logo_file != '' %}
              <div class="brand-logo-wrap">
                <img class="brand-logo" src="{{ logo_file | asset_url }}" alt="{{ block.settings.name }} logo" loading="lazy" />
              </div>
            {% endif %}
            <div class="brand-text">
              <div class="name">{{ block.settings.name }}</div>
              <div class="desc">{{ block.settings.desc }}</div>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* === BRAND ROSTER — Logo-first cards === */
  .hand-roster a {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 24px 28px;
    min-height: 280px;
  }

  /* Number badge — top-left, small */
  .hand-roster a .num {
    position: absolute;
    top: 16px;
    left: 18px;
    z-index: 2;
  }

  /* Arrow — top-right */
  .hand-roster a .arrow {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
  }

  /* Logo wrapper — takes up bulk of card space */
  .brand-logo-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 16px 10px 8px;
  }

  .brand-logo {
    width: 100%;
    max-width: 160px;
    max-height: 140px;
    object-fit: contain;
    opacity: 1;
    transition: opacity .4s ease, transform .4s ease;
  }

  /* All cards — show logos as-is, no filters */
  .hand-roster a:hover .brand-logo {
    transform: scale(1.06);
  }

  /* Text block — centered at bottom */
  .brand-text {
    width: 100%;
    text-align: center;
    margin-top: auto;
    padding-top: 8px;
  }

  .brand-text .name {
    font-size: 22px;
    margin-top: 0;
  }

  .brand-text .desc {
    margin-top: 6px;
  }

  @media (max-width: 820px) {
    .hand-roster a { min-height: 220px; padding: 20px 18px 24px; }
    .brand-logo { max-width: 120px; max-height: 110px; }
    .brand-text .name { font-size: 18px; }
  }

  @media (max-width: 520px) {
    .hand-roster a { min-height: 200px; }
    .brand-logo { max-width: 100px; max-height: 90px; }
  }
</style>

{% schema %}
{
  "name": "V3 Brands",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Family — 09 Sub-Brands" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "One HAND HQ.\n9 Identities." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Have A Nice Day was always more than one logo. Each sub-brand is its own world — born out of music, scene, and 30+ years of underground London." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Browse All Brands" },
    { "type": "url", "id": "link", "label": "Link" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "01 / Flagship" },
        { "type": "text", "id": "name", "label": "Brand name", "default": "Have A Nice Day" },
        { "type": "text", "id": "desc", "label": "Description", "default": "Sam The Man · Shurl The Girl" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "select", "id": "style", "label": "Style", "options": [
          { "value": "", "label": "Default" },
          { "value": "featured", "label": "Featured (dark)" },
          { "value": "accent", "label": "Accent (pink)" }
        ], "default": "" }
      ]
    }
  ],
  "presets": [
    {
      "name": "V3 Brands",
      "blocks": [
        { "type": "brand", "settings": { "number": "01 / Flagship", "name": "Have A Nice Day", "desc": "Sam The Man · Shurl The Girl", "style": "featured" } },
        { "type": "brand", "settings": { "number": "02", "name": "Dready OG", "desc": "Roots · Reggae · Camden", "style": "" } },
        { "type": "brand", "settings": { "number": "03", "name": "Handspun Records", "desc": "Vinyl · Sound · Wax", "style": "accent" } },
        { "type": "brand", "settings": { "number": "04", "name": "BTKA", "desc": "Punk Rocks · Sleazy Rider", "style": "" } },
        { "type": "brand", "settings": { "number": "05", "name": "Vortex", "desc": "Info The Robot · Close Encounter", "style": "" } },
        { "type": "brand", "settings": { "number": "06", "name": "Funky Dog", "desc": "Atomic Dog · Mongrel Soup", "style": "" } },
        { "type": "brand", "settings": { "number": "07", "name": "Don't Do The Dodo", "desc": "Professor Watercooler · Crest", "style": "" } },
        { "type": "brand", "settings": { "number": "08", "name": "Incubator", "desc": "Divergent · Outside The Box", "style": "" } },
        { "type": "brand", "settings": { "number": "09", "name": "Sista", "desc": "Script · Silhouette · Slip Mats", "style": "accent" } }
      ]
    }
  ]
}
{% endschema %}
