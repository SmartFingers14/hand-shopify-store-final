<section class="hand-sec" id="shop">
  <div class="hand-container">
    <div class="hand-sec-head">
      <div class="lhs">
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="rhs">
        <p>{{ section.settings.subtext }}</p>
        <a class="more" href="{{ section.settings.view_all_link | default: '/collections/all' }}">{{ section.settings.view_all_label | default: 'Shop All Products' }} &#8594;</a>
      </div>
    </div>

    {%- comment -%}
      Build a pool of products from multiple brand collections.
      We collect up to 32 products (4 pages of 8) for rotation.
    {%- endcomment -%}
    {%- assign brand_handles = 'have-a-nice-day,t-shirts,hoodies,sweatshirts,btka,vortex,funky-dog,dready-original,dont-do-the-dodo,handspun-records,accessories' | split: ',' -%}
    {%- assign per_page = section.settings.product_count | default: 8 -%}
    {%- assign seen_ids = '' -%}
    {%- assign pool_count = 0 -%}
    {%- assign max_pool = 32 -%}

    <div class="hand-products-rotator" data-interval="6000" data-per-page="{{ per_page }}">
      {%- for col_handle in brand_handles -%}
        {%- assign col = collections[col_handle] -%}
        {%- if col -%}
          {%- for product in col.products limit: 6 -%}
            {%- assign pid_str = product.id | append: ',' -%}
            {%- unless seen_ids contains pid_str -%}
              {%- assign seen_ids = seen_ids | append: pid_str -%}
              {%- assign page_index = pool_count | divided_by: per_page -%}
              <a class="hand-card hand-reveal hand-rotate-card" data-rotate-page="{{ page_index }}" href="{{ product.url }}"{% if page_index > 0 %} style="display:none"{% endif %}>
                <div class="imgwrap">
                  <span class="tag">{{ product.type | default: 'New' }}</span>
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | default: product.title }}" loading="lazy" />
                  {% else %}
                    <div style="width:100%;height:340px;background:#111;display:flex;align-items:center;justify-content:center;">
                      <span style="color:#444;font-family:monospace;font-size:11px;letter-spacing:.1em;">NO IMAGE</span>
                    </div>
                  {% endif %}
                  <span class="quick">Quick Add &#8594;</span>
                </div>
                <div class="body">
                  <div class="name">{{ product.title }}</div>
                  <div class="row2">
                    <div class="price">{{ product.price | money }}</div>
                    <div class="swatches">
                      {% for variant in product.variants limit: 4 %}
                        {% if variant.option1 contains '#' %}
                          <span class="sw" style="background:{{ variant.option1 }}"></span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </div>
              </a>
              {%- assign pool_count = pool_count | plus: 1 -%}
              {%- if pool_count >= max_pool -%}{%- break -%}{%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if pool_count >= max_pool -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .hand-products-rotator {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--ink);
    border: 1px solid var(--ink);
  }
  .hand-rotate-card {
    will-change: transform, opacity;
  }
  @media (max-width:1100px) {
    .hand-products-rotator { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width:820px) {
    .hand-products-rotator { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width:520px) {
    .hand-products-rotator { grid-template-columns: 1fr; }
  }
</style>

<!-- GSAP for premium animations -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Wait for GSAP to load
    function initRotator() {
      if (typeof gsap === 'undefined') {
        return setTimeout(initRotator, 100);
      }

      var rotator = document.querySelector('.hand-products-rotator');
      if (!rotator) return;

      var intervalMs = parseInt(rotator.dataset.interval) || 6000;
      var cards = rotator.querySelectorAll('.hand-rotate-card');
      if (cards.length === 0) return;

      // Find max page index
      var maxPage = 0;
      cards.forEach(function(c) {
        var p = parseInt(c.dataset.rotatePage) || 0;
        if (p > maxPage) maxPage = p;
      });

      if (maxPage === 0) return;

      var currentPage = 0;
      var isAnimating = false;

      function getPageCards(pageNum) {
        return Array.from(cards).filter(function(c) {
          return parseInt(c.dataset.rotatePage) === pageNum;
        });
      }

      function showPage(pageNum) {
        if (isAnimating) return;
        isAnimating = true;

        var oldCards = getPageCards(currentPage);
        var newCards = getPageCards(pageNum);

        // Premium exit: stagger scale down + fade + slide up
        gsap.to(oldCards, {
          opacity: 0,
          y: -40,
          scale: 0.92,
          duration: 0.5,
          stagger: 0.04,
          ease: 'power2.inOut',
          onComplete: function() {
            oldCards.forEach(function(c) { c.style.display = 'none'; });

            // Prepare new cards offscreen
            newCards.forEach(function(c) {
              c.style.display = '';
            });
            gsap.set(newCards, { opacity: 0, y: 50, scale: 0.95 });

            // Premium enter: stagger slide up + scale + fade in
            gsap.to(newCards, {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.65,
              stagger: 0.06,
              ease: 'power3.out',
              clearProps: 'transform',
              onComplete: function() {
                currentPage = pageNum;
                isAnimating = false;
              }
            });
          }
        });
      }

      setInterval(function() {
        var next = (currentPage + 1) > maxPage ? 0 : currentPage + 1;
        showPage(next);
      }, intervalMs);
    }

    initRotator();
  });
</script>

{% schema %}
{
  "name": "V3 Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Reissues" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Heritage Hits." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Eight pieces from across the family — pulled from the original 1990 archive, printed in small UK batches on 220gsm organic cotton." },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Shop All Products" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    { "type": "collection", "id": "collection", "label": "Collection (optional — overrides auto-display)" },
    { "type": "range", "id": "product_count", "min": 4, "max": 12, "step": 1, "label": "Products per page", "default": 8 }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Product image" },
        { "type": "text", "id": "tag", "label": "Tag label", "default": "Reissue" },
        { "type": "checkbox", "id": "tag_pink", "label": "Pink tag?", "default": false },
        { "type": "text", "id": "vendor", "label": "Brand / Vendor", "default": "Have A Nice Day" },
        { "type": "text", "id": "title", "label": "Product title", "default": "Sam The Man Front Print T-Shirt" },
        { "type": "text", "id": "price", "label": "Price", "default": "£29.99" },
        { "type": "url", "id": "link", "label": "Product link" },
        { "type": "color", "id": "swatch1", "label": "Swatch 1" },
        { "type": "color", "id": "swatch2", "label": "Swatch 2" },
        { "type": "color", "id": "swatch3", "label": "Swatch 3" }
      ]
    }
  ],
  "presets": [
    {
      "name": "V3 Products"
    }
  ]
}
{% endschema %}
