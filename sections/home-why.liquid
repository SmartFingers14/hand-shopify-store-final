<section style="background:#87CEEB;color:#000;padding:80px 24px;border-bottom:6px solid #000">
  <div style="max-width:1400px;margin:0 auto">
    <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:24px;margin-bottom:50px">
      <div>
        <p style="font-family:'Bungee',sans-serif;font-size:11px;letter-spacing:.22em;text-transform:uppercase">{{ section.settings.eyebrow }}</p>
        <h2 style="font-family:'Fjalla One',sans-serif;font-size:clamp(36px,6vw,72px);text-transform:uppercase;line-height:.95;margin-top:10px">
          {{ section.settings.heading_pre }}
          <span style="background:#000;color:#FFD400;padding:0 12px">{{ section.settings.heading_em }}</span>
        </h2>
      </div>
      <p style="max-width:380px;font-size:15px;line-height:1.5">{{ section.settings.subhead }}</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px">
      {%- for block in section.blocks -%}
        <div style="background:#F5F1E8;border:2px solid #000;border-radius:14px;padding:28px 22px" {{ block.shopify_attributes }}>
          <div style="font-family:'Fjalla One',sans-serif;font-size:42px;line-height:1">{{ block.settings.icon }}</div>
          <h4 style="font-family:'Fjalla One',sans-serif;font-size:22px;text-transform:uppercase;margin:18px 0 8px">{{ block.settings.title }}</h4>
          <p style="font-size:14px;line-height:1.5;color:#444">{{ block.settings.body }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home why",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why HAND" },
    { "type": "text", "id": "heading_pre", "label": "Heading start", "default": "Not just clothes." },
    { "type": "text", "id": "heading_em", "label": "Highlighted", "default": "A culture." }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        { "type": "text", "id": "icon",  "label": "Icon (text/emoji)", "default": "☻" },
        { "type": "text", "id": "title", "label": "Title", "default": "100% Organic Cotton" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "GOTS-certified, never chemically treated. Heavyweight, butter-soft, gets better with every wash." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home why",
      "blocks": [
        { "type": "perk", "settings": { "icon": "🌱", "title": "100% Organic Cotton", "body": "GOTS-certified, never chemically treated. Heavyweight, butter-soft, ages well." } },
        { "type": "perk", "settings": { "icon": "☻",  "title": "The Original Smiley", "body": "Worn by Camden ravers since 1990. The same hand-drawn icon, the same energy." } },
        { "type": "perk", "settings": { "icon": "U",  "title": "Unisex By Design",     "body": "Cut to fit anyone. Worn loud by everyone. No gendered nonsense." } },
        { "type": "perk", "settings": { "icon": "9",  "title": "One House. 9 Worlds.", "body": "From Sam to Sista to Funky Dog — nine sub-brands, infinite combinations." } }
      ]
    }
  ]
}
{% endschema %}
