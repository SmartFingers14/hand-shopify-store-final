<style>
  .hand-pdp {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 48px 32px 80px;
  }
  .hand-pdp-breadcrumb {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hand-pdp-breadcrumb a { color: #888; text-decoration: none; transition: color .2s; }
  .hand-pdp-breadcrumb a:hover { color: var(--ink); }
  .hand-pdp-breadcrumb span { opacity: .4; }

  .hand-pdp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  /* Gallery */
  .hand-pdp-gallery { position: sticky; top: 100px; }
  .hand-pdp-main-img {
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--paper-2);
    border: 1px solid rgba(0,0,0,.1);
    position: relative;
  }
  .hand-pdp-main-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s cubic-bezier(.2,.7,.2,1);
    cursor: zoom-in;
  }
  .hand-pdp-main-img:hover img { transform: scale(1.04); }
  .hand-pdp-thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    margin-top: 12px;
  }
  .hand-pdp-thumb {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: var(--paper-2);
    border: 1.5px solid transparent;
    cursor: pointer;
    transition: border-color .2s;
  }
  .hand-pdp-thumb.active { border-color: var(--ink); }
  .hand-pdp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }
  .hand-pdp-thumb:hover img { transform: scale(1.06); }

  /* Info panel */
  .hand-pdp-info { display: flex; flex-direction: column; gap: 0; }
  .hand-pdp-vendor {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hand-pdp-vendor::before {
    content: '';
    width: 24px;
    height: 1px;
    background: #888;
  }
  .hand-pdp-title {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(32px, 4vw, 56px);
    text-transform: uppercase;
    line-height: .95;
    letter-spacing: -.005em;
    margin-bottom: 20px;
  }
  .hand-pdp-price-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(0,0,0,.1);
  }
  .hand-pdp-price {
    font-family: var(--mono);
    font-size: 26px;
    letter-spacing: .02em;
    color: var(--ink);
  }
  .hand-pdp-compare {
    font-family: var(--mono);
    font-size: 16px;
    text-decoration: line-through;
    color: #aaa;
  }
  .hand-pdp-save {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .16em;
    text-transform: uppercase;
    background: var(--pink);
    color: #fff;
    padding: 4px 10px;
  }

  /* Options */
  .hand-pdp-option { margin-bottom: 22px; }
  .hand-pdp-option-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .hand-pdp-option-label .selected-val {
    color: var(--ink);
    font-weight: 600;
  }
  .hand-pdp-sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .hand-size-btn {
    min-width: 52px;
    height: 44px;
    padding: 0 14px;
    border: 1.5px solid rgba(0,0,0,.2);
    background: transparent;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink);
    cursor: pointer;
    transition: border-color .2s, background .2s, color .2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hand-size-btn:hover { border-color: var(--ink); }
  .hand-size-btn.selected {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
  }
  .hand-size-btn.unavailable {
    opacity: .35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Size guide */
  .hand-size-guide-link {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #888;
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: 0;
    padding: 0;
    transition: color .2s;
  }
  .hand-size-guide-link:hover { color: var(--ink); }

  /* Add to cart */
  .hand-pdp-cta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    margin-top: 24px;
    margin-bottom: 20px;
  }
  .hand-pdp-qty {
    display: flex;
    align-items: center;
    border: 1.5px solid rgba(0,0,0,.2);
    height: 54px;
  }
  .hand-pdp-qty button {
    width: 44px;
    height: 100%;
    font-size: 18px;
    color: var(--ink);
    background: none;
    border: 0;
    cursor: pointer;
    transition: background .2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hand-pdp-qty button:hover { background: rgba(0,0,0,.06); }
  .hand-pdp-qty input {
    width: 44px;
    height: 100%;
    text-align: center;
    border: 0;
    border-left: 1px solid rgba(0,0,0,.1);
    border-right: 1px solid rgba(0,0,0,.1);
    background: transparent;
    font-family: var(--mono);
    font-size: 14px;
    color: var(--ink);
    outline: none;
  }
  .hand-pdp-add-btn {
    height: 54px;
    background: var(--ink);
    color: #fff;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .2em;
    text-transform: uppercase;
    font-weight: 600;
    border: 0;
    cursor: pointer;
    transition: background .25s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .hand-pdp-add-btn:hover { background: var(--pink); }
  .hand-pdp-add-btn:disabled { opacity: .5; cursor: not-allowed; }

  /* Trust strip */
  .hand-pdp-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(0,0,0,.1);
    border: 1px solid rgba(0,0,0,.1);
    margin-bottom: 24px;
  }
  .hand-pdp-trust-item {
    background: var(--paper);
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #666;
  }
  .hand-pdp-trust-item .icon { font-size: 16px; }

  /* Description */
  .hand-pdp-desc-toggle {
    border-top: 1px solid rgba(0,0,0,.1);
    padding: 18px 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink);
    background: none;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
    width: 100%;
    text-align: left;
    transition: color .2s;
  }
  .hand-pdp-desc-toggle:hover { color: var(--pink); }
  .hand-pdp-desc-toggle .arr { transition: transform .3s; }
  .hand-pdp-desc-toggle.open .arr { transform: rotate(180deg); }
  .hand-pdp-desc-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height .4s cubic-bezier(.22,1,.36,1);
  }
  .hand-pdp-desc-body.open { max-height: 600px; }
  .hand-pdp-desc-body-inner {
    padding: 0 0 20px;
    font-size: 14.5px;
    line-height: 1.7;
    color: #444;
  }
  .hand-pdp-desc-body-inner p { margin-bottom: 12px; }

  /* Related products */
  .hand-pdp-related {
    padding: 60px 32px 80px;
    border-top: 1px solid rgba(0,0,0,.1);
    background: var(--paper-2);
  }
  .hand-pdp-related-inner { max-width: var(--maxw); margin: 0 auto; }
  .hand-pdp-related-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .hand-pdp-related-head h2 {
    font-family: 'Anton', Impact, sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    line-height: .95;
  }
  .hand-pdp-related-head a {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #888;
    text-decoration: none;
    transition: color .2s;
  }
  .hand-pdp-related-head a:hover { color: var(--pink); }
  .hand-pdp-related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    background: transparent;
    border: none;
  }
  /* Related product cards — full styling */
  .hand-pdp-related-grid .hand-coll-card {
    background: var(--paper);
    border: 1px solid rgba(0,0,0,.08);
    overflow: hidden;
    transition: box-shadow .3s;
  }
  .hand-pdp-related-grid .hand-coll-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
  }
  .hand-pdp-related-grid .hand-coll-card-media {
    aspect-ratio: 3/4;
    overflow: hidden;
    position: relative;
    background: var(--paper-2);
  }
  .hand-pdp-related-grid .hand-coll-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s cubic-bezier(.2,.7,.2,1);
  }
  .hand-pdp-related-grid .hand-coll-card:hover .hand-coll-card-media img {
    transform: scale(1.04);
  }
  .hand-pdp-related-grid .hand-coll-badge {
    position: absolute; top: 12px; left: 12px; z-index: 2;
    font-family: var(--mono); font-size: 9px; letter-spacing: .16em;
    text-transform: uppercase; background: var(--ink); color: #fff;
    padding: 4px 10px;
  }
  .hand-pdp-related-grid .hand-coll-quick {
    position: absolute; bottom: 0; left: 0; right: 0; z-index: 2;
    display: flex; gap: 1px;
    transform: translateY(100%);
    transition: transform .3s ease;
  }
  .hand-pdp-related-grid .hand-coll-card:hover .hand-coll-quick {
    transform: translateY(0);
  }
  .hand-pdp-related-grid .hand-coll-quick-btn {
    flex: 1; padding: 12px; border: 0; cursor: pointer;
    background: var(--ink); color: #fff;
    font-family: var(--mono); font-size: 10px; letter-spacing: .16em;
    text-transform: uppercase; font-weight: 600;
    transition: background .2s;
  }
  .hand-pdp-related-grid .hand-coll-quick-btn:hover { background: var(--pink); }
  .hand-pdp-related-grid .hand-coll-quick-link {
    padding: 12px 16px; background: var(--ink); color: #fff;
    text-decoration: none; font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
  }
  .hand-pdp-related-grid .hand-coll-quick-link:hover { background: var(--pink); }
  .hand-pdp-related-grid .hand-coll-card-info {
    padding: 16px;
  }
  .hand-pdp-related-grid .hand-coll-card-vendor {
    font-family: var(--mono); font-size: 9px; letter-spacing: .16em;
    text-transform: uppercase; color: #999; margin-bottom: 6px;
  }
  .hand-pdp-related-grid .hand-coll-card-name {
    font-family: 'Anton', Impact, sans-serif; font-size: 16px;
    text-transform: uppercase; line-height: 1.1;
    color: var(--ink); text-decoration: none;
    display: block; margin-bottom: 8px;
    transition: color .2s;
  }
  .hand-pdp-related-grid .hand-coll-card-name:hover { color: var(--pink); }
  .hand-pdp-related-grid .hand-coll-card-price {
    font-family: var(--mono); font-size: 14px; color: var(--ink);
  }

  @media (max-width: 1100px) {
    .hand-pdp-related-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 820px) {
    .hand-pdp { padding: 32px 22px 60px; }
    .hand-pdp-grid { grid-template-columns: 1fr; gap: 32px; }
    .hand-pdp-gallery { position: static; }
    .hand-pdp-related { padding: 40px 22px 60px; }
    .hand-pdp-related-grid { grid-template-columns: repeat(2, 1fr); }
    .hand-pdp-cta { grid-template-columns: auto 1fr; }
  }
  @media (max-width: 520px) {
    .hand-pdp-related-grid { grid-template-columns: 1fr; }
    .hand-pdp-thumbs { grid-template-columns: repeat(4, 1fr); }
  }

  /* ============================================================
     NEW: Social Proof — Stars + Viewers
     ============================================================ */
  .hand-pdp-social {
    display: flex; align-items: center; gap: 18px; flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .hand-pdp-stars { display: flex; align-items: center; gap: 6px; }
  .star-fill { color: #F59E0B; font-size: 15px; letter-spacing: 1px; }
  .star-half { color: #F59E0B; font-size: 15px; opacity: .5; }
  .star-count { font-family: var(--mono); font-size: 13px; font-weight: 700; color: var(--ink); }
  .star-reviews { font-family: var(--mono); font-size: 11px; color: #888; text-decoration: underline; cursor: pointer; }
  .hand-pdp-viewers {
    display: flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: 10px; letter-spacing: .1em;
    text-transform: uppercase; color: #888;
  }
  .viewer-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #22C55E;
    animation: pdp-pulse 2s ease-in-out infinite;
  }
  @keyframes pdp-pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }

  /* ============================================================
     NEW: Urgency — Low stock + Sold count
     ============================================================ */
  .hand-pdp-urgency {
    display: flex; flex-direction: column; gap: 8px;
    margin-bottom: 18px; padding: 14px 18px;
    background: #FEF3C7; border: 1px solid #FDE68A; border-radius: 0;
  }
  .hand-pdp-stock-warn, .hand-pdp-sold-recent {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--mono); font-size: 11px; letter-spacing: .08em;
    color: #92400E;
  }
  .hand-pdp-stock-warn svg { color: #F59E0B; flex-shrink: 0; }
  .hand-pdp-sold-recent svg { color: #D97706; flex-shrink: 0; }
  .hand-pdp-stock-warn strong { color: #B91C1C; }

  /* ============================================================
     NEW: SVG trust icons
     ============================================================ */
  .trust-icon { flex-shrink: 0; color: var(--ink); opacity: .55; }

  /* ============================================================
     NEW: Buy Now button
     ============================================================ */
  .hand-pdp-buy-now {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 48px;
    background: transparent; color: var(--ink);
    font-family: var(--mono); font-size: 11px; letter-spacing: .18em;
    text-transform: uppercase; font-weight: 600;
    border: 1.5px solid var(--ink); text-decoration: none;
    cursor: pointer; transition: all .25s; margin-bottom: 18px;
  }
  .hand-pdp-buy-now:hover { background: var(--ink); color: #fff; }

  /* ============================================================
     NEW: Estimated delivery
     ============================================================ */
  .hand-pdp-delivery {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--mono); font-size: 11px; letter-spacing: .08em; color: #666;
    padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,.08);
    margin-bottom: 14px;
  }
  .hand-pdp-delivery svg { color: #22C55E; flex-shrink: 0; }
  .hand-pdp-delivery strong { color: var(--ink); }

  /* ============================================================
     NEW: Payment icons
     ============================================================ */
  .hand-pdp-payments {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 24px; padding-bottom: 20px;
    border-bottom: 1px solid rgba(0,0,0,.08);
  }
  .pay-label {
    font-family: var(--mono); font-size: 9px; letter-spacing: .14em;
    text-transform: uppercase; color: #aaa; white-space: nowrap;
  }
  .pay-icons { display: flex; gap: 6px; }
  .pay-icon {
    display: flex; align-items: center; justify-content: center;
    min-width: 38px; height: 24px; padding: 0 6px;
    background: #f5f5f5; border: 1px solid #e5e5e5;
    font-family: var(--mono); font-size: 8px; font-weight: 700;
    letter-spacing: .06em; color: #555; text-transform: uppercase;
  }
  .pay-klarna { background: #FFB3C7; color: #000; border-color: #FFB3C7; }

  /* ============================================================
     NEW: Sticky Mobile CTA
     ============================================================ */
  .hand-pdp-sticky {
    display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 900;
    background: var(--paper); border-top: 1px solid rgba(0,0,0,.12);
    padding: 12px 16px; box-shadow: 0 -4px 20px rgba(0,0,0,.08);
  }
  .hand-pdp-sticky-inner {
    display: flex; align-items: center; gap: 12px; max-width: 600px; margin: 0 auto;
  }
  .hand-pdp-sticky-info { flex: 1; min-width: 0; }
  .hand-pdp-sticky-title {
    font-family: 'Anton', Impact, sans-serif; font-size: 14px;
    text-transform: uppercase; line-height: 1; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis;
  }
  .hand-pdp-sticky-price { font-family: var(--mono); font-size: 14px; color: var(--ink); }
  .hand-pdp-sticky-btn {
    height: 44px; padding: 0 24px; flex-shrink: 0;
    background: var(--ink); color: #fff;
    font-family: var(--mono); font-size: 11px; letter-spacing: .16em;
    text-transform: uppercase; font-weight: 600; border: 0; cursor: pointer;
    transition: background .2s;
  }
  .hand-pdp-sticky-btn:hover { background: var(--pink); }
  @media (max-width: 820px) {
    .hand-pdp-sticky.visible { display: block; }
    .hand-pdp { padding-bottom: 120px; }
  }
</style>

<div class="hand-pdp">
  <!-- Breadcrumb -->
  <nav class="hand-pdp-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span>/</span>
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span>/</span>
    {%- else -%}
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      <span>/</span>
    {%- endif -%}
    <span style="color:var(--ink)">{{ product.title | truncate: 40 }}</span>
  </nav>

  <div class="hand-pdp-grid">
    <!-- Gallery -->
    <div class="hand-pdp-gallery">
      <div class="hand-pdp-main-img" id="pdpMainImg">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}"
               alt="{{ product.featured_image.alt | escape | default: product.title | escape }}"
               id="pdpMainImgEl"
               loading="eager"
               width="1200" height="1600">
        {%- else -%}
          <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:'Anton',sans-serif;font-size:64px;color:rgba(0,0,0,.1)">☻</div>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="hand-pdp-thumbs">
          {%- for img in product.images limit: 10 -%}
            <div class="hand-pdp-thumb{% if forloop.first %} active{% endif %}"
                 data-src="{{ img | image_url: width: 1200 }}"
                 data-alt="{{ img.alt | escape | default: product.title | escape }}"
                 onclick="pdpSetImg(this)">
              <img src="{{ img | image_url: width: 200 }}"
                   alt="{{ img.alt | escape | default: product.title | escape }}"
                   loading="lazy">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="hand-pdp-info">
      <div class="hand-pdp-vendor">{{ product.vendor | default: 'Have A Nice Day' }} · {{ product.type | default: 'Apparel' }}</div>
      <h1 class="hand-pdp-title">{{ product.title }}</h1>

      <!-- Social proof: Rating + Views -->
      <div class="hand-pdp-social">
        <div class="hand-pdp-stars">
          <span class="star-fill">★★★★</span><span class="star-half">★</span>
          <span class="star-count">4.8</span>
          <span class="star-reviews">({{ product.id | modulo: 47 | plus: 12 }} reviews)</span>
        </div>
        <div class="hand-pdp-viewers" id="pdpViewers">
          <span class="viewer-dot"></span>
          <span id="viewerCount">{{ product.id | modulo: 8 | plus: 3 }}</span> people viewing now
        </div>
      </div>

      <!-- Price -->
      <div class="hand-pdp-price-row">
        {%- if product.compare_at_price > product.price -%}
          <span class="hand-pdp-compare">{{ product.compare_at_price | money }}</span>
          <span class="hand-pdp-price" style="color:var(--pink)">{{ product.price | money }}</span>
          {%- assign savings = product.compare_at_price | minus: product.price -%}
          <span class="hand-pdp-save">Save {{ savings | money }}</span>
        {%- else -%}
          <span class="hand-pdp-price">
            {%- if product.price_varies -%}<span style="font-size:14px;opacity:.6;margin-right:4px">From</span>{%- endif -%}
            {{ product.price | money }}
          </span>
        {%- endif -%}
      </div>

      <!-- Product form -->
      {%- form 'product', product, id: 'pdpForm', class: 'pdp-form' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="hand-pdp-option">
              <div class="hand-pdp-option-label">
                {{ option.name }}
                <span class="selected-val" id="optVal{{ forloop.index }}">{{ option.selected_value }}</span>
              </div>
              {%- if option.name == 'Size' or option.name == 'size' -%}
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
                  <div class="hand-pdp-sizes" id="sizeGrid{{ forloop.index }}">
                    {%- for value in option.values -%}
                      <button type="button"
                              class="hand-size-btn{% if option.selected_value == value %} selected{% endif %}"
                              data-option-index="{{ forloop.parentloop.index0 }}"
                              data-option-value="{{ value | escape }}"
                              data-option-label-id="optVal{{ forloop.parentloop.index }}"
                              onclick="pdpSelectOption(this)">
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                  <button type="button" class="hand-size-guide-link" onclick="document.getElementById('pdpSizeGuide').classList.toggle('open')">Size Guide</button>
                </div>
                <!-- Size guide accordion -->
                <div id="pdpSizeGuide" style="overflow:hidden;max-height:0;transition:max-height .4s ease">
                  <div style="background:var(--paper-2);padding:20px;margin-bottom:16px;font-family:var(--mono);font-size:11px;letter-spacing:.12em">
                    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:rgba(0,0,0,.1);border:1px solid rgba(0,0,0,.1)">
                      {%- assign sizes = 'XS,S,M,L,XL,XXL' | split: ',' -%}
                      {%- assign chests = '32-34,34-36,36-38,38-40,40-42,42-44' | split: ',' -%}
                      <div style="background:var(--ink);color:#fff;padding:8px;text-align:center;font-weight:600">Size</div>
                      <div style="background:var(--ink);color:#fff;padding:8px;text-align:center;font-weight:600">Chest</div>
                      <div style="background:var(--ink);color:#fff;padding:8px;text-align:center;font-weight:600">Length</div>
                      <div style="background:var(--ink);color:#fff;padding:8px;text-align:center;font-weight:600">Sleeve</div>
                      <div style="background:var(--ink);color:#fff;padding:8px;text-align:center;font-weight:600">Fit</div>
                      {%- for s in sizes -%}
                        <div style="background:var(--paper);padding:8px;text-align:center">{{ s }}</div>
                        <div style="background:var(--paper);padding:8px;text-align:center">{{ chests[forloop.index0] }}"</div>
                        <div style="background:var(--paper);padding:8px;text-align:center">{{ 26 | plus: forloop.index0 }}"</div>
                        <div style="background:var(--paper);padding:8px;text-align:center">{{ 31 | plus: forloop.index0 }}"</div>
                        <div style="background:var(--paper);padding:8px;text-align:center">Unisex</div>
                      {%- endfor -%}
                    </div>
                    <p style="margin-top:12px;color:#888;font-size:10px;letter-spacing:.14em">All measurements in inches. Unisex fit — size up for oversized look.</p>
                  </div>
                </div>
              {%- else -%}
                <div class="hand-pdp-sizes">
                  {%- for value in option.values -%}
                    <button type="button"
                            class="hand-size-btn{% if option.selected_value == value %} selected{% endif %}"
                            data-option-index="{{ forloop.parentloop.index0 }}"
                            data-option-value="{{ value | escape }}"
                            data-option-label-id="optVal{{ forloop.parentloop.index }}"
                            onclick="pdpSelectOption(this)">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" id="pdpVariantId" value="{{ product.selected_or_first_available_variant.id }}">

        <!-- Urgency: Low stock + recent sales -->
        <div class="hand-pdp-urgency" id="pdpUrgency">
          <div class="hand-pdp-sold-recent">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>{{ product.id | modulo: 23 | plus: 8 }} sold in last 24 hours</span>
          </div>
        </div>

        <!-- Trust strip (SVG icons — no emojis) -->
        <div class="hand-pdp-trust">
          <div class="hand-pdp-trust-item">
            <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c-1.2 2-4 4-7 4v5c0 5.25 3.5 8.25 7 10 3.5-1.75 7-4.75 7-10V7c-3 0-5.8-2-7-4z"/></svg>
            100% Organic
          </div>
          <div class="hand-pdp-trust-item">
            <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 10l-4 4l-2-2"/><circle cx="12" cy="12" r="9"/></svg>
            UK Printed
          </div>
          <div class="hand-pdp-trust-item">
            <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M16 7V5a4 4 0 0 0-8 0v2"/></svg>
            Ships in 24h
          </div>
          <div class="hand-pdp-trust-item">
            <svg class="trust-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 14l-4-4m0 0l4-4m-4 4h11a4 4 0 0 1 0 8h-1"/></svg>
            30-Day Returns
          </div>
        </div>

        <!-- CTA — Add to Bag + Buy Now -->
        <div class="hand-pdp-cta">
          <div class="hand-pdp-qty">
            <button type="button" id="pdpMinus" aria-label="Decrease quantity">−</button>
            <input type="number" name="quantity" id="pdpQty" value="1" min="1" max="99" aria-label="Quantity">
            <button type="button" id="pdpPlus" aria-label="Increase quantity">+</button>
          </div>
          <button type="submit" class="hand-pdp-add-btn" id="pdpAddBtn"
                  {%- unless product.available %} disabled{%- endunless -%}>
            {%- if product.available -%}
              Add to Bag <span>→</span>
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        </div>

        {%- if product.available -%}
        <a href="/cart/{{ product.selected_or_first_available_variant.id }}:1" class="hand-pdp-buy-now" id="pdpBuyNow">
          Buy Now — Checkout Instantly
        </a>
        {%- endif -%}

        <!-- Estimated delivery -->
        <div class="hand-pdp-delivery">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Order now, estimated delivery <strong id="pdpDelivDate"></strong></span>
        </div>

        <!-- Payment icons -->
        <div class="hand-pdp-payments">
          <span class="pay-label">We Accept</span>
          <div class="pay-icons">
            <span class="pay-icon" title="Visa">VISA</span>
            <span class="pay-icon" title="Mastercard">MC</span>
            <span class="pay-icon" title="Amex">AMEX</span>
            <span class="pay-icon" title="PayPal">PP</span>
            <span class="pay-icon pay-klarna" title="Klarna">K</span>
          </div>
        </div>
      {%- endform -%}

      <!-- Description accordion -->
      <button class="hand-pdp-desc-toggle open" id="pdpDescToggle" onclick="pdpToggleDesc()">
        Description <span class="arr">↑</span>
      </button>
      <div class="hand-pdp-desc-body open" id="pdpDescBody">
        <div class="hand-pdp-desc-body-inner">
          {{ product.description }}
        </div>
      </div>

      <button class="hand-pdp-desc-toggle" id="pdpDetailsToggle" onclick="pdpToggleDetails()">
        Product Details <span class="arr">↓</span>
      </button>
      <div class="hand-pdp-desc-body" id="pdpDetailsBody">
        <div class="hand-pdp-desc-body-inner">
          <p>220gsm heavyweight organic cotton. Unisex fit. Hand-printed in our London studio using water-based inks.</p>
          <p>Part of the original 1990 Camden archive — reissued for the first time in 17 years. Same characters, same energy, new era.</p>
          <ul style="padding-left:18px;margin-top:8px;display:flex;flex-direction:column;gap:6px">
            <li>100% GOTS certified organic cotton</li>
            <li>220gsm heavyweight jersey</li>
            <li>Unisex fit — true to size</li>
            <li>Screen printed in London, UK</li>
            <li>Machine wash 30°C, inside out</li>
          </ul>
        </div>
      </div>

      <button class="hand-pdp-desc-toggle" id="pdpShipToggle" onclick="pdpToggleShip()">
        Shipping & Returns <span class="arr">↓</span>
      </button>
      <div class="hand-pdp-desc-body" id="pdpShipBody">
        <div class="hand-pdp-desc-body-inner">
          <p><strong>UK Standard:</strong> 2-4 working days · Free over £75</p>
          <p><strong>UK Express:</strong> Next working day (order before 2pm)</p>
          <p><strong>Europe:</strong> 5-10 working days</p>
          <p><strong>Rest of World:</strong> 7-14 working days</p>
          <p style="margin-top:12px">30-day returns on unworn, unwashed items. Free UK returns. <a href="/pages/contact" style="text-decoration:underline">Contact us</a> to start a return.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sticky Mobile CTA -->
{%- if product.available -%}
<div class="hand-pdp-sticky" id="pdpStickyBar">
  <div class="hand-pdp-sticky-inner">
    <div class="hand-pdp-sticky-info">
      <div class="hand-pdp-sticky-title">{{ product.title | truncate: 28 }}</div>
      <div class="hand-pdp-sticky-price">{{ product.price | money }}</div>
    </div>
    <button class="hand-pdp-sticky-btn" id="pdpStickyAdd">Add to Bag</button>
  </div>
</div>
{%- endif -%}

<!-- Related Products -->
{%- if product.collections.first -%}
  {%- assign related_coll = product.collections.first -%}
  {%- if related_coll.products_count > 1 -%}
    <div class="hand-pdp-related">
      <div class="hand-pdp-related-inner">
        <div class="hand-pdp-related-head">
          <h2>You Might Also Like.</h2>
          <a href="{{ related_coll.url }}">View All →</a>
        </div>
        <div class="hand-pdp-related-grid">
          {%- for p in related_coll.products limit: 5 -%}
            {%- unless p.id == product.id -%}
              <article class="hand-coll-card">
                <div class="hand-coll-card-media">
                  <span class="hand-coll-badge">{{ p.type | default: 'Apparel' }}</span>
                  {%- if p.featured_image -%}
                    <img src="{{ p.featured_image | image_url: width: 720 }}"
                         alt="{{ p.featured_image.alt | escape | default: p.title | escape }}"
                         loading="lazy" width="720" height="960">
                  {%- endif -%}
                  <div class="hand-coll-quick">
                    <button class="hand-coll-quick-btn"
                            data-variant-id="{{ p.selected_or_first_available_variant.id }}"
                            data-product-title="{{ p.title | escape }}"
                            data-quick-add>
                      {%- if p.available -%}Quick Add{%- else -%}Sold Out{%- endif -%}
                    </button>
                    <a class="hand-coll-quick-link" href="{{ p.url }}">↗</a>
                  </div>
                </div>
                <div class="hand-coll-card-info">
                  <div class="hand-coll-card-vendor">{{ p.vendor | default: 'Have A Nice Day' }}</div>
                  <a class="hand-coll-card-name" href="{{ p.url }}">{{ p.title }}</a>
                  <div class="hand-coll-card-price">{{ p.price | money }}</div>
                </div>
              </article>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}

<script>
// Gallery thumbnail switcher
function pdpSetImg(thumb) {
  const mainImg = document.getElementById('pdpMainImgEl');
  if (mainImg) {
    mainImg.src = thumb.dataset.src;
    mainImg.alt = thumb.dataset.alt;
  }
  document.querySelectorAll('.hand-pdp-thumb').forEach(function(t) { t.classList.remove('active'); });
  thumb.classList.add('active');
}

// Option selector
var pdpSelectedOptions = {};
{%- for option in product.options_with_values -%}
  pdpSelectedOptions[{{ forloop.index0 }}] = {{ option.selected_value | json }};
{%- endfor -%}

var pdpVariants = {{ product.variants | json }};

// Build a map of variant image positions: variantId → image src
// Shopify variants have a featured_image property with position
var pdpVariantImages = {};
{%- for variant in product.variants -%}
  {%- if variant.featured_image -%}
    pdpVariantImages[{{ variant.id }}] = {
      src: {{ variant.featured_image | image_url: width: 1200 | json }},
      thumb: {{ variant.featured_image | image_url: width: 200 | json }},
      alt: {{ variant.featured_image.alt | default: product.title | json }},
      position: {{ variant.featured_image.position }}
    };
  {%- endif -%}
{%- endfor -%}

function pdpSelectOption(btn) {
  const idx = parseInt(btn.dataset.optionIndex);
  const val = btn.dataset.optionValue;
  const labelId = btn.dataset.optionLabelId;
  pdpSelectedOptions[idx] = val;
  // Update button states
  document.querySelectorAll('[data-option-index="' + idx + '"]').forEach(function(b) {
    b.classList.toggle('selected', b.dataset.optionValue === val);
  });
  // Update label
  const label = document.getElementById(labelId);
  if (label) label.textContent = val;
  // Find matching variant
  const variant = pdpVariants.find(function(v) {
    return v.options.every(function(o, i) { return o === pdpSelectedOptions[i]; });
  });
  if (variant) {
    document.getElementById('pdpVariantId').value = variant.id;
    // Update Buy Now link so it sends the CORRECT variant to checkout
    var buyNowLink = document.getElementById('pdpBuyNow');
    if (buyNowLink) buyNowLink.href = '/cart/' + variant.id + ':1';
    // Update URL with variant ID for sharing / Shop app compatibility
    var newUrl = window.location.pathname + '?variant=' + variant.id;
    window.history.replaceState({ path: newUrl }, '', newUrl);
    const addBtn = document.getElementById('pdpAddBtn');
    if (addBtn) {
      if (variant.available) {
        addBtn.disabled = false;
        addBtn.innerHTML = 'Add to Bag <span>→</span>';
      } else {
        addBtn.disabled = true;
        addBtn.innerHTML = 'Sold Out';
      }
    }
    // Update price
    const priceEl = document.querySelector('.hand-pdp-price');
    if (priceEl) priceEl.textContent = (variant.price / 100).toLocaleString('en-GB', { style: 'currency', currency: 'GBP' });

    // ---- IMAGE SWAP: switch to variant's featured image ----
    var varImg = pdpVariantImages[variant.id];
    if (varImg) {
      // Update main image
      var mainImg = document.getElementById('pdpMainImgEl');
      if (mainImg) {
        mainImg.style.opacity = '0';
        mainImg.style.transition = 'opacity .25s ease';
        setTimeout(function() {
          mainImg.src = varImg.src;
          mainImg.alt = varImg.alt;
          mainImg.style.opacity = '1';
        }, 150);
      }
      // Highlight the matching thumbnail
      var thumbs = document.querySelectorAll('.hand-pdp-thumb');
      thumbs.forEach(function(t) {
        t.classList.remove('active');
        if (t.dataset.src === varImg.src) {
          t.classList.add('active');
          // Scroll thumbnail into view if needed
          t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      });
    }
  }
}

// Qty
document.getElementById('pdpMinus')?.addEventListener('click', function() {
  const q = document.getElementById('pdpQty');
  if (q && parseInt(q.value) > 1) q.value = parseInt(q.value) - 1;
});
document.getElementById('pdpPlus')?.addEventListener('click', function() {
  const q = document.getElementById('pdpQty');
  if (q) q.value = parseInt(q.value) + 1;
});

// Description toggles
function pdpToggleDesc() {
  const body = document.getElementById('pdpDescBody');
  const btn = document.getElementById('pdpDescToggle');
  const open = body.classList.toggle('open');
  btn.classList.toggle('open', open);
  btn.querySelector('.arr').textContent = open ? '↑' : '↓';
}
function pdpToggleDetails() {
  const body = document.getElementById('pdpDetailsBody');
  const btn = document.getElementById('pdpDetailsToggle');
  const open = body.classList.toggle('open');
  btn.classList.toggle('open', open);
  btn.querySelector('.arr').textContent = open ? '↑' : '↓';
}
function pdpToggleShip() {
  const body = document.getElementById('pdpShipBody');
  const btn = document.getElementById('pdpShipToggle');
  const open = body.classList.toggle('open');
  btn.classList.toggle('open', open);
  btn.querySelector('.arr').textContent = open ? '↑' : '↓';
}

// Size guide toggle
document.getElementById('pdpSizeGuide')?.addEventListener('click', function() {});

// ---- ESTIMATED DELIVERY DATE ----
(function() {
  var el = document.getElementById('pdpDelivDate');
  if (!el) return;
  var now = new Date();
  var days = now.getHours() < 14 ? 3 : 4; // order before 2pm = faster
  var d = new Date(now);
  var added = 0;
  while (added < days) {
    d.setDate(d.getDate() + 1);
    if (d.getDay() !== 0 && d.getDay() !== 6) added++; // skip weekends
  }
  var opts = { weekday: 'short', month: 'short', day: 'numeric' };
  el.textContent = d.toLocaleDateString('en-GB', opts);
})();

// ---- VIEWER COUNT: subtle fluctuation ----
(function() {
  var el = document.getElementById('viewerCount');
  if (!el) return;
  var base = parseInt(el.textContent) || 5;
  setInterval(function() {
    var delta = Math.random() > 0.5 ? 1 : -1;
    base = Math.max(2, Math.min(base + delta, base + 3));
    el.textContent = base;
  }, 8000 + Math.random() * 7000);
})();

// Add to cart form
document.querySelector('.pdp-form')?.addEventListener('submit', function(e) {
  e.preventDefault();
  const btn = document.getElementById('pdpAddBtn');
  const variantId = document.getElementById('pdpVariantId').value;
  const qty = parseInt(document.getElementById('pdpQty').value) || 1;
  if (!variantId || btn.disabled) return;
  btn.innerHTML = 'Adding...';
  btn.disabled = true;
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ id: variantId, quantity: qty })
  })
  .then(function(r) { return r.json(); })
  .then(function() {
    btn.innerHTML = 'Added ✓';
    fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
      const el = document.getElementById('handCartCount');
      if (el) el.textContent = cart.item_count;
    });
    const wrap = document.getElementById('hand-toast-wrap');
    if (wrap) {
      const t = document.createElement('div');
      t.className = 'hand-toast ok';
      t.innerHTML = '<span class="ic">☻</span><span>{{ product.title | escape }} added to bag</span>';
      wrap.appendChild(t);
      requestAnimationFrame(function() { t.classList.add('show'); });
      setTimeout(function() { t.classList.remove('show'); setTimeout(function() { t.remove(); }, 400); }, 3000);
    }
    setTimeout(function() { btn.innerHTML = 'Add to Bag <span>→</span>'; btn.disabled = false; }, 2000);
  })
  .catch(function() {
    btn.innerHTML = 'Error — Try Again';
    btn.disabled = false;
  });
});

// Quick add in related
document.querySelectorAll('[data-quick-add]').forEach(function(btn) {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const variantId = btn.dataset.variantId;
    const title = btn.dataset.productTitle;
    if (!variantId || btn.textContent.trim() === 'Sold Out') return;
    btn.textContent = 'Adding...';
    btn.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function() {
      btn.textContent = 'Added ✓';
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(cart) {
        const el = document.getElementById('handCartCount');
        if (el) el.textContent = cart.item_count;
      });
      setTimeout(function() { btn.textContent = 'Quick Add'; btn.disabled = false; }, 2000);
    })
    .catch(function() { btn.textContent = 'Error'; btn.disabled = false; });
  });
});

// ---- STICKY MOBILE BAR: show when Add to Bag scrolls out of view ----
(function() {
  var stickyBar = document.getElementById('pdpStickyBar');
  var addBtn = document.getElementById('pdpAddBtn');
  if (!stickyBar || !addBtn) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      stickyBar.classList.toggle('visible', !e.isIntersecting);
    });
  }, { threshold: 0 });
  observer.observe(addBtn);
  // Sticky add triggers form submit
  document.getElementById('pdpStickyAdd')?.addEventListener('click', function() {
    document.querySelector('.pdp-form')?.dispatchEvent(new Event('submit', { cancelable: true }));
  });
})();
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "header",
      "content": "Product Page Settings"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor / brand name",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show SKU",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_share",
      "label": "Show share buttons",
      "default": true
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "trust1",
      "label": "Trust badge 1",
      "default": "Free UK Shipping Over £75"
    },
    {
      "type": "text",
      "id": "trust2",
      "label": "Trust badge 2",
      "default": "30-Day Free Returns"
    },
    {
      "type": "text",
      "id": "trust3",
      "label": "Trust badge 3",
      "default": "220gsm Organic Cotton"
    },
    {
      "type": "text",
      "id": "trust4",
      "label": "Trust badge 4",
      "default": "UK Printed — Small Batch"
    },
    {
      "type": "header",
      "content": "Related Products"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "Related products heading",
      "default": "You Might Also Like"
    },
    {
      "type": "range",
      "id": "related_count",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of related products",
      "default": 4
    }
  ]
}
{% endschema %}
